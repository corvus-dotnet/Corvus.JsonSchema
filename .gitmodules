[submodule "JSON-Schema-Test-Suite"]
	path = JSON-Schema-Test-Suite
	url = https://github.com/json-schema-org/JSON-Schema-Test-Suite
[submodule "tests/json-patch-tests"]
	path = tests/json-patch-tests
	url = https://github.com/json-patch/json-patch-tests.git
[submodule "Jsonata-Test-Suite"]
	path = Jsonata-Test-Suite
	url = https://github.com/jsonata-js/jsonata.git
[submodule "JMESPath-Test-Suite"]
	path = JMESPath-Test-Suite
	url = https://github.com/jmespath/jmespath.test
# yaml-test-suite publishes its consumable directory-per-test data on the orphan
# `data` branch, which upstream periodically REGENERATES and force-pushes. Do not
# track that branch (its HEAD changes SHA without changing content, giving false
# "behind" signals and non-diffable updates). The pin below is the immutable
# `data-2022-01-17` tag (commit 6e6c296). When a newer dated `data-YYYY-MM-DD` tag
# is published, update the gitlink to that tag's commit.
[submodule "yaml-test-suite"]
	path = yaml-test-suite
	url = https://github.com/yaml/yaml-test-suite.git
[submodule "jsonpath-compliance-test-suite"]
	path = jsonpath-compliance-test-suite
	url = https://github.com/jsonpath-standard/jsonpath-compliance-test-suite.git
[submodule "toon-format-spec"]
	path = toon-format-spec
	url = https://github.com/toon-format/spec.git
