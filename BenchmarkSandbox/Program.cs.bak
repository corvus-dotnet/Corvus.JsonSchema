using System;
using System.Buffers;
using System.Text;
using Corvus.Text.Json;
using Corvus.Text.Json.Jsonata;

string dataJson = """
    {
        "Account": {
            "Account Name": "Firefly",
            "Order": [
                {
                    "OrderID": "order103",
                    "Product": [
                        {"Product Name": "Bowler Hat", "ProductID": 858383, "Price": 34.45, "Quantity": 2},
                        {"Product Name": "Trilby hat", "ProductID": 858236, "Price": 21.67, "Quantity": 1}
                    ]
                },
                {
                    "OrderID": "order104",
                    "Product": [
                        {"Product Name": "Bowler Hat", "ProductID": 858383, "Price": 34.45, "Quantity": 4},
                        {"Product Name": "Cloak", "ProductID": 345664, "Price": 107.99, "Quantity": 1}
                    ]
                }
            ]
        }
    }
    """;

using var doc = ParsedJsonDocument<JsonElement>.Parse(Encoding.UTF8.GetBytes(dataJson));
var data = doc.RootElement;
var evaluator = new JsonataEvaluator();
using var workspace = JsonWorkspace.Create();

// ---- Test 1: ArrayPool rent/return cycle in isolation ----
Console.WriteLine("=== ArrayPool<JsonElement> rent/return overhead ===");
{
    // Warmup
    var arr = ArrayPool<JsonElement>.Shared.Rent(8);
    ArrayPool<JsonElement>.Shared.Return(arr);
    for (int i = 0; i < 100; i++)
    {
        arr = ArrayPool<JsonElement>.Shared.Rent(8);
        ArrayPool<JsonElement>.Shared.Return(arr);
    }

    GC.Collect(2, GCCollectionMode.Forced, true, true);
    long before = GC.GetAllocatedBytesForCurrentThread();
    for (int i = 0; i < 1000; i++)
    {
        arr = ArrayPool<JsonElement>.Shared.Rent(8);
        ArrayPool<JsonElement>.Shared.Return(arr);
    }
    long after = GC.GetAllocatedBytesForCurrentThread();
    Console.WriteLine($"  Rent+Return cycle: {(after - before) / 1000.0:F1} bytes/iter");
}

// ---- Test 2: CreateArrayBuilder in workspace (what ArrayFromSequence does) ----
Console.WriteLine("\n=== CreateArrayBuilder + AddItem overhead ===");
{
    // Warmup
    for (int i = 0; i < 100; i++)
    {
        workspace.Reset();
        var builder = JsonElement.CreateArrayBuilder(workspace, 4);
        var root = builder.RootElement;
        root.AddItem(data);
        root.AddItem(data);
        root.AddItem(data);
        root.AddItem(data);
    }

    GC.Collect(2, GCCollectionMode.Forced, true, true);
    long before = GC.GetAllocatedBytesForCurrentThread();
    for (int i = 0; i < 1000; i++)
    {
        workspace.Reset();
        var builder = JsonElement.CreateArrayBuilder(workspace, 4);
        var root = builder.RootElement;
        root.AddItem(data);
        root.AddItem(data);
        root.AddItem(data);
        root.AddItem(data);
    }
    long after = GC.GetAllocatedBytesForCurrentThread();
    Console.WriteLine($"  CreateArrayBuilder+4xAddItem: {(after - before) / 1000.0:F1} bytes/iter");
}

// ---- Test 3: CreateObjectBuilder + SetProperty ----
Console.WriteLine("\n=== CreateObjectBuilder + SetProperty overhead ===");
{
    byte[] key1 = "name"u8.ToArray();
    byte[] key2 = "price"u8.ToArray();
    var nameElem = doc.RootElement; // just use something
    for (int i = 0; i < 100; i++)
    {
        workspace.Reset();
        var builder = JsonElement.CreateObjectBuilder(workspace, 2);
        var root = builder.RootElement;
        root.SetProperty(key1, (JsonElement.Source)"hello");
        root.SetProperty(key2, (JsonElement.Source)34.45);
    }

    GC.Collect(2, GCCollectionMode.Forced, true, true);
    long before = GC.GetAllocatedBytesForCurrentThread();
    for (int i = 0; i < 1000; i++)
    {
        workspace.Reset();
        var builder = JsonElement.CreateObjectBuilder(workspace, 2);
        var root = builder.RootElement;
        root.SetProperty(key1, (JsonElement.Source)"hello");
        root.SetProperty(key2, (JsonElement.Source)34.45);
    }
    long after = GC.GetAllocatedBytesForCurrentThread();
    Console.WriteLine($"  CreateObjectBuilder+2xSetProperty: {(after - before) / 1000.0:F1} bytes/iter");
}

// ---- Test 4: Just the evaluator call (simple property chain) ----
Console.WriteLine("\n=== Evaluator overhead by expression ===");
var expressions = new (string Name, string Expr)[]
{
    ("PureArithmetic", "1 + 2 * 3 - 4 / 2 + 10 % 3"),
    ("ArrayIndex",     "Account.Order[0].OrderID"),
    ("DeepPath",       "Account.Order.Product.Price"),
    ("MapArithmetic",  "Account.Order.Product.(Price * Quantity)"),
    ("GroupByObject",  "Account.Order.Product.{`Product Name`: Price}"),
    ("ArrayOfObjects", """[Account.Order.Product.{"name": `Product Name`, "total": Price * Quantity}]"""),
};

const int iterations = 1000;
foreach (var (name, expr) in expressions)
{
    // Warmup
    for (int i = 0; i < 200; i++)
    {
        workspace.Reset();
        evaluator.Evaluate(expr, data, workspace);
    }

    GC.Collect(2, GCCollectionMode.Forced, true, true);
    GC.WaitForPendingFinalizers();
    GC.Collect(2, GCCollectionMode.Forced, true, true);

    long before = GC.GetAllocatedBytesForCurrentThread();
    for (int i = 0; i < iterations; i++)
    {
        workspace.Reset();
        evaluator.Evaluate(expr, data, workspace);
    }
    long after = GC.GetAllocatedBytesForCurrentThread();

    Console.WriteLine($"  {name,-20} {(after - before) / iterations,8} bytes/iter");
}

Console.WriteLine("\nDone.");