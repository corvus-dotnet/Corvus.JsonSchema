<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net10.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <IsPackable>false</IsPackable>
    <NoWarn>$(NoWarn);CS1591;SA1615;CA1822;CS0618;CS0108</NoWarn>
    <Platforms>AnyCPU</Platforms>
    <LangVersion>Preview</LangVersion>
  </PropertyGroup>
  <ItemGroup>
    <PackageReference Include="BenchmarkDotNet" />
  </ItemGroup>
  <!-- The row-security resolver lives in the ASP.NET-hosted control-plane server; reference its framework so the
       benchmark exe can load that assembly (the policy is only constructed and called, never actually hosted). -->
  <ItemGroup>
    <FrameworkReference Include="Microsoft.AspNetCore.App" />
  </ItemGroup>
  <ItemGroup>
    <ProjectReference Include="..\..\src\Corvus.Text.Json.Arazzo.Durability\Corvus.Text.Json.Arazzo.Durability.csproj" />
    <ProjectReference Include="..\..\src\Corvus.Text.Json.Arazzo.Durability.Cosmos\Corvus.Text.Json.Arazzo.Durability.Cosmos.csproj" />
    <ProjectReference Include="..\..\src\Corvus.Text.Json.Arazzo.Durability.ControlPlane.Server\Corvus.Text.Json.Arazzo.Durability.ControlPlane.Server.csproj" />
    <ProjectReference Include="..\..\src\Corvus.Text.Json.Arazzo.Durability.Sqlite\Corvus.Text.Json.Arazzo.Durability.Sqlite.csproj" />
    <ProjectReference Include="..\..\src\Corvus.Text.Json.Arazzo.SourceCredentials.Http\Corvus.Text.Json.Arazzo.SourceCredentials.Http.csproj" />
    <ProjectReference Include="..\..\src\Corvus.Text.Json.Arazzo.Directories.Keycloak\Corvus.Text.Json.Arazzo.Directories.Keycloak.csproj" />
    <ProjectReference Include="..\..\src\Corvus.Text.Json.Arazzo.Directories.Scim\Corvus.Text.Json.Arazzo.Directories.Scim.csproj" />
    <ProjectReference Include="..\..\src\Corvus.Text.Json.Arazzo.Directories.EntraId\Corvus.Text.Json.Arazzo.Directories.EntraId.csproj" />
  </ItemGroup>
</Project>