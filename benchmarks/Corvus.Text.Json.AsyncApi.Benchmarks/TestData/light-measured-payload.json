{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "LightMeasuredPayload",
  "description": "A sensor reading from a streetlight.",
  "type": "object",
  "required": ["id", "lumens", "sentAt"],
  "properties": {
    "id": {
      "type": "integer",
      "minimum": 0,
      "description": "Sensor ID."
    },
    "lumens": {
      "type": "number",
      "minimum": 0,
      "description": "Current lumens measurement."
    },
    "sentAt": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp of the measurement."
    }
  },
  "additionalProperties": false
}