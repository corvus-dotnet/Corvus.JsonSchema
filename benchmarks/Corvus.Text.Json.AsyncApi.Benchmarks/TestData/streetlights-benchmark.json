{
  "asyncapi": "3.0.0",
  "info": {
    "title": "Streetlights Benchmark API",
    "version": "1.0.0",
    "description": "A minimal AsyncAPI spec for benchmarking the generated consumer/producer pipeline."
  },
  "defaultContentType": "application/json",
  "channels": {
    "lightingMeasured": {
      "address": "smartylighting.streetlights.1.0.event.lighting.measured",
      "messages": {
        "lightMeasured": {
          "$ref": "#/components/messages/lightMeasured"
        }
      },
      "description": "The topic on which measured values may be produced and consumed."
    },
    "dimRequest": {
      "address": "smartylighting.streetlights.1.0.action.dim",
      "messages": {
        "dimCommand": {
          "$ref": "#/components/messages/dimCommand"
        },
        "dimResponse": {
          "$ref": "#/components/messages/dimResponse"
        }
      },
      "description": "Request/reply channel for dimming commands."
    },
    "dimReply": {
      "address": "smartylighting.streetlights.1.0.action.dim.reply",
      "messages": {
        "dimResponse": {
          "$ref": "#/components/messages/dimResponse"
        }
      },
      "description": "Reply channel for dimming acknowledgements."
    }
  },
  "operations": {
    "receiveLightMeasurement": {
      "action": "receive",
      "channel": {
        "$ref": "#/channels/lightingMeasured"
      },
      "summary": "Receive light measurement readings from sensors.",
      "messages": [
        {
          "$ref": "#/channels/lightingMeasured/messages/lightMeasured"
        }
      ]
    },
    "publishLightMeasurement": {
      "action": "send",
      "channel": {
        "$ref": "#/channels/lightingMeasured"
      },
      "summary": "Publish light measurement readings.",
      "messages": [
        {
          "$ref": "#/channels/lightingMeasured/messages/lightMeasured"
        }
      ]
    },
    "requestDim": {
      "action": "send",
      "channel": {
        "$ref": "#/channels/dimRequest"
      },
      "summary": "Send a dimming command and wait for acknowledgement.",
      "messages": [
        {
          "$ref": "#/channels/dimRequest/messages/dimCommand"
        }
      ],
      "reply": {
        "channel": {
          "$ref": "#/channels/dimReply"
        },
        "messages": [
          {
            "$ref": "#/channels/dimReply/messages/dimResponse"
          }
        ]
      }
    }
  },
  "components": {
    "messages": {
      "lightMeasured": {
        "name": "lightMeasured",
        "title": "Light measured",
        "summary": "A sensor reading from a streetlight.",
        "contentType": "application/json",
        "payload": {
          "$ref": "#/components/schemas/lightMeasuredPayload"
        }
      },
      "dimCommand": {
        "name": "dimCommand",
        "title": "Dim command",
        "summary": "A command to set a streetlight's dimming level.",
        "contentType": "application/json",
        "payload": {
          "$ref": "#/components/schemas/dimCommandPayload"
        },
        "headers": {
          "$ref": "#/components/schemas/correlatedHeaders"
        },
        "correlationId": {
          "location": "$message.header#/correlationId"
        }
      },
      "dimResponse": {
        "name": "dimResponse",
        "title": "Dim response",
        "summary": "Acknowledgement of a dimming command.",
        "contentType": "application/json",
        "payload": {
          "$ref": "#/components/schemas/dimResponsePayload"
        },
        "headers": {
          "$ref": "#/components/schemas/correlatedHeaders"
        },
        "correlationId": {
          "location": "$message.header#/correlationId"
        }
      }
    },
    "schemas": {
      "lightMeasuredPayload": {
        "type": "object",
        "required": ["id", "lumens", "sentAt"],
        "properties": {
          "id": {
            "type": "integer",
            "minimum": 0,
            "description": "Sensor ID."
          },
          "lumens": {
            "type": "number",
            "minimum": 0,
            "description": "Current lumens measurement."
          },
          "sentAt": {
            "type": "string",
            "format": "date-time",
            "description": "ISO 8601 timestamp of the measurement."
          }
        },
        "additionalProperties": false
      },
      "dimCommandPayload": {
        "type": "object",
        "required": ["streetlightId", "percentage"],
        "properties": {
          "streetlightId": {
            "type": "integer",
            "minimum": 0,
            "description": "The streetlight to dim."
          },
          "percentage": {
            "type": "integer",
            "minimum": 0,
            "maximum": 100,
            "description": "Target brightness percentage."
          },
          "sentAt": {
            "type": "string",
            "format": "date-time",
            "description": "ISO 8601 timestamp of the command."
          }
        },
        "additionalProperties": false
      },
      "dimResponsePayload": {
        "type": "object",
        "required": ["streetlightId", "status"],
        "properties": {
          "streetlightId": {
            "type": "integer",
            "minimum": 0,
            "description": "The streetlight that was dimmed."
          },
          "status": {
            "type": "string",
            "enum": ["ok", "error"],
            "description": "Whether the dimming succeeded."
          },
          "appliedPercentage": {
            "type": "integer",
            "minimum": 0,
            "maximum": 100,
            "description": "The actual brightness applied."
          }
        },
        "additionalProperties": false
      },
      "correlatedHeaders": {
        "type": "object",
        "required": ["correlationId"],
        "properties": {
          "correlationId": {
            "type": "string",
            "description": "Unique correlation identifier for request/reply matching."
          }
        }
      }
    }
  }
}