<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net10.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <IsPackable>false</IsPackable>
    <NoWarn>$(NoWarn);CS1591;SA1615;CA1822;CS0618;CS0108</NoWarn>
    <Platforms>AnyCPU</Platforms>
    <LangVersion>Preview</LangVersion>
    <PreserveCompilationContext>true</PreserveCompilationContext>
    <EmitCompilerGeneratedFiles>true</EmitCompilerGeneratedFiles>
  </PropertyGroup>
  <ItemGroup>
    <PackageReference Include="BenchmarkDotNet" />
    <PackageReference Include="BenchmarkDotNet.Diagnostics.Windows" />
    <PackageReference Include="JsonCons.JsonPath" />
    <PackageReference Include="JsonPath.Net" />
  </ItemGroup>
  <ItemGroup>
    <ProjectReference Include="..\..\src\Corvus.Text.Json.JsonPath\Corvus.Text.Json.JsonPath.csproj" />
    <ProjectReference Include="..\..\src\Corvus.Text.Json\Corvus.Text.Json.csproj" />
  </ItemGroup>
  <!-- Source generator reference (analyzer-only, no runtime DLL) -->
  <ItemGroup>
    <ProjectReference Include="..\..\src\Corvus.Text.Json.JsonPath.SourceGenerator\Corvus.Text.Json.JsonPath.SourceGenerator.csproj" PrivateAssets="all" ReferenceOutputAssembly="false" OutputItemType="Analyzer" />
  </ItemGroup>
  <!-- JSONPath expression files for source-generated evaluators -->
  <ItemGroup>
    <AdditionalFiles Include="Expressions\*.jsonpath" />
  </ItemGroup>
</Project>
