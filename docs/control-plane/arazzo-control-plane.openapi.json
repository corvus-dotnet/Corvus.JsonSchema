{
  "openapi": "3.2.0",
  "$self": "https://corvus-oss.org/arazzo/control-plane/openapi.json",
  "info": {
    "title": "Arazzo Workflow Control Plane API",
    "summary": "Inspect and remediate durable Arazzo workflow runs.",
    "description": "A REST surface over the Arazzo durability control plane (`IWorkflowManagementClient`, plan §11): list and inspect runs, resume a faulted run, cancel a run, and reap terminal ones. It is the workflow-level analogue of dead-letter inspection and redelivery. Every control action takes a single-owner lease and writes under optimistic concurrency, so concurrent operators — or an operator and a worker — cannot conflict. This document is the contract a CLI (`arazzo-runs`) and other clients are generated against; an implementation maps each operation onto the corresponding `IWorkflowManagementClient` method over a chosen durability store.",
    "version": "0.1.0",
    "license": { "name": "Apache-2.0", "identifier": "Apache-2.0" }
  },
  "servers": [
    {
      "url": "{scheme}://{host}/arazzo/v1",
      "description": "The control-plane host (a service the operator deploys alongside its durability store).",
      "variables": {
        "scheme": { "enum": ["https", "http"], "default": "https" },
        "host": { "default": "localhost:8080" }
      }
    }
  ],
  "security": [
    { "oauth2": ["runs:read"] },
    { "openIdConnect": ["runs:read"] },
    { "mtls": [] }
  ],
  "tags": [
    {
      "name": "runs",
      "summary": "Workflow runs",
      "description": "Visibility and remediation for durable workflow runs."
    }
  ],
  "paths": {
    "/runs": {
      "get": {
        "operationId": "listRuns",
        "security": [
          { "oauth2": ["runs:read"] },
          { "openIdConnect": ["runs:read"] },
          { "mtls": [] }
        ],
        "tags": ["runs"],
        "summary": "List runs",
        "description": "Returns a page of runs matching the visibility query. Backed by the store's wait/visibility index (the same index Tier 2 uses for wakeups), so the filters are answered server-side.",
        "parameters": [
          { "$ref": "#/components/parameters/StatusQuery" },
          { "$ref": "#/components/parameters/WorkflowIdQuery" },
          { "$ref": "#/components/parameters/LimitQuery" },
          { "$ref": "#/components/parameters/PageTokenQuery" }
        ],
        "responses": {
          "200": {
            "description": "A page of matching runs.",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/WorkflowRunPage" }
              }
            },
            "links": {
              "next": { "$ref": "#/components/links/NextPage" }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" }
        }
      },
      "additionalOperations": {
        "PURGE": {
          "operationId": "purgeRuns",
          "security": [
            { "oauth2": ["runs:purge"] },
            { "openIdConnect": ["runs:purge"] },
            { "mtls": [] }
          ],
          "tags": ["runs"],
          "summary": "Purge terminal runs",
          "description": "Reaps completed and cancelled runs last updated strictly before `olderThan`, up to `limit`. Non-terminal runs (including faulted ones, which are terminal-but-recoverable) are never purged.",
          "parameters": [
            { "$ref": "#/components/parameters/OlderThanQuery" },
            { "$ref": "#/components/parameters/LimitQuery" }
          ],
          "responses": {
            "200": {
              "description": "The number of runs deleted.",
              "content": {
                "application/json": {
                  "schema": { "$ref": "#/components/schemas/PurgeResult" }
                }
              }
            },
            "400": { "$ref": "#/components/responses/BadRequest" }
          }
        }
      }
    },
    "/runs/{runId}": {
      "parameters": [{ "$ref": "#/components/parameters/RunIdPath" }],
      "get": {
        "operationId": "getRun",
        "security": [
          { "oauth2": ["runs:read"] },
          { "openIdConnect": ["runs:read"] },
          { "mtls": [] }
        ],
        "tags": ["runs"],
        "summary": "Get a run",
        "description": "Returns a run's management detail — status, cursor, wait/fault detail and etag — from its authoritative checkpoint.",
        "responses": {
          "200": {
            "description": "The run detail.",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/WorkflowRunDetail" }
              }
            },
            "links": {
              "resume": { "$ref": "#/components/links/ResumeRun" },
              "cancel": { "$ref": "#/components/links/CancelRun" },
              "delete": { "$ref": "#/components/links/DeleteRun" }
            }
          },
          "404": { "$ref": "#/components/responses/NotFound" }
        }
      },
      "delete": {
        "operationId": "deleteRun",
        "security": [
          { "oauth2": ["runs:purge"] },
          { "openIdConnect": ["runs:purge"] },
          { "mtls": [] }
        ],
        "tags": ["runs"],
        "summary": "Delete a run",
        "description": "Permanently deletes a single run by id, regardless of status. Unlike `PURGE /runs` (which reaps only old terminal runs in bulk), this removes exactly the named run — the operator's explicit \"remove this\" action. Destructive: requires the `runs:purge` scope.",
        "responses": {
          "204": { "description": "The run was deleted." },
          "404": { "$ref": "#/components/responses/NotFound" },
          "409": { "$ref": "#/components/responses/Conflict" }
        }
      }
    },
    "/runs/{runId}/resume": {
      "parameters": [{ "$ref": "#/components/parameters/RunIdPath" }],
      "post": {
        "operationId": "resumeRun",
        "security": [
          { "oauth2": ["runs:write"] },
          { "openIdConnect": ["runs:write"] },
          { "mtls": [] }
        ],
        "tags": ["runs"],
        "summary": "Resume a faulted run",
        "description": "Resumes a faulted run, re-executing it from its last checkpoint (the faulted step). Only a run in the `Faulted` state can be resumed. Returns the run's new detail on success. An implementation MAY process the resume asynchronously and instead return `202 Accepted`.",
        "requestBody": {
          "required": false,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/ResumeRequest" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "The run was resumed; the body is its new detail.",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/WorkflowRunDetail" }
              }
            }
          },
          "404": { "$ref": "#/components/responses/NotFound" },
          "409": { "$ref": "#/components/responses/Conflict" }
        }
      }
    },
    "/runs/{runId}/cancel": {
      "parameters": [{ "$ref": "#/components/parameters/RunIdPath" }],
      "post": {
        "operationId": "cancelRun",
        "security": [
          { "oauth2": ["runs:write"] },
          { "openIdConnect": ["runs:write"] },
          { "mtls": [] }
        ],
        "tags": ["runs"],
        "summary": "Cancel a run",
        "description": "Cancels a non-terminal run, marking it `Cancelled` (any fault record is kept for post-mortem visibility). Returns the run's new detail on success.",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": { "$ref": "#/components/schemas/CancelRequest" }
            }
          }
        },
        "responses": {
          "200": {
            "description": "The run was cancelled; the body is its new detail.",
            "content": {
              "application/json": {
                "schema": { "$ref": "#/components/schemas/WorkflowRunDetail" }
              }
            }
          },
          "400": { "$ref": "#/components/responses/BadRequest" },
          "404": { "$ref": "#/components/responses/NotFound" },
          "409": { "$ref": "#/components/responses/Conflict" }
        }
      }
    }
  },
  "components": {
    "securitySchemes": {
      "oauth2": {
        "type": "oauth2",
        "description": "OAuth2 bearer access tokens scoped to the control plane's capability tiers. Interactive operators use the authorization-code flow (with PKCE, or device-code at the IdP); services and the CLI use client-credentials. The authorization server is chosen by the deployment — the URLs below are placeholders.",
        "flows": {
          "authorizationCode": {
            "authorizationUrl": "https://login.example.com/oauth2/authorize",
            "tokenUrl": "https://login.example.com/oauth2/token",
            "refreshUrl": "https://login.example.com/oauth2/token",
            "scopes": {
              "runs:read": "List and read workflow runs (visibility).",
              "runs:write": "Resume and cancel workflow runs (remediation).",
              "runs:purge": "Permanently delete terminal runs (destructive)."
            }
          },
          "clientCredentials": {
            "tokenUrl": "https://login.example.com/oauth2/token",
            "scopes": {
              "runs:read": "List and read workflow runs (visibility).",
              "runs:write": "Resume and cancel workflow runs (remediation).",
              "runs:purge": "Permanently delete terminal runs (destructive)."
            }
          }
        }
      },
      "openIdConnect": {
        "type": "openIdConnect",
        "description": "OpenID Connect discovery for the same access tokens and scopes (runs:read / runs:write / runs:purge); the discovery URL is deployment-specific (placeholder shown).",
        "openIdConnectUrl": "https://login.example.com/.well-known/openid-configuration"
      },
      "mtls": {
        "type": "mutualTLS",
        "description": "Mutual-TLS client-certificate authentication, for zero-trust service/operator callers that prefer certificates over tokens. Mutual TLS carries no scopes, so the host maps the client certificate's identity to a capability tier (read/write/purge) out of band."
      }
    },
    "parameters": {
      "RunIdPath": {
        "name": "runId",
        "in": "path",
        "required": true,
        "description": "The run id.",
        "schema": { "type": "string" }
      },
      "StatusQuery": {
        "name": "status",
        "in": "query",
        "required": false,
        "description": "Restrict to runs in this lifecycle status.",
        "schema": { "$ref": "#/components/schemas/WorkflowRunStatus" }
      },
      "WorkflowIdQuery": {
        "name": "workflowId",
        "in": "query",
        "required": false,
        "description": "Restrict to runs of this workflow.",
        "schema": { "type": "string" }
      },
      "LimitQuery": {
        "name": "limit",
        "in": "query",
        "required": false,
        "description": "The maximum number of runs to return (or delete, for purge).",
        "schema": { "type": "integer", "minimum": 1, "maximum": 1000, "default": 100 }
      },
      "PageTokenQuery": {
        "name": "pageToken",
        "in": "query",
        "required": false,
        "description": "An opaque continuation token from a previous page's `nextPageToken`, for paging.",
        "schema": { "type": "string" }
      },
      "OlderThanQuery": {
        "name": "olderThan",
        "in": "query",
        "required": true,
        "description": "Reap terminal runs last updated strictly before this instant (RFC 3339 date-time).",
        "schema": { "type": "string", "format": "date-time" }
      }
    },
    "responses": {
      "BadRequest": {
        "description": "The request was malformed.",
        "content": {
          "application/problem+json": {
            "schema": { "$ref": "#/components/schemas/ProblemDetails" }
          }
        }
      },
      "NotFound": {
        "description": "No run with that id exists.",
        "content": {
          "application/problem+json": {
            "schema": { "$ref": "#/components/schemas/ProblemDetails" },
            "examples": {
              "notFound": {
                "value": {
                  "type": "https://corvus-oss.org/arazzo/control-plane/problems/run-not-found",
                  "title": "Run not found",
                  "status": 404,
                  "detail": "No run with id 'adopt-42' exists."
                }
              }
            }
          }
        }
      },
      "Conflict": {
        "description": "The action does not apply in the run's current state, or the run is held by another owner (lease) or was changed concurrently.",
        "content": {
          "application/problem+json": {
            "schema": { "$ref": "#/components/schemas/ProblemDetails" },
            "examples": {
              "notFaulted": {
                "summary": "Resume requested for a run that is not faulted",
                "value": {
                  "type": "https://corvus-oss.org/arazzo/control-plane/problems/not-resumable",
                  "title": "Run is not resumable",
                  "status": 409,
                  "detail": "Run 'adopt-42' is Completed; only a Faulted run can be resumed."
                }
              },
              "leaseHeld": {
                "summary": "Another owner holds the run's lease",
                "value": {
                  "type": "https://corvus-oss.org/arazzo/control-plane/problems/lease-held",
                  "title": "Run is busy",
                  "status": 409,
                  "detail": "Run 'adopt-42' is currently held by another owner."
                }
              }
            }
          }
        }
      }
    },
    "links": {
      "NextPage": {
        "operationId": "listRuns",
        "description": "Fetch the next page of runs; absent in effect when nextPageToken is null (the last page).",
        "parameters": {
          "pageToken": "$response.body#/nextPageToken",
          "status": "$request.query.status",
          "workflowId": "$request.query.workflowId",
          "limit": "$request.query.limit"
        }
      },
      "ResumeRun": {
        "operationId": "resumeRun",
        "description": "Resume this run from its last checkpoint (only applies if it is faulted).",
        "parameters": { "runId": "$response.body#/id" }
      },
      "CancelRun": {
        "operationId": "cancelRun",
        "description": "Cancel this run.",
        "parameters": { "runId": "$response.body#/id" }
      },
      "DeleteRun": {
        "operationId": "deleteRun",
        "description": "Permanently delete this run.",
        "parameters": { "runId": "$response.body#/id" }
      }
    },
    "schemas": {
      "WorkflowRunStatus": {
        "type": "string",
        "description": "A run's lifecycle status. `Faulted` is terminal-but-recoverable (awaiting remediation); `Completed` and `Cancelled` are terminal.",
        "enum": ["Pending", "Running", "Suspended", "Completed", "Cancelled", "Faulted"]
      },
      "WorkflowWaitKind": {
        "type": "string",
        "description": "What a suspended run is waiting for.",
        "enum": ["Timer", "Message"]
      },
      "WorkflowWait": {
        "type": "object",
        "description": "Why a run is suspended.",
        "properties": {
          "kind": { "$ref": "#/components/schemas/WorkflowWaitKind" },
          "dueAt": {
            "type": ["string", "null"],
            "format": "date-time",
            "description": "When a timer wait becomes due (set for `Timer`)."
          },
          "channel": {
            "type": ["string", "null"],
            "description": "The channel a message wait listens on (set for `Message`)."
          },
          "correlationId": {
            "type": ["string", "null"],
            "description": "The correlation id a message wait matches, if any."
          }
        },
        "required": ["kind"]
      },
      "WorkflowFault": {
        "type": "object",
        "description": "A run's fault record (terminal-but-recoverable failure).",
        "properties": {
          "stepId": { "type": "string", "description": "The step that faulted." },
          "attempt": { "type": "integer", "description": "The attempt count at the fault." },
          "error": { "type": "string", "description": "The error type/message." },
          "at": { "type": "string", "format": "date-time", "description": "When the fault occurred." }
        },
        "required": ["stepId", "attempt", "error", "at"]
      },
      "WorkflowRunSummary": {
        "type": "object",
        "description": "A run as projected into the visibility index (one entry in a page).",
        "properties": {
          "id": { "type": "string" },
          "workflowId": { "type": "string" },
          "status": { "$ref": "#/components/schemas/WorkflowRunStatus" },
          "createdAt": { "type": "string", "format": "date-time" },
          "updatedAt": { "type": "string", "format": "date-time" },
          "dueAt": { "type": ["string", "null"], "format": "date-time" },
          "awaitingChannel": { "type": ["string", "null"] },
          "awaitingCorrelationId": { "type": ["string", "null"] },
          "errorType": { "type": ["string", "null"], "description": "The fault error, if the run is/was faulted." }
        },
        "required": ["id", "workflowId", "status", "createdAt", "updatedAt"]
      },
      "WorkflowRunPage": {
        "type": "object",
        "description": "A page of runs matching a visibility query.",
        "properties": {
          "runs": {
            "type": "array",
            "items": { "$ref": "#/components/schemas/WorkflowRunSummary" }
          },
          "nextPageToken": {
            "type": ["string", "null"],
            "description": "An opaque token to fetch the next page, or null/absent if this is the last page."
          }
        },
        "required": ["runs"]
      },
      "WorkflowRunDetail": {
        "type": "object",
        "description": "A run's management detail, read from its authoritative checkpoint.",
        "properties": {
          "id": { "type": "string" },
          "workflowId": { "type": "string" },
          "status": { "$ref": "#/components/schemas/WorkflowRunStatus" },
          "cursor": { "type": "integer", "description": "The state-machine index of the next step to run." },
          "createdAt": { "type": "string", "format": "date-time" },
          "wait": {
            "description": "Why the run is suspended, if it is.",
            "anyOf": [{ "$ref": "#/components/schemas/WorkflowWait" }, { "type": "null" }]
          },
          "fault": {
            "description": "The fault record if the run is (or was) faulted.",
            "anyOf": [{ "$ref": "#/components/schemas/WorkflowFault" }, { "type": "null" }]
          },
          "etag": { "type": "string", "description": "The optimistic-concurrency token the checkpoint was read at." }
        },
        "required": ["id", "workflowId", "status", "cursor", "createdAt", "etag"]
      },
      "ResumeRequest": {
        "description": "How to resume a faulted run — a union on `mode`. Each form carries only the fields its mode needs; the `const` mode discriminates the variant.",
        "oneOf": [
          { "$ref": "#/components/schemas/RetryFaultedStepResume" },
          { "$ref": "#/components/schemas/RewindResume" },
          { "$ref": "#/components/schemas/SkipResume" },
          { "$ref": "#/components/schemas/StatePatchResume" }
        ]
      },
      "RetryFaultedStepResume": {
        "type": "object",
        "description": "Re-execute from the last checkpoint — the faulted step. The common case.",
        "properties": {
          "mode": { "type": "string", "const": "RetryFaultedStep" }
        },
        "required": ["mode"]
      },
      "RewindResume": {
        "type": "object",
        "description": "Reset the cursor to an earlier step and re-run forward from there.",
        "properties": {
          "mode": { "type": "string", "const": "Rewind" },
          "targetCursor": { "type": "integer", "format": "int32", "description": "The cursor to rewind to." }
        },
        "required": ["mode", "targetCursor"]
      },
      "SkipResume": {
        "type": "object",
        "description": "Advance the cursor past the faulted step, optionally recording operator-supplied outputs for it.",
        "properties": {
          "mode": { "type": "string", "const": "Skip" },
          "targetCursor": { "type": "integer", "format": "int32", "description": "The cursor to resume at (defaults to the faulted cursor + 1)." },
          "skipOutputs": { "description": "The operator-supplied outputs to record for the skipped step so downstream references resolve. Any JSON value." }
        },
        "required": ["mode"]
      },
      "StatePatchResume": {
        "type": "object",
        "description": "Apply an RFC 6902 JSON Patch to the run's context object { \"inputs\": …, \"stepOutputs\": { … } }, then retry the faulted step.",
        "properties": {
          "mode": { "type": "string", "const": "StatePatch" },
          "patch": {
            "type": "array",
            "description": "The RFC 6902 JSON Patch array.",
            "items": { "type": "object" }
          }
        },
        "required": ["mode", "patch"]
      },
      "CancelRequest": {
        "type": "object",
        "description": "A request to cancel a run.",
        "properties": {
          "reason": { "type": "string", "description": "An operator-supplied reason for the cancellation (recorded for audit)." }
        },
        "required": ["reason"]
      },
      "PurgeResult": {
        "type": "object",
        "description": "The outcome of a purge.",
        "properties": {
          "purgedCount": { "type": "integer", "description": "The number of runs deleted." }
        },
        "required": ["purgedCount"]
      },
      "ProblemDetails": {
        "type": "object",
        "description": "An RFC 9457 problem detail.",
        "properties": {
          "type": { "type": "string", "format": "uri" },
          "title": { "type": "string" },
          "status": { "type": "integer" },
          "detail": { "type": "string" },
          "instance": { "type": "string" }
        }
      }
    }
  }
}
