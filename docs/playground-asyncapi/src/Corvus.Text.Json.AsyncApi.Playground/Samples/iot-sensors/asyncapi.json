{
  "asyncapi": "3.0.0",
  "info": {
    "title": "IoT Sensor Network",
    "version": "1.0.0",
    "description": "A sensor network that publishes temperature readings and supports request/reply for sensor status."
  },
  "servers": {
    "local": {
      "host": "nats://localhost:4222",
      "protocol": "nats"
    }
  },
  "channels": {
    "temperatureReading": {
      "address": "sensors/{sensorId}/temperature",
      "messages": {
        "reading": { "$ref": "#/components/messages/temperatureReading" }
      },
      "parameters": {
        "sensorId": { "description": "The unique sensor identifier." }
      }
    },
    "sensorStatusRequest": {
      "address": "sensors/{sensorId}/status/request",
      "messages": {
        "request": { "$ref": "#/components/messages/statusRequest" }
      },
      "parameters": {
        "sensorId": { "description": "The unique sensor identifier." }
      }
    },
    "sensorStatusReply": {
      "address": "sensors/{sensorId}/status/reply",
      "messages": {
        "reply": { "$ref": "#/components/messages/statusReply" }
      },
      "parameters": {
        "sensorId": { "description": "The unique sensor identifier." }
      }
    }
  },
  "operations": {
    "publishTemperature": {
      "action": "send",
      "channel": { "$ref": "#/channels/temperatureReading" },
      "summary": "Publish a temperature reading from a sensor.",
      "tags": [{ "name": "telemetry" }],
      "messages": [{ "$ref": "#/channels/temperatureReading/messages/reading" }]
    },
    "receiveTemperature": {
      "action": "receive",
      "channel": { "$ref": "#/channels/temperatureReading" },
      "summary": "Receive temperature readings from sensors.",
      "tags": [{ "name": "telemetry" }],
      "messages": [{ "$ref": "#/channels/temperatureReading/messages/reading" }]
    },
    "requestStatus": {
      "action": "send",
      "channel": { "$ref": "#/channels/sensorStatusRequest" },
      "summary": "Request the current status of a sensor.",
      "tags": [{ "name": "control" }],
      "messages": [{ "$ref": "#/channels/sensorStatusRequest/messages/request" }],
      "reply": {
        "channel": { "$ref": "#/channels/sensorStatusReply" },
        "messages": [{ "$ref": "#/channels/sensorStatusReply/messages/reply" }]
      }
    }
  },
  "components": {
    "messages": {
      "temperatureReading": {
        "name": "temperatureReading",
        "title": "Temperature Reading",
        "summary": "A temperature measurement from a sensor.",
        "payload": { "$ref": "#/components/schemas/temperaturePayload" }
      },
      "statusRequest": {
        "name": "statusRequest",
        "title": "Status Request",
        "summary": "Request to check sensor health.",
        "payload": { "$ref": "#/components/schemas/statusRequestPayload" }
      },
      "statusReply": {
        "name": "statusReply",
        "title": "Status Reply",
        "summary": "Response with sensor health information.",
        "payload": { "$ref": "#/components/schemas/statusReplyPayload" }
      }
    },
    "schemas": {
      "temperaturePayload": {
        "type": "object",
        "required": ["celsius", "timestamp"],
        "properties": {
          "celsius": {
            "type": "number",
            "description": "Temperature in degrees Celsius."
          },
          "timestamp": {
            "type": "string",
            "format": "date-time",
            "description": "ISO 8601 timestamp of the reading."
          },
          "humidity": {
            "type": "number",
            "minimum": 0,
            "maximum": 100,
            "description": "Relative humidity percentage (optional)."
          }
        }
      },
      "statusRequestPayload": {
        "type": "object",
        "required": ["requestId"],
        "properties": {
          "requestId": {
            "type": "string",
            "format": "uuid",
            "description": "Correlation ID for the request."
          },
          "includeMetrics": {
            "type": "boolean",
            "description": "Whether to include detailed metrics in the reply."
          }
        }
      },
      "statusReplyPayload": {
        "type": "object",
        "required": ["sensorId", "healthy", "uptime"],
        "properties": {
          "sensorId": {
            "type": "string",
            "description": "The sensor that replied."
          },
          "healthy": {
            "type": "boolean",
            "description": "Whether the sensor is healthy."
          },
          "uptime": {
            "type": "integer",
            "minimum": 0,
            "description": "Uptime in seconds."
          },
          "lastReading": {
            "type": "number",
            "description": "The most recent temperature reading."
          }
        }
      }
    }
  }
}
