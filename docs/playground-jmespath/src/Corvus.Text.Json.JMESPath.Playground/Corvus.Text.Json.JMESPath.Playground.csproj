<Project Sdk="Microsoft.NET.Sdk.BlazorWebAssembly">
  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <LangVersion>14</LangVersion>
    <AllowUnsafeBlocks>true</AllowUnsafeBlocks>
    <StaticWebAssetBasePath>/</StaticWebAssetBasePath>
    <!-- Disable the Endjin analyzers for this standalone tool -->
    <EndjinDisableCreateEditorConfig>true</EndjinDisableCreateEditorConfig>
    <EndjinDisableAutoPackagesLock>true</EndjinDisableAutoPackagesLock>
    <NoWarn>$(NoWarn);CS1591</NoWarn>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.AspNetCore.Components.WebAssembly" />
    <PackageReference Include="BlazorMonaco" />
  </ItemGroup>

  <!-- JMESPath runtime evaluator -->
  <ItemGroup>
    <ProjectReference Include="..\..\..\..\src\Corvus.Text.Json.JMESPath\Corvus.Text.Json.JMESPath.csproj" />
  </ItemGroup>
</Project>
