@inherits LayoutComponentBase
@implements IDisposable
@page "/"
@inject EvaluationService EvalService
@inject BindingsCompilationService BindingsCompiler
@inject IJSRuntime JSRuntime

<div class="playground-toolbar">
    <h1>JSONata Playground</h1>
    <button class="toolbar-btn secondary" @onclick="NewProjectAsync" title="New blank project">📄 New</button>
    <select class="toolbar-select" value="@(activeSampleId ?? "")" @onchange="OnSampleChanged">
        @if (activeSampleId is null)
        {
            <option value="" disabled>— Custom —</option>
        }
        @foreach (var sample in SampleRegistry.All)
        {
            <option value="@sample.Id">@sample.DisplayName</option>
        }
    </select>
    <div class="spacer"></div>
    <button class="theme-toggle-btn" @onclick="CycleTheme" title="@themeTooltip">@themeIcon</button>
</div>

<div class="jsonata-grid">
    @* Left column: JSON data (top) and Bindings (bottom) *@
    <div class="playground-panel panel-data">
        <div class="panel-header">
            JSON Data
            <div class="spacer"></div>
            <button class="panel-copy-btn" @onclick="CopyData" title="Copy data">📋</button>
        </div>
        <div class="panel-body">
            <StandaloneCodeEditor @ref="dataEditor"
                                  Id="data-editor"
                                  ConstructionOptions="DataEditorOptions"
                                  OnDidChangeModelContent="OnDataChanged" />
        </div>
    </div>

    <div class="playground-panel panel-bindings">
        <div class="panel-header">
            Bindings (C#)
            @if (bindingsError is not null)
            {
                <span class="bindings-error-indicator" title="@bindingsError">⚠</span>
            }
            <div class="spacer"></div>
            <button class="panel-copy-btn" @onclick="CopyBindings" title="Copy bindings">📋</button>
        </div>
        <div class="panel-body">
            <StandaloneCodeEditor @ref="bindingsEditor"
                                  Id="bindings-editor"
                                  ConstructionOptions="BindingsEditorOptions"
                                  OnDidChangeModelContent="OnBindingsChanged" />
        </div>
    </div>

    @* Top-right: JSONata expression *@
    <div class="playground-panel panel-expression">
        <div class="panel-header">
            JSONata Expression
            <div class="spacer"></div>
            <button class="panel-copy-btn" @onclick="CopyExpression" title="Copy expression">📋</button>
        </div>
        <div class="panel-body">
            <StandaloneCodeEditor @ref="expressionEditor"
                                  Id="expression-editor"
                                  ConstructionOptions="ExpressionEditorOptions"
                                  OnDidChangeModelContent="OnExpressionChanged" />
        </div>
    </div>

    @* Bottom-right: Result output *@
    <div class="playground-panel panel-output">
        <div class="panel-header">
            Result
            <div class="spacer"></div>
            @if (lastResult is not null)
            {
                <span style="font-weight:normal;text-transform:none;">
                    @(lastResult.Success ? "✓" : "✗")
                    @($"{lastResult.ElapsedMs:F1}ms")
                </span>
            }
            <button class="panel-copy-btn" @onclick="CopyResult" title="Copy result">📋</button>
        </div>
        <div class="panel-body" style="@(lastResult is not null && !lastResult.Success ? "display:none" : "")">
            <StandaloneCodeEditor @ref="outputEditor"
                                  Id="output-editor"
                                  ConstructionOptions="OutputEditorOptions" />
        </div>
        @if (lastResult is not null && !lastResult.Success)
        {
            <div class="panel-body">
                <div class="error-output">@lastResult.ErrorMessage</div>
            </div>
        }
    </div>
</div>

@if (showDirtyConfirmation)
{
    <div class="modal-overlay" @onclick="CancelDirtyConfirmation">
        <div class="modal-dialog" @onclick:stopPropagation="true">
            <h3>Unsaved Changes</h3>
            <p>Your editors have been modified. Do you want to discard these changes?</p>
            <ul class="dirty-file-list">
                @foreach (string name in GetDirtyEditorNames())
                {
                    <li>@name</li>
                }
            </ul>
            <div class="modal-actions">
                <button class="toolbar-btn secondary" @onclick="CancelDirtyConfirmation">Cancel</button>
                <button class="toolbar-btn primary" @onclick="ConfirmDirtyAction">Discard Changes</button>
            </div>
        </div>
    </div>
}

<div class="status-bar @(lastResult is not null && !lastResult.Success ? "error" : "")">
    <span>Corvus.Text.Json.Jsonata — Interpreted Runtime</span>
    <div class="spacer"></div>
    @if (isCompiling)
    {
        <span>Compiling bindings…</span>
    }
    else if (isEvaluating)
    {
        <span>Evaluating…</span>
    }
    else if (bindingsError is not null)
    {
        <span class="bindings-status-error">Bindings error</span>
    }
    else if (lastResult is not null)
    {
        <span>@(lastResult.Success ? "OK" : "Error") — @($"{lastResult.ElapsedMs:F1}ms")</span>
    }
    else
    {
        <span>Ready</span>
    }
</div>

@code {
    private StandaloneCodeEditor dataEditor = null!;
    private StandaloneCodeEditor expressionEditor = null!;
    private StandaloneCodeEditor outputEditor = null!;
    private StandaloneCodeEditor bindingsEditor = null!;

    private string? activeSampleId;
    private EvaluationResult? lastResult;
    private bool isEvaluating;
    private bool isCompiling;
    private bool isInitializing = true;
    private bool isLoadingSample;

    // Dirty checking
    private bool showDirtyConfirmation;
    private Func<Task>? pendingDirtyAction;
    private string cleanData = "";
    private string cleanExpression = "";
    private string cleanBindings = "";
    private List<string> dirtyEditorSnapshot = new();

    // Compiled bindings (null = no bindings or empty)
    private Dictionary<string, JsonataBinding>? activeBindings;
    private string? bindingsError;

    // Theme state
    private string themePref = "auto";
    private string resolvedTheme = "dark";
    private string themeIcon = "🌙";
    private string themeTooltip = "Toggle theme";
    private DotNetObjectReference<MainLayout>? dotNetRef;

    // Debounce
    private CancellationTokenSource? evaluateDebounce;
    private CancellationTokenSource? bindingsDebounce;
    private CancellationTokenSource? saveDebounce;

    private const string DataStorageKey = "jsonata-playground-data";
    private const string ExpressionStorageKey = "jsonata-playground-expression";
    private const string BindingsStorageKey = "jsonata-playground-bindings";
    private const string ThemeStorageKey = "jsonata-playground-theme";

    private const string DefaultBindingsPlaceholder =
        """
        // Define bindings as dictionary entries.
        // Value bindings:   ["name"] = Value(3.14)
        // Function bindings: ["name"] = Function((args, ws) => ToElement(...), paramCount)
        {
            // ["myVar"] = Value(42),
        }
        """;

    // ── Editor options ──

    private StandaloneEditorConstructionOptions DataEditorOptions(StandaloneCodeEditor editor) => new()
    {
        Language = "json",
        Theme = resolvedTheme == "light" ? "vs" : "vs-dark",
        Value = initialData,
        AutomaticLayout = true,
        Minimap = new EditorMinimapOptions { Enabled = false },
        FontSize = 13,
        TabSize = 2,
        ScrollBeyondLastLine = false,
    };

    private StandaloneEditorConstructionOptions ExpressionEditorOptions(StandaloneCodeEditor editor) => new()
    {
        Language = "jsonata",
        Theme = resolvedTheme == "light" ? "vs" : "vs-dark",
        Value = initialExpression,
        AutomaticLayout = true,
        Minimap = new EditorMinimapOptions { Enabled = false },
        FontSize = 14,
        TabSize = 2,
        ScrollBeyondLastLine = false,
        WordWrap = "on",
    };

    private StandaloneEditorConstructionOptions OutputEditorOptions(StandaloneCodeEditor editor) => new()
    {
        Language = "json",
        Theme = resolvedTheme == "light" ? "vs" : "vs-dark",
        Value = "",
        AutomaticLayout = true,
        Minimap = new EditorMinimapOptions { Enabled = false },
        FontSize = 13,
        TabSize = 2,
        ReadOnly = true,
        ScrollBeyondLastLine = false,
    };

    private StandaloneEditorConstructionOptions BindingsEditorOptions(StandaloneCodeEditor editor) => new()
    {
        Language = "csharp",
        Theme = resolvedTheme == "light" ? "vs" : "vs-dark",
        Value = initialBindingsCode,
        AutomaticLayout = true,
        Minimap = new EditorMinimapOptions { Enabled = false },
        FontSize = 13,
        TabSize = 4,
        ScrollBeyondLastLine = false,
    };

    // ── Initial values (set before render) ──
    private string initialData = SampleRegistry.All[0].Data;
    private string initialExpression = SampleRegistry.All[0].Expression;
    private string initialBindingsCode = SampleRegistry.All[0].BindingsCode ?? DefaultBindingsPlaceholder;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            dotNetRef = DotNetObjectReference.Create(this);
            await JSRuntime.InvokeVoidAsync("registerPlaygroundShortcuts", dotNetRef);
            await JSRuntime.InvokeVoidAsync("onSystemThemeChange", dotNetRef);

            // Load saved theme preference
            var savedTheme = await GetLocalStorage(ThemeStorageKey);
            if (!string.IsNullOrEmpty(savedTheme))
            {
                themePref = savedTheme;
            }

            resolvedTheme = await JSRuntime.InvokeAsync<string>("getInitialTheme");
            UpdateThemeIcon();

            // Load saved data
            var savedData = await GetLocalStorage(DataStorageKey);
            var savedExpr = await GetLocalStorage(ExpressionStorageKey);
            var savedBindings = await GetLocalStorage(BindingsStorageKey);

            if (!string.IsNullOrEmpty(savedData) || !string.IsNullOrEmpty(savedExpr))
            {
                activeSampleId = null;
                if (!string.IsNullOrEmpty(savedData))
                {
                    await dataEditor.SetValue(savedData);
                }

                if (!string.IsNullOrEmpty(savedExpr))
                {
                    await expressionEditor.SetValue(savedExpr);
                }

                if (!string.IsNullOrEmpty(savedBindings))
                {
                    await bindingsEditor.SetValue(savedBindings);
                }
            }
            else
            {
                activeSampleId = SampleRegistry.All[0].Id;
            }

            StateHasChanged();

            // Initialization complete — sync clean baselines, enable change handlers, then compile+evaluate
            isInitializing = false;
            await SyncCleanBaselines();
            await CompileAndEvaluateAsync();
        }
    }

    // ── Event handlers ──

    private void OnDataChanged(ModelContentChangedEvent e)
    {
        if (isInitializing || isLoadingSample) { return; }

        activeSampleId = null;
        DebounceEvaluate();
        DebounceSave();
    }

    private void OnExpressionChanged(ModelContentChangedEvent e)
    {
        if (isInitializing || isLoadingSample) { return; }

        activeSampleId = null;
        DebounceEvaluate();
        DebounceSave();
    }

    private void OnBindingsChanged(ModelContentChangedEvent e)
    {
        if (isInitializing || isLoadingSample) { return; }

        activeSampleId = null;
        DebounceCompileBindings();
        DebounceSave();
    }

    private async Task OnSampleChanged(ChangeEventArgs e)
    {
        var sampleId = e.Value?.ToString();
        var sample = SampleRegistry.All.FirstOrDefault(s => s.Id == sampleId);
        if (sample is null)
        {
            return;
        }

        await CheckDirtyAndConfirm(async () =>
        {
            await LoadSample(sample);
        });
    }

    private async Task NewProjectAsync()
    {
        await CheckDirtyAndConfirm(async () =>
        {
            isLoadingSample = true;
            try
            {
                activeSampleId = null;
                await dataEditor.SetValue("{}");
                await expressionEditor.SetValue("/* Enter a JSONata expression */");
                await bindingsEditor.SetValue(DefaultBindingsPlaceholder);
            }
            finally
            {
                isLoadingSample = false;
            }

            await SyncCleanBaselines();
            await ClearLocalStorage();
            lastResult = null;
            if (outputEditor is not null)
            {
                await outputEditor.SetValue("");
            }

            StateHasChanged();
        });
    }

    private async Task LoadSample(Sample sample)
    {
        isLoadingSample = true;
        try
        {
            activeSampleId = sample.Id;
            await dataEditor.SetValue(sample.Data);
            await expressionEditor.SetValue(sample.Expression);
            await bindingsEditor.SetValue(sample.BindingsCode ?? DefaultBindingsPlaceholder);
        }
        finally
        {
            isLoadingSample = false;
        }

        await SyncCleanBaselines();
        await ClearLocalStorage();
        await CompileAndEvaluateAsync();
    }

    // ── Dirty checking ──

    private async Task CheckDirtyAndConfirm(Func<Task> action)
    {
        var currentData = await dataEditor.GetValue();
        var currentExpr = await expressionEditor.GetValue();
        var currentBindings = await bindingsEditor.GetValue();

        bool dataDirty = currentData != cleanData;
        bool exprDirty = currentExpr != cleanExpression;
        bool bindingsDirty = currentBindings != cleanBindings;

        if (!dataDirty && !exprDirty && !bindingsDirty)
        {
            await action();
            return;
        }

        // Snapshot which editors are dirty for synchronous rendering
        dirtyEditorSnapshot = new List<string>();
        if (dataDirty) { dirtyEditorSnapshot.Add("JSON Data"); }
        if (exprDirty) { dirtyEditorSnapshot.Add("JSONata Expression"); }
        if (bindingsDirty) { dirtyEditorSnapshot.Add("Bindings (C#)"); }

        pendingDirtyAction = action;
        showDirtyConfirmation = true;
        StateHasChanged();
    }

    private async Task ConfirmDirtyAction()
    {
        showDirtyConfirmation = false;
        var action = pendingDirtyAction;
        pendingDirtyAction = null;

        if (action is not null)
        {
            await action();
        }
    }

    private async Task CancelDirtyConfirmation()
    {
        showDirtyConfirmation = false;
        pendingDirtyAction = null;

        // The browser already updated the <select> natively; reset it to match our state
        await JSRuntime.InvokeVoidAsync("resetSampleSelect", activeSampleId ?? "");
    }

    private List<string> GetDirtyEditorNames() => dirtyEditorSnapshot;

    private async Task SyncCleanBaselines()
    {
        cleanData = await dataEditor.GetValue();
        cleanExpression = await expressionEditor.GetValue();
        cleanBindings = await bindingsEditor.GetValue();
    }

    // ── Copy helpers ──

    private async Task CopyData()
    {
        var text = await dataEditor.GetValue();
        await JSRuntime.InvokeVoidAsync("navigator.clipboard.writeText", text);
    }

    private async Task CopyExpression()
    {
        var text = await expressionEditor.GetValue();
        await JSRuntime.InvokeVoidAsync("navigator.clipboard.writeText", text);
    }

    private async Task CopyBindings()
    {
        var text = await bindingsEditor.GetValue();
        await JSRuntime.InvokeVoidAsync("navigator.clipboard.writeText", text);
    }

    private async Task CopyResult()
    {
        if (lastResult is not null && !lastResult.Success)
        {
            await JSRuntime.InvokeVoidAsync("navigator.clipboard.writeText", lastResult.ErrorMessage ?? "");
        }
        else if (outputEditor is not null)
        {
            var text = await outputEditor.GetValue();
            await JSRuntime.InvokeVoidAsync("navigator.clipboard.writeText", text);
        }
    }

    [JSInvokable]
    public async Task OnEvaluateShortcut()
    {
        await CompileAndEvaluateAsync();
    }

    [JSInvokable]
    public void OnSystemThemeChanged(string systemTheme)
    {
        if (themePref == "auto")
        {
            resolvedTheme = systemTheme;
            UpdateThemeIcon();
            _ = JSRuntime.InvokeVoidAsync("applyTheme", resolvedTheme);
            StateHasChanged();
        }
    }

    // ── Bindings compilation ──

    private async Task CompileBindingsAsync()
    {
        isCompiling = true;
        StateHasChanged();

        try
        {
            var code = await bindingsEditor.GetValue();

            if (string.IsNullOrWhiteSpace(code) || IsPlaceholderOnly(code))
            {
                activeBindings = null;
                bindingsError = null;
                return;
            }

            var result = await BindingsCompiler.CompileAsync(code);

            if (result.Success)
            {
                activeBindings = result.Bindings;
                bindingsError = null;
            }
            else
            {
                activeBindings = null;
                bindingsError = result.ErrorMessage;

                // Show bindings errors in the Result panel
                lastResult = new EvaluationResult
                {
                    Success = false,
                    ErrorMessage = $"Bindings compilation error:\n{result.ErrorMessage}",
                    ElapsedMs = 0,
                };

                if (outputEditor is not null)
                {
                    await outputEditor.SetValue("");
                }
            }
        }
        catch (Exception ex)
        {
            activeBindings = null;
            bindingsError = ex.Message;

            lastResult = new EvaluationResult
            {
                Success = false,
                ErrorMessage = $"Bindings compilation error:\n{ex.Message}",
                ElapsedMs = 0,
            };

            if (outputEditor is not null)
            {
                await outputEditor.SetValue("");
            }
        }
        finally
        {
            isCompiling = false;
            StateHasChanged();
        }
    }

    private async Task CompileAndEvaluateAsync()
    {
        await CompileBindingsAsync();

        // Only evaluate if bindings compiled successfully (or are empty)
        if (bindingsError is null)
        {
            await EvaluateAsync();
        }
    }

    private static bool IsPlaceholderOnly(string code)
    {
        foreach (var line in code.Split('\n'))
        {
            var trimmed = line.Trim();
            if (trimmed.Length == 0 || trimmed.StartsWith("//"))
            {
                continue;
            }

            // Just braces with nothing inside
            if (trimmed is "{" or "}")
            {
                continue;
            }

            return false;
        }

        return true;
    }

    // ── Evaluation ──

    private async Task EvaluateAsync()
    {
        // Don't evaluate while bindings have compilation errors
        if (bindingsError is not null || isEvaluating)
        {
            return;
        }

        isEvaluating = true;
        StateHasChanged();

        try
        {
            var data = await dataEditor.GetValue();
            var expression = await expressionEditor.GetValue();

            lastResult = await EvalService.EvaluateAsync(expression, data, activeBindings);

            if (lastResult.Success && outputEditor is not null)
            {
                await outputEditor.SetValue(lastResult.ResultJson ?? "");
            }
        }
        catch (Exception ex)
        {
            lastResult = new EvaluationResult
            {
                Success = false,
                ErrorMessage = ex.Message,
                ElapsedMs = 0,
            };
        }
        finally
        {
            isEvaluating = false;
            StateHasChanged();
        }
    }

    // ── Debounce helpers ──

    private void DebounceEvaluate()
    {
        evaluateDebounce?.Cancel();
        evaluateDebounce = new CancellationTokenSource();
        var token = evaluateDebounce.Token;

        _ = Task.Delay(300, token).ContinueWith(async _ =>
        {
            if (!token.IsCancellationRequested)
            {
                await InvokeAsync(EvaluateAsync);
            }
        }, token, TaskContinuationOptions.OnlyOnRanToCompletion, TaskScheduler.Current);
    }

    private void DebounceCompileBindings()
    {
        bindingsDebounce?.Cancel();
        bindingsDebounce = new CancellationTokenSource();
        var token = bindingsDebounce.Token;

        _ = Task.Delay(800, token).ContinueWith(async _ =>
        {
            if (!token.IsCancellationRequested)
            {
                await InvokeAsync(CompileAndEvaluateAsync);
            }
        }, token, TaskContinuationOptions.OnlyOnRanToCompletion, TaskScheduler.Current);
    }

    private void DebounceSave()
    {
        saveDebounce?.Cancel();
        saveDebounce = new CancellationTokenSource();
        var token = saveDebounce.Token;

        _ = Task.Delay(2000, token).ContinueWith(async _ =>
        {
            if (!token.IsCancellationRequested)
            {
                await InvokeAsync(SaveToLocalStorage);
            }
        }, token, TaskContinuationOptions.OnlyOnRanToCompletion, TaskScheduler.Current);
    }

    private async Task SaveToLocalStorage()
    {
        try
        {
            var data = await dataEditor.GetValue();
            var expr = await expressionEditor.GetValue();
            var bindings = await bindingsEditor.GetValue();
            await SetLocalStorage(DataStorageKey, data);
            await SetLocalStorage(ExpressionStorageKey, expr);
            await SetLocalStorage(BindingsStorageKey, bindings);
        }
        catch
        {
            // localStorage may be unavailable
        }
    }

    // ── Theme ──

    private async Task CycleTheme()
    {
        themePref = themePref switch
        {
            "dark" => "light",
            "light" => "auto",
            _ => "dark",
        };

        if (themePref == "auto")
        {
            resolvedTheme = await JSRuntime.InvokeAsync<string>("getSystemTheme");
        }
        else
        {
            resolvedTheme = themePref;
        }

        UpdateThemeIcon();
        await JSRuntime.InvokeVoidAsync("applyTheme", resolvedTheme);
        await SetLocalStorage(ThemeStorageKey, themePref);
    }

    private void UpdateThemeIcon()
    {
        (themeIcon, themeTooltip) = themePref switch
        {
            "dark" => ("🌙", "Theme: Dark (click for Light)"),
            "light" => ("☀️", "Theme: Light (click for System)"),
            _ => ("🖥️", "Theme: System (click for Dark)"),
        };
    }

    // ── localStorage helpers ──

    private async Task<string?> GetLocalStorage(string key)
    {
        try
        {
            return await JSRuntime.InvokeAsync<string?>("localStorage.getItem", key);
        }
        catch
        {
            return null;
        }
    }

    private async Task SetLocalStorage(string key, string value)
    {
        try
        {
            await JSRuntime.InvokeVoidAsync("localStorage.setItem", key, value);
        }
        catch
        {
            // ignore
        }
    }

    private async Task ClearLocalStorage()
    {
        try
        {
            await JSRuntime.InvokeVoidAsync("localStorage.removeItem", DataStorageKey);
            await JSRuntime.InvokeVoidAsync("localStorage.removeItem", ExpressionStorageKey);
            await JSRuntime.InvokeVoidAsync("localStorage.removeItem", BindingsStorageKey);
        }
        catch
        {
            // ignore
        }
    }

    // ── Dispose ──

    public void Dispose()
    {
        evaluateDebounce?.Cancel();
        evaluateDebounce?.Dispose();
        bindingsDebounce?.Cancel();
        bindingsDebounce?.Dispose();
        saveDebounce?.Cancel();
        saveDebounce?.Dispose();
        dotNetRef?.Dispose();
    }
}