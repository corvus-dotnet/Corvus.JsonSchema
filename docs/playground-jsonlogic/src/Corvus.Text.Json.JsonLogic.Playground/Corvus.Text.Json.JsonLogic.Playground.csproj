<Project Sdk="Microsoft.NET.Sdk.BlazorWebAssembly">
  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <LangVersion>14</LangVersion>
    <AllowUnsafeBlocks>true</AllowUnsafeBlocks>
    <StaticWebAssetBasePath>/</StaticWebAssetBasePath>
    <!-- Disable WebCIL to output regular .dll files that Roslyn can read -->
    <WasmEnableWebcil>false</WasmEnableWebcil>
    <!-- Disable the Endjin analyzers for this standalone tool -->
    <EndjinDisableCreateEditorConfig>true</EndjinDisableCreateEditorConfig>
    <EndjinDisableAutoPackagesLock>true</EndjinDisableAutoPackagesLock>
    <NoWarn>$(NoWarn);CS1591</NoWarn>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.AspNetCore.Components.WebAssembly" Version="10.0.0" />
    <PackageReference Include="BlazorMonaco" Version="3.4.0" />
    <!-- Roslyn for in-browser compilation of custom operators -->
    <PackageReference Include="Microsoft.CodeAnalysis.CSharp" Version="5.3.0" />
    <PackageReference Include="Microsoft.CodeAnalysis.CSharp.Features" Version="5.3.0" />
    <PackageReference Include="Microsoft.CodeAnalysis.Features" Version="5.3.0" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\..\..\..\src\Corvus.Text.Json.JsonLogic\Corvus.Text.Json.JsonLogic.csproj" />
  </ItemGroup>

  <!-- V4 Code Generation base (for schema introspection via TypeDeclaration) -->
  <ItemGroup>
    <ProjectReference Include="..\..\..\..\src-v4\Corvus.Json.CodeGeneration\Corvus.Json.CodeGeneration.csproj" />
  </ItemGroup>

  <!-- Vocabulary analyzers (needed to register schema dialects for $ref resolution) -->
  <ItemGroup>
    <ProjectReference Include="..\..\..\..\src-v4\Corvus.Json.CodeGeneration.201909\Corvus.Json.CodeGeneration.201909.csproj" />
    <ProjectReference Include="..\..\..\..\src-v4\Corvus.Json.CodeGeneration.202012\Corvus.Json.CodeGeneration.202012.csproj" />
    <ProjectReference Include="..\..\..\..\src-v4\Corvus.Json.CodeGeneration.4\Corvus.Json.CodeGeneration.4.csproj" />
    <ProjectReference Include="..\..\..\..\src-v4\Corvus.Json.CodeGeneration.6\Corvus.Json.CodeGeneration.6.csproj" />
    <ProjectReference Include="..\..\..\..\src-v4\Corvus.Json.CodeGeneration.7\Corvus.Json.CodeGeneration.7.csproj" />
    <ProjectReference Include="..\..\..\..\src-v4\Corvus.Json.CodeGeneration.CorvusVocabulary\Corvus.Json.CodeGeneration.CorvusVocabulary.csproj" />
    <ProjectReference Include="..\..\..\..\src-v4\Corvus.Json.CodeGeneration.OpenApi30\Corvus.Json.CodeGeneration.OpenApi30.csproj" />
  </ItemGroup>

  <!-- Embed metaschema files as resources (needed for schema vocabulary resolution) -->
  <ItemGroup>
    <EmbeddedResource Include="..\..\..\..\src\Corvus.Json.CodeGenerator\metaschema\**\*.json"
                      Link="metaschema\%(RecursiveDir)%(Filename)%(Extension)" />
  </ItemGroup>

  <!-- Preserve assemblies from trimming for dynamic Roslyn compilation -->
  <ItemGroup>
    <TrimmerRootAssembly Include="System.Private.CoreLib" />
    <TrimmerRootAssembly Include="System.Runtime" />
    <TrimmerRootAssembly Include="System.Collections" />
    <TrimmerRootAssembly Include="System.Linq" />
    <TrimmerRootAssembly Include="System.Text.Json" />
    <TrimmerRootAssembly Include="System.Text.Encodings.Web" />
    <TrimmerRootAssembly Include="System.Buffers" />
    <TrimmerRootAssembly Include="System.Memory" />
    <TrimmerRootAssembly Include="System.Threading" />
    <TrimmerRootAssembly Include="System.Threading.Tasks" />
    <TrimmerRootAssembly Include="System.Diagnostics.Debug" />
    <TrimmerRootAssembly Include="System.ComponentModel" />
    <TrimmerRootAssembly Include="System.Runtime.InteropServices" />
    <TrimmerRootAssembly Include="netstandard" />
    <TrimmerRootAssembly Include="System.Private.Uri" />
    <TrimmerRootAssembly Include="System.Text.RegularExpressions" />
    <TrimmerRootAssembly Include="System.Numerics.Vectors" />
    <TrimmerRootAssembly Include="System.Runtime.Numerics" />
    <TrimmerRootAssembly Include="Corvus.Text.Json" />
    <TrimmerRootAssembly Include="Corvus.Text.Json.JsonLogic" />
    <TrimmerRootAssembly Include="Corvus.Text.Json.JsonLogic.Playground" />
    <TrimmerRootAssembly Include="Microsoft.CodeAnalysis" />
    <TrimmerRootAssembly Include="Microsoft.CodeAnalysis.CSharp" />
    <TrimmerRootAssembly Include="Microsoft.CodeAnalysis.Features" />
    <TrimmerRootAssembly Include="Microsoft.CodeAnalysis.CSharp.Features" />
  </ItemGroup>

  <!-- Copy static web assets manifest to wwwroot for Roslyn assembly resolution -->
  <Target Name="CopyAssetManifestBuild" AfterTargets="Build">
    <Copy SourceFiles="$(OutputPath)$(AssemblyName).staticwebassets.endpoints.json"
          DestinationFiles="$(OutputPath)wwwroot/_framework/asset-manifest.json"
          SkipUnchangedFiles="true"
          Condition="Exists('$(OutputPath)$(AssemblyName).staticwebassets.endpoints.json')" />
  </Target>

  <Target Name="CopyAssetManifestPublish" AfterTargets="Publish">
    <Copy SourceFiles="$(PublishDir)$(AssemblyName).staticwebassets.endpoints.json"
          DestinationFiles="$(PublishDir)wwwroot/_framework/asset-manifest.json"
          SkipUnchangedFiles="true"
          Condition="Exists('$(PublishDir)$(AssemblyName).staticwebassets.endpoints.json')" />
  </Target>

  <!-- Restore Blockly from npm and copy to wwwroot for self-hosting.
       Loaded before Monaco's AMD loader to avoid define() conflicts. -->
  <PropertyGroup>
    <BlocklySource>$(MSBuildProjectDirectory)\node_modules\blockly</BlocklySource>
    <BlocklyTarget>$(MSBuildProjectDirectory)\wwwroot\js\blockly</BlocklyTarget>
  </PropertyGroup>

  <Target Name="RestoreBlockly" BeforeTargets="BeforeBuild" Inputs="$(MSBuildProjectDirectory)\package-lock.json" Outputs="$(BlocklyTarget)\blockly_compressed.js">
    <Exec Command="npm ci --ignore-scripts" WorkingDirectory="$(MSBuildProjectDirectory)" />
    <MakeDir Directories="$(BlocklyTarget)\msg" />
    <Copy SourceFiles="$(BlocklySource)\blockly_compressed.js" DestinationFolder="$(BlocklyTarget)" />
    <Copy SourceFiles="$(BlocklySource)\blocks_compressed.js" DestinationFolder="$(BlocklyTarget)" />
    <Copy SourceFiles="$(BlocklySource)\msg\en.js" DestinationFolder="$(BlocklyTarget)\msg" />
  </Target>
</Project>
