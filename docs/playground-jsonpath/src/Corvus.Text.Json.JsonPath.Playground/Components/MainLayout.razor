        if (model is not null)
        {
            await BlazorMonaco.Editor.Global.SetModelMarkers(
                JSRuntime, model, "data-errors", []);
        }
    }

    private async Task ClearAllMarkers()
    {
        await ClearFunctionsMarkers();
        await ClearExpressionMarkers();
        await ClearDataMarkers();
