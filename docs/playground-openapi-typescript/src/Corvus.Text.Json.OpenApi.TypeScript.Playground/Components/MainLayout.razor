@inherits LayoutComponentBase
@implements IAsyncDisposable
@page "/"
@inject CodeGenerationService CodeGenService
@inject IJSRuntime JSRuntime

<div class="playground-toolbar">
    <h1>OpenAPI <span class="accent">TypeScript</span> Playground</h1>
    <select class="toolbar-select" value="@(activeSampleId ?? "")" @onchange="OnSampleChanged">
        @if (activeSampleId is null)
        {
            <option value="" disabled>— Custom spec —</option>
        }
        @foreach (PlaygroundSample sample in availableSamples)
        {
            <option value="@sample.Id">@sample.DisplayName</option>
        }
    </select>
    <div class="spacer"></div>
    <button class="theme-toggle-btn" @onclick="CycleTheme" title="@ThemeTooltip">@ThemeIcon</button>
    <button class="toolbar-btn primary" @onclick="ListOperationsAsync" disabled="@(isGenerating || isListing || isRunning)">
        @(isListing ? "Listing…" : "List Operations")
    </button>
    <button class="toolbar-btn primary" @onclick="GenerateAsync" disabled="@(!hasOperations || isGenerating || isListing || isRunning || checkedOperationCount == 0)">
        @(isGenerating ? "Generating…" : "Generate")
    </button>
    <button class="toolbar-btn primary" @onclick="RunAsync" disabled="@(generationResult is null || generationResult.Files.Count == 0 || isGenerating || isListing || isRunning)" title="Run (F5)">
        @(isRunning ? "Running…" : "▶ Run")
    </button>
</div>

<div class="playground-grid @(maximizedPanel.HasValue ? "has-maximized" : "")">
    <div class="playground-panel @(maximizedPanel == 0 ? "maximized" : "") @(maximizedPanel.HasValue && maximizedPanel != 0 ? "hidden" : "")">
        <div class="panel-header">
            OpenAPI Spec
            <div class="spacer"></div>
            <button class="panel-maximize-btn" @onclick="() => ToggleMaximize(0)" title="@(maximizedPanel == 0 ? "Restore" : "Maximize")">
                @(maximizedPanel == 0 ? "⊟" : "⊞")
            </button>
        </div>
        <div class="schema-tabs-wrapper">
            <button class="schema-tabs-scroll-btn scroll-left" @onclick="ScrollTabsLeft" title="Scroll left">‹</button>
            <div class="schema-tabs-scroll">
                @for (int i = 0; i < specFiles.Count; i++)
                {
                    int index = i;
                    SpecFile file = specFiles[index];
                    <div class="schema-tab @(index == activeSpecIndex ? "active" : "") @(file.IsRoot ? "root-type" : "")"
                         @onclick="() => SelectSpecTab(index)">
                        @if (renamingTabIndex == index)
                        {
                            <input @ref="renameInputRef"
                                   class="schema-tab-rename-input"
                                   @bind="renameValue"
                                   @bind:event="oninput"
                                   @onclick:stopPropagation="true"
                                   @onkeydown="OnRenameKeyDown"
                                   @onblur="CommitRename" />
                        }
                        else
                        {
                            <span class="schema-tab-name">@file.Name</span>
                            <button class="schema-tab-rename-btn"
                                    @onclick:stopPropagation="true"
                                    @onclick="() => StartRename(index)"
                                    title="Rename">✎</button>
                        }
                        <button class="schema-tab-root-badge @(file.IsRoot ? "is-root" : "")"
                                @onclick:stopPropagation="true"
                                @onclick="() => ToggleRoot(index)"
                                title="@(file.IsRoot ? "Root spec (click to mark another file as root)" : "Reference document (click to mark as root)")">
                            @(file.IsRoot ? "ROOT" : "REF")
                        </button>
                        @if (specFiles.Count > 1)
                        {
                            <button class="schema-tab-close"
                                    @onclick:stopPropagation="true"
                                    @onclick="() => RemoveSpecTab(index)"
                                    title="Remove">×</button>
                        }
                    </div>
                }
                <button class="schema-tab-add" @onclick="AddSpecTab" title="Add reference document">+</button>
            </div>
            <button class="schema-tabs-scroll-btn scroll-right" @onclick="ScrollTabsRight" title="Scroll right">›</button>
        </div>
        <div class="panel-content">
            <StandaloneCodeEditor @ref="specEditor"
                                  Id="spec-editor"
                                  ConstructionOptions="SpecEditorOptions"
                                  OnDidInit="OnSpecEditorInit"
                                  OnDidChangeModelContent="OnSpecContentChanged" />
        </div>
    </div>

    <div class="playground-panel @(maximizedPanel == 1 ? "maximized" : "") @(maximizedPanel.HasValue && maximizedPanel != 1 ? "hidden" : "")">
        <div class="panel-header">
            <button class="tab-btn @(rightPanelTab == RightTab.Operations ? "active" : "")"
                    @onclick="() => rightPanelTab = RightTab.Operations">
                Operations
                @if (hasOperations)
                {
                    <span class="badge">@totalOperationCount</span>
                }
            </button>
            <button class="tab-btn @(rightPanelTab == RightTab.GeneratedFiles ? "active" : "")"
                    @onclick="() => rightPanelTab = RightTab.GeneratedFiles">
                Generated
                @if (generationResult?.Files.Count > 0)
                {
                    <span class="badge">@generationResult.Files.Count</span>
                }
            </button>
            <div class="spacer"></div>
            <button class="panel-maximize-btn" @onclick="() => ToggleMaximize(1)" title="@(maximizedPanel == 1 ? "Restore" : "Maximize")">
                @(maximizedPanel == 1 ? "⊟" : "⊞")
            </button>
        </div>
        <div class="panel-content">
            @if (rightPanelTab == RightTab.Operations)
            {
                <OperationTreePanel Operations="@operations"
                                    OnSelectionChanged="OnOperationSelectionChanged" />
            }
            else
            {
                <GeneratedFilesPanel Files="@(generationResult?.Files ?? [])"
                                     SelectedFile="@selectedGeneratedFile"
                                     OnFileSelected="OnGeneratedFileSelected"
                                     Theme="@MonacoTheme" />
            }
        </div>
    </div>

    <div class="playground-panel @(maximizedPanel == 2 ? "maximized" : "") @(maximizedPanel.HasValue && maximizedPanel != 2 ? "hidden" : "")">
        <div class="panel-header">
            Your TypeScript
            <div class="spacer"></div>
            <button class="panel-copy-btn" @onclick="CopyUserCode" title="Copy code">📋</button>
            <button class="panel-maximize-btn" @onclick="() => ToggleMaximize(2)" title="@(maximizedPanel == 2 ? "Restore" : "Maximize")">
                @(maximizedPanel == 2 ? "⊟" : "⊞")
            </button>
        </div>
        <div class="panel-content">
            <StandaloneCodeEditor @ref="userCodeEditor"
                                  Id="user-code-editor"
                                  ConstructionOptions="UserCodeEditorOptions"
                                  OnDidInit="OnUserCodeEditorInit" />
        </div>
    </div>

    <div class="playground-panel @(maximizedPanel == 3 ? "maximized" : "") @(maximizedPanel.HasValue && maximizedPanel != 3 ? "hidden" : "")">
        <div class="panel-header">
            Console Output
            <div class="spacer"></div>
            <button class="panel-clear-btn" @onclick="ClearConsole" title="Clear">🗑️</button>
            <button class="panel-copy-btn" @onclick="CopyConsoleOutput" title="Copy output">📋</button>
            <button class="panel-maximize-btn" @onclick="() => ToggleMaximize(3)" title="@(maximizedPanel == 3 ? "Restore" : "Maximize")">
                @(maximizedPanel == 3 ? "⊟" : "⊞")
            </button>
        </div>
        <div class="panel-content">
            <div class="console-output">
                @foreach (ConsoleLine line in consoleLines)
                {
                    <div class="console-line @line.CssClass">@line.Text</div>
                }
            </div>
        </div>
    </div>
</div>

<div class="status-bar @(statusError ? "error" : "")">
    @if (isGenerating || isListing || isRunning)
    {
        <span class="status-spinner"></span>
    }
    <span class="status-item">@statusText</span>
</div>

@code {
    private const string DefaultUserCode =
        """
        // 1. Paste your OpenAPI spec in the top-left editor
        // 2. Click "List Operations" to see available operations
        // 3. Select the operations you want, then click "Generate"
        // 4. Write TypeScript here that uses the generated client
        // 5. Click "▶ Run" to transpile + run it in the browser
        console.log("Hello from the OpenAPI TypeScript Playground!");
        """;

    private StandaloneCodeEditor? specEditor;
    private StandaloneCodeEditor? userCodeEditor;
    private DotNetObjectReference<MainLayout>? dotNetRef;
    private ElementReference renameInputRef;
    private bool focusRenameInput;
    private int? maximizedPanel;

    private GenerationResult? generationResult;
    private List<OperationNode> operations = [];
    private bool hasOperations;
    private int totalOperationCount;
    private int checkedOperationCount;
    private bool isListing;
    private bool isGenerating;
    private bool isRunning;
    private bool statusError;
    private string statusText = "Ready";
    private List<ConsoleLine> consoleLines = [];
    private RightTab rightPanelTab = RightTab.Operations;
    private GeneratedFile? selectedGeneratedFile;

    private List<SpecFile> specFiles = [new SpecFile()];
    private int activeSpecIndex;
    private int renamingTabIndex = -1;
    private string renameValue = string.Empty;

    private IReadOnlyList<PlaygroundSample> availableSamples = [];
    private string? activeSampleId;
    private bool suppressContentChange;

    private string themePreference = "system";
    private string resolvedTheme = "dark";

    private string MonacoTheme => this.resolvedTheme == "light" ? "vs" : "vs-dark";
    private string ThemeIcon => this.themePreference switch
    {
        "dark" => "🌙",
        "light" => "☀️",
        _ => "🖥️",
    };

    private string ThemeTooltip => this.themePreference switch
    {
        "dark" => "Dark theme (click to switch)",
        "light" => "Light theme (click to switch)",
        _ => "System theme (click to switch)",
    };

    private enum RightTab
    {
        Operations,
        GeneratedFiles,
    }

    private sealed record ConsoleLine(string Text, string CssClass = "");

    private StandaloneEditorConstructionOptions SpecEditorOptions(StandaloneCodeEditor editor) => new()
    {
        Language = "json",
        Theme = MonacoTheme,
        AutomaticLayout = true,
        Value = specFiles[activeSpecIndex].Content,
        FontSize = 13,
        ScrollBeyondLastLine = false,
        Minimap = new EditorMinimapOptions { Enabled = false },
    };

    private StandaloneEditorConstructionOptions UserCodeEditorOptions(StandaloneCodeEditor editor) => new()
    {
        Language = "typescript",
        Theme = MonacoTheme,
        AutomaticLayout = true,
        Value = DefaultUserCode,
        FontSize = 13,
        ScrollBeyondLastLine = false,
        Minimap = new EditorMinimapOptions { Enabled = false },
    };

    protected override void OnInitialized()
    {
        availableSamples = SampleRegistry.GetSamples();
        activeSampleId = availableSamples.Count > 0 ? availableSamples[0].Id : null;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            dotNetRef = DotNetObjectReference.Create(this);
            await JSRuntime.InvokeVoidAsync("registerPlaygroundShortcuts", dotNetRef);
            await InitializeThemeAsync();
            await JSRuntime.InvokeVoidAsync("onSystemThemeChange", dotNetRef);
            _ = JSRuntime.InvokeVoidAsync("playgroundInterop.warmUp");
        }

        if (focusRenameInput)
        {
            focusRenameInput = false;
            try
            {
                await renameInputRef.FocusAsync();
            }
            catch
            {
            }
        }
    }

    private async Task InitializeThemeAsync()
    {
        resolvedTheme = await JSRuntime.InvokeAsync<string>("getInitialTheme");

        string? storedPreference = null;
        try
        {
            storedPreference = await JSRuntime.InvokeAsync<string?>("localStorage.getItem", "playground-theme");
        }
        catch
        {
        }

        themePreference = storedPreference switch
        {
            "dark" => "dark",
            "light" => "light",
            _ => "system",
        };

        await ApplyCurrentThemeAsync();
        StateHasChanged();
    }

    private async Task ApplyCurrentThemeAsync()
    {
        resolvedTheme = themePreference == "system"
            ? await JSRuntime.InvokeAsync<string>("getSystemTheme")
            : themePreference;

        await JSRuntime.InvokeVoidAsync("applyTheme", resolvedTheme);

        try
        {
            await JSRuntime.InvokeVoidAsync(
                "localStorage.setItem",
                "playground-theme",
                themePreference == "system" ? "auto" : themePreference);
        }
        catch
        {
        }
    }

    private async Task OnSpecEditorInit()
    {
        if (activeSampleId is not null)
        {
            await LoadSampleAsync(activeSampleId);
        }
    }

    private Task OnUserCodeEditorInit() => Task.CompletedTask;

    private async Task OnSampleChanged(ChangeEventArgs e)
    {
        string? selectedId = e.Value?.ToString();
        if (!string.IsNullOrEmpty(selectedId))
        {
            await LoadSampleAsync(selectedId);
        }
    }

    private async Task LoadSampleAsync(string sampleId)
    {
        PlaygroundSample? sample = availableSamples.FirstOrDefault(s => s.Id == sampleId);
        if (sample is null)
        {
            return;
        }

        activeSampleId = sampleId;

        IReadOnlyList<(string Name, string Content, bool IsRoot)> sampleFiles = SampleRegistry.LoadSampleFiles(sampleId);
        specFiles.Clear();
        foreach ((string Name, string Content, bool IsRoot) sampleFile in sampleFiles)
        {
            specFiles.Add(new SpecFile
            {
                Name = sampleFile.Name,
                Content = sampleFile.Content,
                IsRoot = sampleFile.IsRoot,
            });
        }

        if (specFiles.Count == 0)
        {
            specFiles.Add(new SpecFile());
        }

        foreach (SpecFile file in specFiles)
        {
            file.MarkClean();
            file.IsNew = false;
        }

        activeSpecIndex = GetRootSpecIndex();
        renamingTabIndex = -1;
        ResetSpecDerivedState();
        statusText = $"Ready — loaded {sample.DisplayName}";
        statusError = false;

        if (specEditor is not null)
        {
            suppressContentChange = true;
            await specEditor.SetValue(specFiles[activeSpecIndex].Content);
            suppressContentChange = false;
        }

        if (userCodeEditor is not null)
        {
            string? sampleUserCode = SampleRegistry.LoadSampleUserCode(sampleId);
            await userCodeEditor.SetValue(sampleUserCode ?? DefaultUserCode);
        }

        StateHasChanged();
    }

    private int GetRootSpecIndex()
    {
        int index = specFiles.FindIndex(f => f.IsRoot);
        return index >= 0 ? index : 0;
    }

    private void ResetSpecDerivedState()
    {
        operations = [];
        hasOperations = false;
        totalOperationCount = 0;
        checkedOperationCount = 0;
        generationResult = null;
        selectedGeneratedFile = null;
        rightPanelTab = RightTab.Operations;
    }

    private async Task SaveActiveSpecAsync()
    {
        if (specEditor is not null && activeSpecIndex >= 0 && activeSpecIndex < specFiles.Count)
        {
            specFiles[activeSpecIndex].Content = await specEditor.GetValue();
        }
    }

    private async Task SelectSpecTab(int index)
    {
        if (index == activeSpecIndex || index < 0 || index >= specFiles.Count)
        {
            return;
        }

        await SaveActiveSpecAsync();
        activeSpecIndex = index;

        if (specEditor is not null)
        {
            await specEditor.SetValue(specFiles[activeSpecIndex].Content);
        }
    }

    private async Task AddSpecTab()
    {
        await SaveActiveSpecAsync();

        int n = 1;
        while (specFiles.Any(f => string.Equals(f.Name, $"ref-{n}.json", StringComparison.OrdinalIgnoreCase)))
        {
            n++;
        }

        specFiles.Add(new SpecFile
        {
            Name = $"ref-{n}.json",
            IsRoot = false,
            Content = "{}",
            IsNew = true,
        });

        activeSpecIndex = specFiles.Count - 1;
        activeSampleId = null;
        ResetSpecDerivedState();
        statusText = "Ready — added reference document";
        statusError = false;

        if (specEditor is not null)
        {
            await specEditor.SetValue(specFiles[activeSpecIndex].Content);
        }
    }

    private async Task RemoveSpecTab(int index)
    {
        if (specFiles.Count <= 1 || index < 0 || index >= specFiles.Count)
        {
            return;
        }

        bool removingActive = index == activeSpecIndex;
        if (removingActive)
        {
            await SaveActiveSpecAsync();
        }

        specFiles.RemoveAt(index);

        if (!specFiles.Any(f => f.IsRoot))
        {
            specFiles[0].IsRoot = true;
        }

        if (removingActive)
        {
            activeSpecIndex = Math.Min(index, specFiles.Count - 1);
        }
        else if (index < activeSpecIndex)
        {
            activeSpecIndex--;
        }

        activeSampleId = null;
        ResetSpecDerivedState();
        statusText = "Ready — removed reference document";
        statusError = false;

        if (removingActive && specEditor is not null)
        {
            await specEditor.SetValue(specFiles[activeSpecIndex].Content);
        }
    }

    private void ToggleRoot(int index)
    {
        if (index < 0 || index >= specFiles.Count)
        {
            return;
        }

        int rootIndex = index;
        if (specFiles[index].IsRoot)
        {
            if (specFiles.Count == 1)
            {
                return;
            }

            rootIndex = index == 0 ? 1 : 0;
        }

        for (int i = 0; i < specFiles.Count; i++)
        {
            specFiles[i].IsRoot = i == rootIndex;
        }

        activeSampleId = null;
        ResetSpecDerivedState();
        statusText = "Ready — root document updated";
        statusError = false;
    }

    private void StartRename(int index)
    {
        renamingTabIndex = index;
        renameValue = specFiles[index].Name;
        focusRenameInput = true;
    }

    private void CommitRename()
    {
        if (renamingTabIndex >= 0
            && renamingTabIndex < specFiles.Count
            && !string.IsNullOrWhiteSpace(renameValue))
        {
            specFiles[renamingTabIndex].Name = renameValue.Trim();
            activeSampleId = null;
            ResetSpecDerivedState();
            statusText = "Ready — document renamed";
            statusError = false;
        }

        renamingTabIndex = -1;
    }

    private void OnRenameKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter")
        {
            CommitRename();
        }
        else if (e.Key == "Escape")
        {
            renamingTabIndex = -1;
        }
    }

    private async Task ScrollTabsLeft()
    {
        await JSRuntime.InvokeVoidAsync("eval", "document.querySelector('.schema-tabs-scroll')?.scrollBy({left: -150, behavior: 'smooth'})");
    }

    private async Task ScrollTabsRight()
    {
        await JSRuntime.InvokeVoidAsync("eval", "document.querySelector('.schema-tabs-scroll')?.scrollBy({left: 150, behavior: 'smooth'})");
    }

    private void OnSpecContentChanged(ModelContentChangedEvent e)
    {
        if (suppressContentChange)
        {
            return;
        }

        activeSampleId = null;
        if (hasOperations || generationResult is not null || selectedGeneratedFile is not null)
        {
            ResetSpecDerivedState();
            statusText = "Spec changed — list operations again";
            statusError = false;
        }
    }

    private async Task ListOperationsAsync()
    {
        isListing = true;
        statusError = false;
        statusText = "Listing operations…";
        ResetSpecDerivedState();
        StateHasChanged();

        try
        {
            await SaveActiveSpecAsync();
            await Task.Yield();

            ListOperationsResult listResult = await CodeGenService.ListOperationsAsync(specFiles);

            if (listResult.Errors.Count > 0)
            {
                foreach (string error in listResult.Errors)
                {
                    WriteConsole($"⚠ {error}", "error");
                }

                statusText = "Failed to list operations";
                statusError = true;
            }
            else
            {
                operations = listResult.Operations;
                hasOperations = operations.Count > 0;
                totalOperationCount = operations.Sum(p => p.Children.Count);
                checkedOperationCount = operations.Sum(p => p.Children.Count(c => c.IsChecked));

                if (hasOperations)
                {
                    string version = string.IsNullOrWhiteSpace(listResult.SpecVersion)
                        ? "unknown version"
                        : $"OpenAPI {listResult.SpecVersion}";
                    statusText = $"Found {totalOperationCount} operations in {operations.Count} paths ({version})";
                    WriteConsole($"✓ {totalOperationCount} operations listed", "success");
                }
                else
                {
                    statusText = "No operations found in spec";
                    WriteConsole("No operations found in the spec", "info");
                }
            }
        }
        catch (Exception ex)
        {
            WriteConsole($"❌ {ex.Message}", "error");
            statusText = "Error listing operations";
            statusError = true;
        }
        finally
        {
            isListing = false;
            StateHasChanged();
        }
    }

    private async Task GenerateAsync()
    {
        isGenerating = true;
        statusError = false;
        statusText = "Generating…";
        generationResult = null;
        selectedGeneratedFile = null;
        StateHasChanged();

        try
        {
            await SaveActiveSpecAsync();
            await Task.Yield();

            HashSet<string> includePaths = new(StringComparer.Ordinal);
            foreach (OperationNode group in operations)
            {
                foreach (OperationNode op in group.Children)
                {
                    if (op.IsChecked)
                    {
                        includePaths.Add(op.Path);
                    }
                }
            }

            generationResult = await CodeGenService.GenerateAsync(specFiles, GenerationMode.Client, includePaths);

            if (generationResult.Errors.Count > 0)
            {
                foreach (string error in generationResult.Errors)
                {
                    WriteConsole($"⚠ {error}", "error");
                }

                string issueWord = generationResult.Errors.Count == 1 ? "issue" : "issues";
                statusText = $"Generation completed with {generationResult.Errors.Count} {issueWord}";
                statusError = true;
            }
            else if (generationResult.Files.Count == 0)
            {
                statusText = "No files generated";
                WriteConsole("No files generated", "info");
            }
            else
            {
                int clientCount = generationResult.Files.Count(f => f.IsClient);
                int modelCount = generationResult.Files.Count(f => f.IsModel);
                statusText = $"Generated {generationResult.Files.Count} files ({clientCount} client, {modelCount} model)";
                WriteConsole($"✓ Generated {generationResult.Files.Count} files", "success");
            }

            if (generationResult.Files.Count > 0)
            {
                rightPanelTab = RightTab.GeneratedFiles;
            }
        }
        catch (Exception ex)
        {
            WriteConsole($"❌ {ex.Message}", "error");
            statusText = "Generation failed";
            statusError = true;
        }
        finally
        {
            isGenerating = false;
            StateHasChanged();
        }
    }

    private async Task RunAsync()
    {
        if (generationResult is null || generationResult.Files.Count == 0 || userCodeEditor is null)
        {
            return;
        }

        isRunning = true;
        statusError = false;
        statusText = "Transpiling + running…";
        WriteConsole("▶ Transpiling + running…", "console-progress");
        StateHasChanged();

        try
        {
            string userCode = await userCodeEditor.GetValue();
            await Task.Yield();

            // Pass the whole generated file set (filename -> content) to the run interop; its esbuild vfs
            // plugin serves the client .ts files, the model barrel, and resolves both runtimes to the
            // vendored bundles. The mock transport (a stubbed globalThis.fetch) makes the client run offline.
            var generatedFiles = generationResult.Files.ToDictionary(f => f.FileName, f => f.Content);
            RunResult result = await JSRuntime.InvokeAsync<RunResult>("playgroundInterop.transpileAndRun", generatedFiles, userCode);

            foreach (RunConsoleLine line in result.Output)
            {
                WriteConsole(line.Text, line.Kind == "error" ? "error" : line.Kind == "warn" ? "console-progress" : "");
            }

            if (!result.Ok && !string.IsNullOrEmpty(result.Error))
            {
                WriteConsole($"✗ {result.Error}", "error");
            }

            statusError = !result.Ok;
            statusText = result.Ok
                ? $"✓ Ran in the browser — {result.Output.Count} console line(s)."
                : "Run failed — see the console.";
        }
        catch (Exception ex)
        {
            statusText = "Error";
            statusError = true;
            WriteConsole($"❌ {ex.Message}", "error");
        }
        finally
        {
            isRunning = false;
            StateHasChanged();
        }
    }

    [JSInvokable]
    public async Task OnF5Pressed()
    {
        if (generationResult is not null
            && generationResult.Files.Count > 0
            && !isRunning
            && !isGenerating
            && !isListing)
        {
            await RunAsync();
        }
    }

    [JSInvokable]
    public async Task OnSystemThemeChanged(string newTheme)
    {
        if (themePreference == "system")
        {
            resolvedTheme = newTheme;
            await JSRuntime.InvokeVoidAsync("applyTheme", resolvedTheme);
            await InvokeAsync(StateHasChanged);
        }
    }

    private async Task CycleTheme()
    {
        themePreference = themePreference switch
        {
            "dark" => "light",
            "light" => "system",
            _ => "dark",
        };

        await ApplyCurrentThemeAsync();
        StateHasChanged();
    }

    private void OnOperationSelectionChanged()
    {
        checkedOperationCount = operations.Sum(p => p.Children.Count(c => c.IsChecked));
        StateHasChanged();
    }

    private void OnGeneratedFileSelected(GeneratedFile? file)
    {
        selectedGeneratedFile = file;
    }

    private void WriteConsole(string text, string cssClass = "")
    {
        consoleLines.Add(new ConsoleLine(text, cssClass));
    }

    private void ClearConsole()
    {
        consoleLines.Clear();
    }

    private async Task CopyUserCode()
    {
        if (userCodeEditor is not null)
        {
            string code = await userCodeEditor.GetValue();
            await JSRuntime.InvokeVoidAsync("navigator.clipboard.writeText", code);
        }
    }

    private async Task CopyConsoleOutput()
    {
        string text = string.Join("\n", consoleLines.Select(l => l.Text));
        await JSRuntime.InvokeVoidAsync("navigator.clipboard.writeText", text);
    }

    private void ToggleMaximize(int panelIndex)
    {
        maximizedPanel = maximizedPanel == panelIndex ? null : panelIndex;
    }

    public ValueTask DisposeAsync()
    {
        dotNetRef?.Dispose();
        return ValueTask.CompletedTask;
    }
}