@using Corvus.Text.Json.OpenApi.Playground.Models
@inject IJSRuntime JSRuntime
@implements IDisposable

<div class="operation-tree">
    @if (Operations.Count == 0)
    {
        <p class="tree-empty">Click "List Operations" to parse your spec</p>
    }
    else
    {
        <div class="tree-toolbar">
            <button @onclick="SelectAll">Select All</button>
            <button @onclick="DeselectAll">Deselect All</button>
        </div>

        @foreach (OperationNode group in Operations)
        {
            bool allChecked = group.Children.All(c => c.IsChecked);
            bool someChecked = !allChecked && group.Children.Any(c => c.IsChecked);
            <div class="tree-group">
                <div class="tree-group-header">
                    <input type="checkbox"
                           checked="@allChecked"
                           class="@(someChecked ? "indeterminate" : "")"
                           @onchange="e => ToggleGroup(group, (bool)(e.Value ?? false))" />
                    <span class="tree-group-toggle" @onclick="() => ToggleExpand(group)">
                        @(group.IsExpanded ? "▼" : "▶")
                    </span>
                    <span class="tree-group-name" @onclick="() => ToggleExpand(group)">
                        @group.GroupName
                    </span>
                    <span class="tree-group-count">(@group.Children.Count)</span>
                </div>
                @if (group.IsExpanded)
                {
                    @foreach (OperationNode op in group.Children)
                    {
                        <div class="tree-operation">
                            <input type="checkbox" checked="@op.IsChecked"
                                   @onchange="e => OnOperationToggled(op, (bool)(e.Value ?? false))" />
                            <span class="tree-method tree-method-@op.Method?.ToLowerInvariant()">@op.Method</span>
                            <span class="tree-op-path">@op.Path</span>
                            @if (!string.IsNullOrWhiteSpace(op.OperationId))
                            {
                                <span class="tree-op-id">@op.OperationId</span>
                            }
                        </div>
                    }
                }
            </div>
        }
    }
</div>

@code {
    [Parameter]
    public IReadOnlyList<OperationNode> Operations { get; set; } = [];

    [Parameter]
    public EventCallback OnSelectionChanged { get; set; }

    private bool needsIndeterminateUpdate;

    protected override void OnParametersSet()
    {
        needsIndeterminateUpdate = true;
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (needsIndeterminateUpdate)
        {
            needsIndeterminateUpdate = false;
            await JSRuntime.InvokeVoidAsync("updateIndeterminateCheckboxes");
        }
    }

    private void ToggleExpand(OperationNode node)
    {
        node.IsExpanded = !node.IsExpanded;
    }

    private async Task ToggleGroup(OperationNode group, bool check)
    {
        foreach (OperationNode op in group.Children)
        {
            op.IsChecked = check;
        }

        await OnSelectionChanged.InvokeAsync();
        needsIndeterminateUpdate = true;
    }

    private async Task OnOperationToggled(OperationNode op, bool check)
    {
        op.IsChecked = check;
        await OnSelectionChanged.InvokeAsync();
        needsIndeterminateUpdate = true;
    }

    private async Task SelectAll()
    {
        foreach (OperationNode group in Operations)
        {
            foreach (OperationNode op in group.Children)
            {
                op.IsChecked = true;
            }
        }

        await OnSelectionChanged.InvokeAsync();
        needsIndeterminateUpdate = true;
    }

    private async Task DeselectAll()
    {
        foreach (OperationNode group in Operations)
        {
            foreach (OperationNode op in group.Children)
            {
                op.IsChecked = false;
            }
        }

        await OnSelectionChanged.InvokeAsync();
        needsIndeterminateUpdate = true;
    }

    public void Dispose()
    {
    }
}
