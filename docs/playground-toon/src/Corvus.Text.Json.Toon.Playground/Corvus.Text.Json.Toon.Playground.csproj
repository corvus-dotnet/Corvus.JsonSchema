<Project Sdk="Microsoft.NET.Sdk.BlazorWebAssembly">
  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <LangVersion>14</LangVersion>
    <AllowUnsafeBlocks>true</AllowUnsafeBlocks>
    <StaticWebAssetBasePath>/</StaticWebAssetBasePath>
    <!-- Local WasmAppHost returns an empty dotnet.js response for generated gzip build assets. -->
    <DisableBuildCompression>true</DisableBuildCompression>
    <!-- Disable the Endjin analyzers for this standalone tool -->
    <EndjinDisableCreateEditorConfig>true</EndjinDisableCreateEditorConfig>
    <EndjinDisableAutoPackagesLock>true</EndjinDisableAutoPackagesLock>
    <NoWarn>$(NoWarn);CS1591</NoWarn>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.AspNetCore.Components.WebAssembly" />
    <PackageReference Include="BlazorMonaco" />
  </ItemGroup>

  <!-- TOON converter (STJ variant — no Corvus.Text.Json dependency) -->
  <ItemGroup>
    <ProjectReference Include="..\..\..\..\src\Corvus.Toon.SystemTextJson\Corvus.Toon.SystemTextJson.csproj" />
  </ItemGroup>
</Project>
