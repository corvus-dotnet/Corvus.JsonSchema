@inherits LayoutComponentBase
@page "/"
@inject CodeGenerationService CodeGenService
@inject SampleRegistry Samples
@inject IJSRuntime JS

<div class="pg-root">
    <div class="pg-toolbar">
        <h1>Corvus.Text.Json <span class="accent">TypeScript</span> Playground</h1>
        <select id="sample-select" class="pg-select" value="@activeSampleId" @onchange="OnSampleChanged" title="Load a sample">
            @if (string.IsNullOrEmpty(activeSampleId))
            {
                <option value="">— Custom / shared —</option>
            }
            @foreach (PlaygroundSample sample in Samples.Samples)
            {
                <option value="@sample.Id">@sample.DisplayName</option>
            }
        </select>
        <button id="share-btn" class="pg-btn" @onclick="ShareAsync" title="Copy a shareable link to the clipboard">@shareLabel</button>
        <button id="save-btn" class="pg-btn" @onclick="SaveAsync" title="Save the project as a .zip">Save</button>
        <label class="pg-btn pg-file-label" title="Open a saved .zip project">
            Open
            <InputFile OnChange="OnProjectFileSelected" accept=".zip" class="pg-file-input" />
        </label>
        <div class="spacer"></div>
        <button id="theme-btn" class="pg-icon-btn" @onclick="CycleThemeAsync" title="@($"Theme: {themePref} (click to change)")">@ThemeIcon</button>
        <button id="generate-btn" class="pg-btn" @onclick="GenerateAsync" disabled="@(isGenerating || isRunning)">
            @(isGenerating ? "Generating…" : "Generate")
        </button>
        <button id="run-btn" class="pg-btn primary" @onclick="RunAsync" disabled="@(isGenerating || isRunning || string.IsNullOrEmpty(generatedText))" title="Run the TypeScript (F5)">
            @(isRunning ? "Running…" : "▶ Run")
        </button>
    </div>

    <div class="pg-body">
        <div class="pg-panel">
            <div class="pg-panel-title">JSON Schema</div>
            <div class="pg-editor-host">
                <StandaloneCodeEditor @ref="schemaEditor" Id="schema-editor" ConstructionOptions="SchemaEditorOptions" OnDidInit="OnEditorInit" />
            </div>
        </div>
        <div class="pg-panel">
            <div class="pg-panel-tabs">
                <button class="pg-tab @(topRightTab == "generated" ? "active" : "")" @onclick='() => topRightTab = "generated"'>Generated TypeScript</button>
                <button id="typemap-tab" class="pg-tab @(topRightTab == "typemap" ? "active" : "")" @onclick='() => topRightTab = "typemap"'>
                    Type Map@(typeMap.Count > 0 ? $" ({typeMap.Count})" : string.Empty)
                </button>
            </div>
            <div class="pg-editor-host" style="@(topRightTab == "generated" ? string.Empty : "display:none")">
                <StandaloneCodeEditor @ref="generatedEditor" Id="generated-editor" ConstructionOptions="GeneratedEditorOptions" OnDidInit="OnEditorInit" />
            </div>
            <div class="tm-scroll" style="@(topRightTab == "typemap" ? string.Empty : "display:none")">
                <TypeMapPanel TypeMap="typeMap" />
            </div>
        </div>
        <div class="pg-panel">
            <div class="pg-panel-title">Your TypeScript</div>
            <div class="pg-editor-host">
                <StandaloneCodeEditor @ref="userEditor" Id="user-editor" ConstructionOptions="UserEditorOptions" OnDidInit="OnEditorInit" />
            </div>
        </div>
        <div class="pg-panel">
            <div class="pg-panel-title">Console</div>
            <div class="pg-console" id="pg-console">
                @if (consoleLines.Count == 0 && string.IsNullOrEmpty(runError))
                {
                    <div class="pg-console-line dim">Press Run to transpile and execute your TypeScript in the browser.</div>
                }
                @foreach (ConsoleLine line in consoleLines)
                {
                    <div class="pg-console-line @line.Kind">@line.Text</div>
                }
                @if (!string.IsNullOrEmpty(runError))
                {
                    <div class="pg-console-line error">@runError</div>
                }
            </div>
        </div>
    </div>

    <div class="pg-status @(hasError ? "error" : "")" id="pg-status">@statusMessage</div>

    @* Hidden mirror of the generated source — a stable target for automated verification. *@
    <pre id="generated-raw" style="display:none">@generatedText</pre>
    <pre id="console-raw" style="display:none">@ConsoleRaw()</pre>
</div>

@code {
    private StandaloneCodeEditor? schemaEditor;
    private StandaloneCodeEditor? generatedEditor;
    private StandaloneCodeEditor? userEditor;
    private bool isGenerating;
    private bool isRunning;
    private bool hasError;
    private string statusMessage = "Loading…";
    private string generatedText = string.Empty;
    private string runError = string.Empty;
    private readonly List<ConsoleLine> consoleLines = [];
    private string topRightTab = "generated";
    private IReadOnlyList<TypeMapEntry> typeMap = [];
    private string shareLabel = "Share";

    private string activeSampleId = string.Empty;
    private string themePref = "auto";
    private string currentMonacoTheme = "vs-dark";

    private PlaygroundSample ActiveSample => this.Samples.FindById(this.activeSampleId) ?? this.Samples.Default;

    private string ThemeIcon => this.themePref switch { "light" => "☀", "dark" => "🌙", _ => "🌗" };

    protected override void OnInitialized() => this.activeSampleId = this.Samples.Default.Id;

    private StandaloneEditorConstructionOptions SchemaEditorOptions(StandaloneCodeEditor editor) =>
        EditorOptions("json", this.ActiveSample.Schema, readOnly: false);

    private StandaloneEditorConstructionOptions GeneratedEditorOptions(StandaloneCodeEditor editor) =>
        EditorOptions("typescript", "// Generating…", readOnly: true);

    private StandaloneEditorConstructionOptions UserEditorOptions(StandaloneCodeEditor editor) =>
        EditorOptions("typescript", this.ActiveSample.UserCode, readOnly: false);

    private StandaloneEditorConstructionOptions EditorOptions(string language, string value, bool readOnly) => new()
    {
        AutomaticLayout = true,
        Language = language,
        Theme = this.currentMonacoTheme,
        Value = value,
        FontSize = 13,
        ReadOnly = readOnly,
        Minimap = new EditorMinimapOptions { Enabled = false },
        ScrollBeyondLastLine = false,
    };

    private int readyEditors;

    // Generate once all three editors are ready, so the generated panel + Run are immediately usable, and
    // warm up the esbuild toolchain so the first Run is fast. (Manual Generate works regardless.)
    private async Task OnEditorInit()
    {
        this.readyEditors++;
        if (this.readyEditors == 3)
        {
            await this.JS.InvokeVoidAsync("playgroundInterop.setupTsIntelliSense");

            // Load shared state from the URL, if any, in preference to the default sample.
            UrlState? shared = await this.JS.InvokeAsync<UrlState?>("playgroundInterop.getUrlState");
            if (shared?.Schema is string s && shared.UserCode is string u && this.schemaEditor is not null && this.userEditor is not null)
            {
                await this.schemaEditor.SetValue(s);
                await this.userEditor.SetValue(u);
                this.activeSampleId = string.Empty;
            }

            await this.GenerateAsync();
            _ = this.JS.InvokeVoidAsync("playgroundInterop.warmUp");
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            // Sync the (persisted) theme preference to Monaco + the document.
            this.themePref = await this.JS.InvokeAsync<string>("playgroundInterop.getThemePref");
            string resolved = await this.JS.InvokeAsync<string>("playgroundInterop.setTheme", this.themePref);
            this.currentMonacoTheme = resolved == "light" ? "vs" : "vs-dark";
            this.StateHasChanged();
        }
    }

    private async Task CycleThemeAsync()
    {
        this.themePref = this.themePref switch { "auto" => "light", "light" => "dark", _ => "auto" };
        string resolved = await this.JS.InvokeAsync<string>("playgroundInterop.setTheme", this.themePref);
        this.currentMonacoTheme = resolved == "light" ? "vs" : "vs-dark";
        this.StateHasChanged();
    }

    private async Task OnSampleChanged(ChangeEventArgs e)
    {
        if (this.schemaEditor is null || this.userEditor is null || e.Value is not string id)
        {
            return;
        }

        this.activeSampleId = id;
        PlaygroundSample sample = this.ActiveSample;
        await this.schemaEditor.SetValue(sample.Schema);
        await this.userEditor.SetValue(sample.UserCode);
        this.consoleLines.Clear();
        this.runError = string.Empty;
        await this.GenerateAsync();
    }

    private async Task ShareAsync()
    {
        if (this.schemaEditor is null || this.userEditor is null)
        {
            return;
        }

        string schema = await this.schemaEditor.GetValue();
        string userCode = await this.userEditor.GetValue();
        string url = await this.JS.InvokeAsync<string>("playgroundInterop.setUrlState", schema, userCode);
        bool copied = await this.JS.InvokeAsync<bool>("playgroundInterop.copyToClipboard", url);
        this.shareLabel = copied ? "Copied!" : "Link in URL";
        this.StateHasChanged();
        await Task.Delay(1500);
        this.shareLabel = "Share";
        this.StateHasChanged();
    }

    private async Task SaveAsync()
    {
        if (this.schemaEditor is null || this.userEditor is null)
        {
            return;
        }

        string schema = await this.schemaEditor.GetValue();
        string userCode = await this.userEditor.GetValue();

        using var ms = new MemoryStream();
        using (var zip = new ZipArchive(ms, ZipArchiveMode.Create, leaveOpen: true))
        {
            using (var w = new StreamWriter(zip.CreateEntry("schema.json").Open()))
            {
                await w.WriteAsync(schema);
            }

            using (var w = new StreamWriter(zip.CreateEntry("user.ts").Open()))
            {
                await w.WriteAsync(userCode);
            }
        }

        string base64 = Convert.ToBase64String(ms.ToArray());
        await this.JS.InvokeAsync<bool>("playgroundInterop.downloadFile", "playground.zip", base64, "application/zip");
    }

    private async Task OnProjectFileSelected(InputFileChangeEventArgs e)
    {
        if (this.schemaEditor is null || this.userEditor is null)
        {
            return;
        }

        try
        {
            using var ms = new MemoryStream();
            await e.File.OpenReadStream(maxAllowedSize: 5 * 1024 * 1024).CopyToAsync(ms);
            ms.Position = 0;
            using var zip = new ZipArchive(ms, ZipArchiveMode.Read);

            string? schema = await ReadEntryAsync(zip, "schema.json");
            string? userCode = await ReadEntryAsync(zip, "user.ts");
            if (schema is not null)
            {
                await this.schemaEditor.SetValue(schema);
            }

            if (userCode is not null)
            {
                await this.userEditor.SetValue(userCode);
            }

            this.activeSampleId = string.Empty;
            this.consoleLines.Clear();
            this.runError = string.Empty;
            await this.GenerateAsync();
        }
        catch (Exception ex)
        {
            this.hasError = true;
            this.statusMessage = "Open failed: " + ex.Message;
            this.StateHasChanged();
        }
    }

    private static async Task<string?> ReadEntryAsync(ZipArchive zip, string name)
    {
        ZipArchiveEntry? entry = zip.GetEntry(name);
        if (entry is null)
        {
            return null;
        }

        using var r = new StreamReader(entry.Open());
        return await r.ReadToEndAsync();
    }

    private async Task GenerateAsync()
    {
        if (this.schemaEditor is null || this.generatedEditor is null)
        {
            return;
        }

        this.isGenerating = true;
        this.hasError = false;
        this.statusMessage = "Generating…";
        this.StateHasChanged();

        try
        {
            string schema = await this.schemaEditor.GetValue();
            GenerationResult result = await this.CodeGenService.GenerateAsync(schema);

            if (result.Success)
            {
                this.generatedText = result.GeneratedTypeScript;
                this.typeMap = result.TypeMap;
                await this.generatedEditor.SetValue(this.generatedText);
                _ = this.JS.InvokeVoidAsync("playgroundInterop.updateGeneratedLib", this.generatedText);
                this.hasError = false;
                this.statusMessage = $"✓ Generated {this.generatedText.Length:N0} characters of TypeScript. Press Run to execute it.";
            }
            else
            {
                this.generatedText = string.Empty;
                this.typeMap = [];
                await this.generatedEditor.SetValue("// " + (result.ErrorMessage ?? "Generation failed."));
                this.hasError = true;
                this.statusMessage = result.ErrorMessage ?? "Generation failed.";
            }
        }
        catch (Exception ex)
        {
            this.hasError = true;
            this.statusMessage = "Error: " + ex.Message;
        }
        finally
        {
            this.isGenerating = false;
            this.StateHasChanged();
        }
    }

    private async Task RunAsync()
    {
        if (this.userEditor is null || string.IsNullOrEmpty(this.generatedText))
        {
            return;
        }

        this.isRunning = true;
        this.runError = string.Empty;
        this.consoleLines.Clear();
        this.statusMessage = "Transpiling + running…";
        this.StateHasChanged();

        try
        {
            string userCode = await this.userEditor.GetValue();
            RunResult result = await this.JS.InvokeAsync<RunResult>("playgroundInterop.transpileAndRun", this.generatedText, userCode);

            this.consoleLines.AddRange(result.Output);
            if (!result.Ok && !string.IsNullOrEmpty(result.Error))
            {
                this.runError = result.Error;
            }

            this.hasError = !result.Ok;
            this.statusMessage = result.Ok
                ? $"✓ Ran in the browser — {result.Output.Count} console line(s)."
                : "Run failed — see the console.";
        }
        catch (Exception ex)
        {
            this.runError = ex.Message;
            this.hasError = true;
            this.statusMessage = "Run error: " + ex.Message;
        }
        finally
        {
            this.isRunning = false;
            this.StateHasChanged();
        }
    }

    private string ConsoleRaw() =>
        string.Join("\n", this.consoleLines.Select(l => l.Text)) + (string.IsNullOrEmpty(this.runError) ? string.Empty : "\n" + this.runError);
}
