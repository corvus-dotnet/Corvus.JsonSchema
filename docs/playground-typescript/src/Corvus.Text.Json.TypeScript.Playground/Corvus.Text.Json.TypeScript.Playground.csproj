<Project Sdk="Microsoft.NET.Sdk.BlazorWebAssembly">
  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <LangVersion>14</LangVersion>
    <StaticWebAssetBasePath>/</StaticWebAssetBasePath>
    <!-- Local WasmAppHost returns an empty dotnet.js response for generated gzip build assets. -->
    <DisableBuildCompression>true</DisableBuildCompression>
    <!-- Standalone tool: skip the Endjin analyzer/editorconfig/lock conventions. -->
    <EndjinDisableCreateEditorConfig>true</EndjinDisableCreateEditorConfig>
    <EndjinDisableAutoPackagesLock>true</EndjinDisableAutoPackagesLock>
    <NoWarn>$(NoWarn);CS1591</NoWarn>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.AspNetCore.Components.WebAssembly" />
    <PackageReference Include="BlazorMonaco" />
  </ItemGroup>

  <!-- The TypeScript code-generation engine (the language provider) + the language-neutral V5 core. -->
  <ItemGroup>
    <ProjectReference Include="..\..\..\..\src\Corvus.Text.Json.TypeScript.CodeGeneration\Corvus.Text.Json.TypeScript.CodeGeneration.csproj" />
    <ProjectReference Include="..\..\..\..\src-v4\Corvus.Json.CodeGeneration\Corvus.Json.CodeGeneration.csproj" />
  </ItemGroup>

  <!-- Vocabulary analyzers (needed to register schema dialects). -->
  <ItemGroup>
    <ProjectReference Include="..\..\..\..\src-v4\Corvus.Json.CodeGeneration.201909\Corvus.Json.CodeGeneration.201909.csproj" />
    <ProjectReference Include="..\..\..\..\src-v4\Corvus.Json.CodeGeneration.202012\Corvus.Json.CodeGeneration.202012.csproj" />
    <ProjectReference Include="..\..\..\..\src-v4\Corvus.Json.CodeGeneration.4\Corvus.Json.CodeGeneration.4.csproj" />
    <ProjectReference Include="..\..\..\..\src-v4\Corvus.Json.CodeGeneration.6\Corvus.Json.CodeGeneration.6.csproj" />
    <ProjectReference Include="..\..\..\..\src-v4\Corvus.Json.CodeGeneration.7\Corvus.Json.CodeGeneration.7.csproj" />
    <ProjectReference Include="..\..\..\..\src-v4\Corvus.Json.CodeGeneration.CorvusVocabulary\Corvus.Json.CodeGeneration.CorvusVocabulary.csproj" />
    <ProjectReference Include="..\..\..\..\src-v4\Corvus.Json.CodeGeneration.OpenApi30\Corvus.Json.CodeGeneration.OpenApi30.csproj" />
  </ItemGroup>

  <!-- Embed metaschema files as resources (shared with the CLI tool). -->
  <ItemGroup>
    <EmbeddedResource Include="..\..\..\..\src\Corvus.Json.Cli.Core\metaschema\**\*.json"
                      Link="metaschema\%(RecursiveDir)%(Filename)%(Extension)" />
  </ItemGroup>

  <!-- Embed the documented TypeScript example recipes (schema + demo.ts) as the playground samples.
       %(RecursiveDir) (populated only by **) keeps each recipe's resource name distinct. -->
  <ItemGroup>
    <EmbeddedResource Include="..\..\..\typescript\examples\**\*.json"
                      Exclude="..\..\..\typescript\examples\node_modules\**;..\..\..\typescript\examples\dist\**;..\..\..\typescript\examples\package.json;..\..\..\typescript\examples\package-lock.json;..\..\..\typescript\examples\tsconfig.json"
                      Link="Recipes\%(RecursiveDir)%(Filename)%(Extension)" />
    <EmbeddedResource Include="..\..\..\typescript\examples\**\demo.ts"
                      Exclude="..\..\..\typescript\examples\node_modules\**;..\..\..\typescript\examples\dist\**"
                      Link="Recipes\%(RecursiveDir)%(Filename)%(Extension)" />
  </ItemGroup>
</Project>
