{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Person",
  "type": "object",
  "required": [ "familyName" ],
  "properties": {
    "familyName": { "type": "string" },
    "givenName": { "type": "string" },
    "birthDate": { "type": "string", "format": "date" },
    "height": { "type": "number" }
  }
}
