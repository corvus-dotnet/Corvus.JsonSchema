    // ── Auto-save to localStorage ──

    private void ScheduleAutoSave()
    {
        autoSaveTimer?.Dispose();
        autoSaveTimer = new System.Threading.Timer(
            _ => InvokeAsync(AutoSaveAsync),
            null,
            2000,
            Timeout.Infinite);
    }

    private async Task AutoSaveAsync()
    {
        try
        {
            // Read current editor content
            string userCode = userCodeEditor is not null
                ? await userCodeEditor.GetValue()
                : restoredUserCode ?? NewProjectUserCode;

            await SyncSchemaFromEditor();

            var state = new
            {
                version = AutoSaveVersion,
                activeSampleId,
                activeSchemaIndex,
                userCode,
                schemaFiles = schemaFiles.Select(f => new
                {
                    name = f.Name,
                    content = f.Content,
                    isRootType = f.IsRootType,
                    typeName = f.TypeName,
                }).ToArray(),
            };

            string json = System.Text.Json.JsonSerializer.Serialize(state);
            await JSRuntime.InvokeVoidAsync("localStorage.setItem", AutoSaveKey, json);
        }
        catch
        {
            // Silently ignore — auto-save is best-effort
        }
    }

    /// <summary>
    /// Synchronously restores auto-saved state from localStorage.
    /// Uses IJSInProcessRuntime (available in Blazor WASM) so the state
    /// is fully resolved before the first render — no race conditions.
    /// </summary>
    private bool RestoreAutoSavedStateSync()
    {
        try
        {
            var jsInProcess = (Microsoft.JSInterop.IJSInProcessRuntime)JSRuntime;
            string? json = jsInProcess.Invoke<string?>("localStorage.getItem", AutoSaveKey);
            if (string.IsNullOrEmpty(json))
            {
                return false;
            }

            using var doc = System.Text.Json.JsonDocument.Parse(json);
            var root = doc.RootElement;

            // Version check
            if (!root.TryGetProperty("version", out var versionEl) || versionEl.GetInt32() != AutoSaveVersion)
            {
                return false;
            }

            // Restore schema files
            if (root.TryGetProperty("schemaFiles", out var schemasEl) && schemasEl.GetArrayLength() > 0)
            {
                schemaFiles.Clear();
                foreach (var s in schemasEl.EnumerateArray())
                {
                    var file = new SchemaFile
                    {
                        Name = s.GetProperty("name").GetString() ?? "schema.json",
                        Content = s.GetProperty("content").GetString() ?? EmptySchemaContent,
                        IsRootType = s.TryGetProperty("isRootType", out var rt) && rt.GetBoolean(),
                        TypeName = s.TryGetProperty("typeName", out var tn) && tn.ValueKind != System.Text.Json.JsonValueKind.Null
                            ? tn.GetString() : null,
                    };
                    file.MarkClean();
                    schemaFiles.Add(file);
                }
            }

            // Restore active schema index
            if (root.TryGetProperty("activeSchemaIndex", out var idxEl))
            {
                int idx = idxEl.GetInt32();
                if (idx >= 0 && idx < schemaFiles.Count)
                {
                    activeSchemaIndex = idx;
                }
            }

            // Restore active sample ID (may be null for a custom project)
            if (root.TryGetProperty("activeSampleId", out var sampleEl))
            {
                activeSampleId = sampleEl.ValueKind == System.Text.Json.JsonValueKind.Null
                    ? null
                    : sampleEl.GetString();
            }

            // Restore user code — consumed by GetInitialUserCode() on first render
            if (root.TryGetProperty("userCode", out var codeEl))
            {
                restoredUserCode = codeEl.GetString();
                userCodeCleanContent = restoredUserCode ?? NewProjectUserCode;
            }

            return true;
        }
        catch
        {
            // If restore fails, fall through to defaults
            return false;
        }
    }

    public void Dispose()
    {
        diagnosticsDebounceTimer?.Dispose();
        diagnosticsCts?.Cancel();
        diagnosticsCts?.Dispose();
        autoSaveTimer?.Dispose();
        intelliSenseRef?.Dispose();
        shortcutRef?.Dispose();
        themeChangeRef?.Dispose();
    }
