@model SiteViewModel
@{
    var currentUrl = Model.PageContext.Navigation?.Url;
    var parentUrl = Model.PageContext.Navigation?.Parent;
    var navChildren = Model.SiteContext.Navigation?.Children?
        .Where(x => x.Header.Visible)
        .OrderBy(x => x.Rank)
        .ToList();
}
<a class="sr-only" href="#main-content">Skip to content</a>
<header class="site-header">
    <div class="site-header__inner">
        <a class="site-header__brand" href="/index.html" aria-label="Corvus.Text.Json home">
            <img src="/assets/images/logo-corvus.svg" alt="" width="28" height="28" aria-hidden="true" />
            Corvus<span style="color:var(--color-brand)">.</span>Text<span style="color:var(--color-brand)">.</span>Json
        </a>
        <nav class="site-header__nav-desktop" aria-label="Main navigation">
            @if (navChildren != null)
            {
                @foreach (var child in navChildren)
                {
                    var isActive = (parentUrl != null && Vellum.Cli.Domain.Url.AreEquivalent(child.Url, parentUrl))
                        || (currentUrl != null && Vellum.Cli.Domain.Url.AreEquivalent(child.Url, currentUrl));
                    <a href="@child.Url"
                       class="site-header__link @(isActive ? "is-active" : "")"
                       @(isActive ? "aria-current=page" : "")>@child.Title</a>
                }
            }
            <a href="/playground/"
               class="site-header__link"
               target="_blank" rel="noopener noreferrer"
               title="Interactive JSON Schema playground">Playground</a>
            <a href="@ViewBag.GitHubUrl"
               class="site-header__link" target="_blank" rel="noopener noreferrer"
               aria-label="View on GitHub">
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
            </a>
        </nav>
        <button class="site-header__menu-toggle js-toggle-menu"
                aria-expanded="false" aria-label="Toggle menu">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24"
                 fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                <line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/>
            </svg>
        </button>
    </div>
</header>
<nav class="site-header__nav-mobile js-mobile-nav" aria-label="Mobile navigation">
    @if (navChildren != null)
    {
        @foreach (var child in navChildren)
        {
            <a href="@child.Url" class="site-header__link">@child.Title</a>
        }
    }
    <a href="/playground/" class="site-header__link" target="_blank" rel="noopener noreferrer">Playground</a>
    <a href="@ViewBag.GitHubUrl"
       class="site-header__link" target="_blank" rel="noopener noreferrer">GitHub</a>
</nav>
