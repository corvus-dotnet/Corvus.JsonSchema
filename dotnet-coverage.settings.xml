<?xml version="1.0" encoding="utf-8"?>
<!-- dotnet-coverage settings: filter coverage to core library assemblies only.
     Passed via dotnet-coverage collect -s coverage.settings.xml -->
<Configuration>
  <CodeCoverage>
    <ModulePaths>
      <Include>
        <ModulePath>.*Corvus\.Json\.CodeGeneration\.dll$</ModulePath>
        <ModulePath>.*Corvus\.Json\.CodeGeneration\.CSharp\.dll$</ModulePath>
        <ModulePath>.*Corvus\.Json\.ExtendedTypes\.dll$</ModulePath>
        <ModulePath>.*Corvus\.Json\.JsonReference\.dll$</ModulePath>
        <ModulePath>.*Corvus\.Text\.Json\.dll$</ModulePath>
        <ModulePath>.*Corvus\.Text\.Json\.Validator\.dll$</ModulePath>
        <ModulePath>.*Corvus\.Text\.Json\.CodeGeneration\.dll$</ModulePath>
        <ModulePath>.*Corvus\.Text\.Json\.JMESPath\.dll$</ModulePath>
        <ModulePath>.*Corvus\.Text\.Json\.JMESPath\.CodeGeneration\.dll$</ModulePath>
        <ModulePath>.*Corvus\.Text\.Json\.Jsonata\.dll$</ModulePath>
        <ModulePath>.*Corvus\.Text\.Json\.Jsonata\.CodeGeneration\.dll$</ModulePath>
        <ModulePath>.*Corvus\.Text\.Json\.JsonLogic\.dll$</ModulePath>
        <ModulePath>.*Corvus\.Text\.Json\.JsonLogic\.CodeGeneration\.dll$</ModulePath>
        <ModulePath>.*Corvus\.Text\.Json\.JsonPath\.dll$</ModulePath>
        <ModulePath>.*Corvus\.Text\.Json\.JsonPath\.CodeGeneration\.dll$</ModulePath>
        <ModulePath>.*Corvus\.Text\.Json\.Patch\.dll$</ModulePath>
        <ModulePath>.*Corvus\.Text\.Json\.Yaml\.dll$</ModulePath>
        <ModulePath>.*Corvus\.Yaml\.SystemTextJson\.dll$</ModulePath>
      </Include>
    </ModulePaths>
    <Sources>
      <Exclude>
        <!-- V4 generated core types inflate the denominator without meaningful coverage value -->
        <Source>.*\\src-v4\\Corvus\.Json\.ExtendedTypes\\Corvus\.Json\\GeneratedCoreTypes\\.*</Source>
        <!-- Roslyn source-generator output under obj\ — these are
             machine-generated types whose coverage is not actionable.
             Matches both V5 layout (obj\...\generated\...) and
             regex/other generators (obj\...\System.Text.RegularExpressions.Generator\...) -->
        <Source>.*\\obj\\.*\.g\.cs$</Source>
        <!-- Auto-generated resource strings (SR.cs, Strings.Designer.cs, etc.) -->
        <Source>.*\\SR\.cs$</Source>
        <Source>.*\.Designer\.cs$</Source>
        <!-- Common/ shared source files (Utf8ValueStringBuilder, CodeGenStringHelpers,
             polyfills, etc.) are linked into many packages via <Compile Include>.
             Each package only calls a subset of methods, inflating uncovered counts.
             These files are already thoroughly tested via Corvus.Text.Json.Tests. -->
        <Source>.*\\Common\\src\\.*</Source>
        <Source>.*\\src\\Common\\.*</Source>
        <!-- System.Private.CoreLib polyfills (ValueListBuilder, HashHelpers, etc.)
             Same pattern: linked into many packages, only subset used per package. -->
        <Source>.*\\System\.Private\.CoreLib\\.*</Source>
        <!-- .NET runtime-derived Globalization polyfills (CharUnicodeInfoData lookup
             tables, IdnMapping, etc.). The data tables are auto-generated byte arrays
             indexed by Unicode code point ranges — individual array elements appear as
             "lines" but are not meaningfully testable. -->
        <Source>.*\\Corvus\\Globalization\\.*</Source>
        <!-- .NET runtime-derived Internal\Unicode polyfills (CharUnicodeInfo,
             TextSegmentationUtility, etc.) — compiled only on netstandard2.0/net481
             via #if !NET8_0_OR_GREATER. Same rationale as other polyfill exclusions. -->
        <Source>.*\\Internal\\Unicode\\.*</Source>
      </Exclude>
    </Sources>
  </CodeCoverage>
</Configuration>