<?xml version="1.0" encoding="utf-8"?>
<!-- dotnet-coverage settings: filter coverage to core library assemblies only.
     Passed via dotnet-coverage collect -s coverage.settings.xml -->
<Configuration>
  <CodeCoverage>
    <ModulePaths>
      <Include>
        <ModulePath>.*Corvus\.Json\.CodeGeneration\.dll$</ModulePath>
        <ModulePath>.*Corvus\.Json\.CodeGeneration\.CSharp\.dll$</ModulePath>
        <ModulePath>.*Corvus\.Json\.ExtendedTypes\.dll$</ModulePath>
        <ModulePath>.*Corvus\.Json\.JsonReference\.dll$</ModulePath>
        <ModulePath>.*Corvus\.Text\.Json\.dll$</ModulePath>
        <ModulePath>.*Corvus\.Text\.Json\.Validator\.dll$</ModulePath>
        <ModulePath>.*Corvus\.Text\.Json\.CodeGeneration\.dll$</ModulePath>
        <ModulePath>.*Corvus\.Text\.Json\.JMESPath\.dll$</ModulePath>
        <ModulePath>.*Corvus\.Text\.Json\.JMESPath\.CodeGeneration\.dll$</ModulePath>
        <ModulePath>.*Corvus\.Text\.Json\.Jsonata\.dll$</ModulePath>
        <ModulePath>.*Corvus\.Text\.Json\.Jsonata\.CodeGeneration\.dll$</ModulePath>
        <ModulePath>.*Corvus\.Text\.Json\.JsonLogic\.dll$</ModulePath>
        <ModulePath>.*Corvus\.Text\.Json\.JsonLogic\.CodeGeneration\.dll$</ModulePath>
        <ModulePath>.*Corvus\.Text\.Json\.JsonPath\.dll$</ModulePath>
        <ModulePath>.*Corvus\.Text\.Json\.JsonPath\.CodeGeneration\.dll$</ModulePath>
        <ModulePath>.*Corvus\.Text\.Json\.Patch\.dll$</ModulePath>
        <ModulePath>.*Corvus\.Text\.Json\.Yaml\.dll$</ModulePath>
        <ModulePath>.*Corvus\.Yaml\.SystemTextJson\.dll$</ModulePath>
      </Include>
    </ModulePaths>
    <Sources>
      <Exclude>
        <!-- V4 generated core types inflate the denominator without meaningful coverage value -->
        <Source>.*\\src-v4\\Corvus\.Json\.ExtendedTypes\\Corvus\.Json\\GeneratedCoreTypes\\.*</Source>
        <!-- Roslyn source-generator output (obj\...\generated\...\*.g.cs) — these are
             machine-generated types whose coverage is not actionable -->
        <Source>.*\\obj\\.*\\generated\\.*</Source>
      </Exclude>
    </Sources>
  </CodeCoverage>
</Configuration>