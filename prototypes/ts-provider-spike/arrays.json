{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Container",
  "type": "object",
  "properties": {
    "tags": { "type": "array", "items": { "type": "string" } },
    "triple": { "type": "array", "prefixItems": [{ "type": "string" }, { "type": "number" }, { "type": "boolean" }], "items": false },
    "labelled": { "type": "array", "prefixItems": [{ "type": "string" }], "items": { "type": "number" } },
    "matrix": { "type": "array", "items": { "type": "array", "items": { "type": "number" } } },
    "scores": { "type": "object", "additionalProperties": { "type": "number" } }
  },
  "required": ["tags", "triple"]
}
