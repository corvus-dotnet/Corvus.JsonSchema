{
  "title": "Person",
  "type": "object",
  "required": ["name", "address"],
  "properties": {
    "name": { "type": "string", "minLength": 3 },
    "address": {
      "type": "object",
      "required": ["zip"],
      "properties": { "zip": { "type": "string", "pattern": "^[0-9]{5}$" } }
    },
    "tags": { "type": "array", "items": { "type": "string", "minLength": 2 } }
  }
}
