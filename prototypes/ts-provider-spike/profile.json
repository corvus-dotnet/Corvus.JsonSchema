{
  "title": "Profile",
  "type": "object",
  "properties": {
    "id":      { "type": "string" },
    "name":    { "type": "string" },
    "email":   { "type": "string" },
    "age":     { "type": "integer" },
    "roles":   { "type": "array", "items": { "type": "string" } },
    "address": { "type": "object", "properties": {
                   "street":  { "type": "string" },
                   "city":    { "type": "string" },
                   "country": { "type": "string" } } }
  },
  "required": ["id", "name"]
}
