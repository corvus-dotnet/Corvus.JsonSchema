         Aspire.Hosting.AppHost is added implicitly by the SDK (versionless under CPM; pinned in
         Directory.Packages.props). -->
    <ProjectReference Include="..\Corvus.Text.Json.Arazzo.ControlPlane.Demo\Corvus.Text.Json.Arazzo.ControlPlane.Demo.csproj" />
    <ProjectReference Include="..\Corvus.Text.Json.Arazzo.Runner.Demo\Corvus.Text.Json.Arazzo.Runner.Demo.csproj" />
  </ItemGroup>

</Project>
