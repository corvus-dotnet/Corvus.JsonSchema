{
  "realm": "arazzo",
  "enabled": true,
  "displayName": "Arazzo Control Plane",
  "sslRequired": "none",
  "registrationAllowed": false,
  "loginWithEmailAllowed": true,
  "groups": [
    { "name": "arazzo-admins" },
    { "name": "payments" },
    { "name": "onboarding" },
    { "name": "observers" },
    { "name": "env-admins" },
    { "name": "reconcile-owners" },
    { "name": "prod-ops" },
    { "name": "arazzo-schedulers" }
  ],
  "clients": [
    {
      "clientId": "arazzo-ui",
      "name": "Arazzo Control Plane UI (BFF)",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": false,
      "secret": "arazzo-ui-dev-secret",
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": false,
      "serviceAccountsEnabled": false,
      "redirectUris": ["http://localhost:*", "https://localhost:*"],
      "webOrigins": ["+"],
      "attributes": { "pkce.code.challenge.method": "S256", "post.logout.redirect.uris": "+" },
      "defaultClientScopes": ["profile"],
      "protocolMappers": [
        {
          "name": "groups",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-group-membership-mapper",
          "config": {
            "claim.name": "groups",
            "full.path": "false",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "userinfo.token.claim": "true"
          }
        }
      ]
    },
    {
      "clientId": "arazzo-cli",
      "name": "Arazzo CLI",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": true,
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": false,
      "attributes": {
        "oauth2.device.authorization.grant.enabled": "true",
        "pkce.code.challenge.method": "S256"
      },
      "defaultClientScopes": ["profile"],
      "redirectUris": ["http://localhost:*", "http://127.0.0.1:*"],
      "protocolMappers": [
        {
          "name": "groups",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-group-membership-mapper",
          "config": {
            "claim.name": "groups",
            "full.path": "false",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "userinfo.token.claim": "true"
          }
        }
      ]
    },
    {
      "clientId": "arazzo-directory",
      "name": "Arazzo grantee directory (service account)",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": false,
      "secret": "arazzo-directory-dev-secret",
      "standardFlowEnabled": false,
      "directAccessGrantsEnabled": false,
      "serviceAccountsEnabled": true
    },
    {
      "clientId": "arazzo-runner",
      "name": "Arazzo execution-host runner (machine principal, design §16.4)",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": false,
      "secret": "arazzo-runner-dev-secret",
      "standardFlowEnabled": false,
      "directAccessGrantsEnabled": false,
      "serviceAccountsEnabled": true,
      "defaultClientScopes": ["runners:register", "runs:write"],
      "protocolMappers": [
        {
          "name": "scheduler-group",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-hardcoded-claim-mapper",
          "config": {
            "claim.name": "groups",
            "claim.value": "arazzo-schedulers",
            "jsonType.label": "String",
            "id.token.claim": "false",
            "access.token.claim": "true",
            "userinfo.token.claim": "false"
          }
        }
      ]
    },
    {
      "clientId": "arazzo-access-approval",
      "name": "Arazzo control-plane system runner (machine principal, design §16.5.1)",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": false,
      "secret": "arazzo-access-approval-dev-secret",
      "standardFlowEnabled": false,
      "directAccessGrantsEnabled": false,
      "serviceAccountsEnabled": true,
      "defaultClientScopes": ["runners:register", "accessRequests:grant"]
    }
  ],
  "clientScopes": [
    {
      "name": "profile",
      "description": "OpenID Connect profile scope (preferred_username + name). Defined here because listing custom clientScopes on import suppresses Keycloak's built-in scopes, so the standard-flow clients would otherwise lack it.",
      "protocol": "openid-connect",
      "attributes": { "include.in.token.scope": "true", "display.on.consent.screen": "false" },
      "protocolMappers": [
        {
          "name": "username",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-property-mapper",
          "config": {
            "user.attribute": "username",
            "claim.name": "preferred_username",
            "jsonType.label": "String",
            "id.token.claim": "true",
            "access.token.claim": "true",
            "userinfo.token.claim": "true"
          }
        },
        {
          "name": "full name",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-full-name-mapper",
          "config": {
            "id.token.claim": "true",
            "access.token.claim": "true",
            "userinfo.token.claim": "true"
          }
        }
      ]
    },
    {
      "name": "runners:register",
      "description": "Register a runner to serve a deployment environment as a trusted machine principal (design §5.5/§16.4).",
      "protocol": "openid-connect",
      "attributes": { "include.in.token.scope": "true", "display.on.consent.screen": "false" }
    },
    {
      "name": "accessRequests:grant",
      "description": "Grant an access request as the control plane's own approval workflow (design §16.5.1). Held by the system runner's machine principal so its access-approval runs may call grantAccessRequest.",
      "protocol": "openid-connect",
      "attributes": { "include.in.token.scope": "true", "display.on.consent.screen": "false" }
    },
    {
      "name": "runs:write",
      "description": "Start runs of catalogued workflow versions (design §5.5). Held by the runner's machine principal so its durable scheduler (#896) may fire scheduled targets through the governed run endpoint.",
      "protocol": "openid-connect",
      "attributes": { "include.in.token.scope": "true", "display.on.consent.screen": "false" }
    }
  ]
}
