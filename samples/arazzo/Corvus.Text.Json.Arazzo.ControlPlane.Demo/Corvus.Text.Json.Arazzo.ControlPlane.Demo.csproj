<Project Sdk="Microsoft.NET.Sdk.Web">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <LangVersion>preview</LangVersion>
    <IsPackable>false</IsPackable>
    <!-- The /validate endpoint compiles a JSON Schema at runtime; the host must preserve its compilation
         context so the validator's dynamic compiler has the right defines + reference assemblies. -->
    <PreserveCompilationContext>true</PreserveCompilationContext>
  </PropertyGroup>

  <ItemGroup>
    <Content Update="specs\**\*.json" CopyToOutputDirectory="PreserveNewest" />
  </ItemGroup>

  <ItemGroup>
    <!-- Keycloak JWT-bearer client integration: validates OIDC tokens against the referenced Keycloak realm (§16.3). -->
    <PackageReference Include="Aspire.Keycloak.Authentication" />
  </ItemGroup>

  <ItemGroup>
    <!-- Aspire service defaults: OpenTelemetry (incl. the Corvus.Arazzo source/meter), health checks,
         service discovery, HTTP resilience — so this host's telemetry flows to the Aspire dashboard. -->
    <ProjectReference Include="..\Corvus.Text.Json.Arazzo.ControlPlane.Demo.ServiceDefaults\Corvus.Text.Json.Arazzo.ControlPlane.Demo.ServiceDefaults.csproj" />
    <ProjectReference Include="..\..\..\src\Corvus.Text.Json.Arazzo\Corvus.Text.Json.Arazzo.csproj" />
    <ProjectReference Include="..\..\..\src\Corvus.Text.Json.Arazzo.CodeGeneration\Corvus.Text.Json.Arazzo.CodeGeneration.csproj" />
    <!-- Live execution: the executor provider bakes a compiled executor into each catalogued version at add time;
         the loader + HTTP transport let the resumer re-enter it against the hosted /svc backends. -->
    <ProjectReference Include="..\..\..\src\Corvus.Text.Json.Arazzo.Generation\Corvus.Text.Json.Arazzo.Generation.csproj" />
    <ProjectReference Include="..\..\..\src\Corvus.Text.Json.Arazzo.Execution\Corvus.Text.Json.Arazzo.Execution.csproj" />
    <ProjectReference Include="..\..\..\src\Corvus.Text.Json.OpenApi.HttpTransport\Corvus.Text.Json.OpenApi.HttpTransport.csproj" />
    <ProjectReference Include="..\..\..\src\Corvus.Text.Json.Arazzo.Durability\Corvus.Text.Json.Arazzo.Durability.csproj" />
    <ProjectReference Include="..\..\..\src\Corvus.Text.Json.Arazzo.Durability.Sqlite\Corvus.Text.Json.Arazzo.Durability.Sqlite.csproj" />
    <ProjectReference Include="..\..\..\src\Corvus.Text.Json.Arazzo.Durability.ControlPlane.Server\Corvus.Text.Json.Arazzo.Durability.ControlPlane.Server.csproj" />
  </ItemGroup>

</Project>
