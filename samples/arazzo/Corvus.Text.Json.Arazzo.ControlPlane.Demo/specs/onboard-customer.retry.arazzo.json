{
  "arazzo": "1.1.0",
  "info": { "title": "Onboard Customer (retry on transient KYC outage)", "version": "1.0.0", "description": "Create an account and verify identity, retrying the identity check with a backoff when the provider returns a transient low/incomplete result — the run suspends on a durable timer between attempts and resumes when the backoff elapses." },
  "sourceDescriptions": [ { "name": "onboarding", "url": "./onboarding.openapi.json", "type": "openapi" } ],
  "workflows": [
    {
      "workflowId": "onboard-customer-retry",
      "inputs": {
        "type": "object",
        "properties": {
          "email": { "type": "string", "format": "idn-email", "description": "The applicant's email." },
          "fullName": { "type": "string", "description": "The applicant's full name, submitted for identity verification." },
          "plan": { "type": "string", "enum": [ "free", "pro", "enterprise" ] }
        },
        "required": [ "email" ]
      },
      "steps": [
        { "stepId": "createAccount", "operationId": "createAccount", "outputs": { "accountId": "$response.body#/accountId" } },
        {
          "stepId": "verifyIdentity",
          "operationId": "verifyIdentity",
          "parameters": [ { "name": "accountId", "in": "path", "value": "$steps.createAccount.outputs.accountId" } ],
          "requestBody": {
            "contentType": "application/json",
            "payload": { "fullName": "Applicant", "documentNumber": "X1234567" },
            "replacements": [ { "target": "/fullName", "value": "$inputs.fullName" } ]
          },
          "successCriteria": [
            { "condition": "$statusCode == 200" },
            { "condition": "$response.body#/score >= 0.8" }
          ],
          "onFailure": [
            { "name": "retryAfterBackoff", "type": "retry", "retryAfter": 2, "retryLimit": 3 }
          ],
          "outputs": {
            "score": "$response.body#/score",
            "method": "$response.body#/method",
            "applicant": "$response.body#/applicant",
            "evidence": "$response.body#/evidence",
            "flags": "$response.body#/flags"
          }
        },
        {
          "stepId": "provisionResources",
          "operationId": "provisionResources",
          "parameters": [ { "name": "accountId", "in": "path", "value": "$steps.createAccount.outputs.accountId" } ],
          "outputs": {
            "accountUrl": "$response.body#/accountUrl",
            "quotaGb": "$response.body#/quotaGb",
            "resources": "$response.body#/resources",
            "tags": "$response.body#/tags"
          }
        },
        {
          "stepId": "notifyApplicant",
          "operationId": "sendWelcome",
          "parameters": [ { "name": "accountId", "in": "path", "value": "$steps.createAccount.outputs.accountId" } ],
          "outputs": {}
        }
      ]
    }
  ]
}
