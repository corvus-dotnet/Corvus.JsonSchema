<Project Sdk="Microsoft.NET.Sdk.Web">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <LangVersion>preview</LangVersion>
    <IsPackable>false</IsPackable>
    <!-- The system runner re-enters catalogued executors (the access-approval workflow); the durable executor loader's
         Roslyn compile needs the reference assemblies preserved, exactly as the app runner and control-plane host do. -->
    <PreserveCompilationContext>true</PreserveCompilationContext>
  </PropertyGroup>

  <ItemGroup>
    <!-- Aspire service defaults: OpenTelemetry, health checks, service discovery — traces/logs/metrics to the dashboard. -->
    <ProjectReference Include="..\Corvus.Text.Json.Arazzo.ControlPlane.Demo.ServiceDefaults\Corvus.Text.Json.Arazzo.ControlPlane.Demo.ServiceDefaults.csproj" />
    <!-- The reusable runner building blocks (RunnerOptions, RunnerRegistrationService, WorkflowDispatchService,
         ControlPlaneRunnerRegistrar, VaultTokenLifecycleService, DraftRunHost.CreateBinder), shared with the app runner.
         Only this project's composition root (its sources, environment, and access-decision consumer) differs. -->
    <ProjectReference Include="..\Corvus.Text.Json.Arazzo.Runner\Corvus.Text.Json.Arazzo.Runner.csproj" />
    <!-- The bootstrapped access-approval workflow's generated access-decision consumer + its resume handler. -->
    <ProjectReference Include="..\..\..\src\Corvus.Text.Json.Arazzo.Durability.ControlPlane.SystemWorkflows\Corvus.Text.Json.Arazzo.Durability.ControlPlane.SystemWorkflows.csproj" />
    <!-- The composition root directly opens the shared Postgres stores, resolves the OAuth2 credential as its own Vault
         identity, loads the signed executor, and drives runs against the NATS bus (access.notify / access.decision). -->
    <ProjectReference Include="..\..\..\src\Corvus.Text.Json.Arazzo\Corvus.Text.Json.Arazzo.csproj" />
    <ProjectReference Include="..\..\..\src\Corvus.Text.Json.Arazzo.Durability\Corvus.Text.Json.Arazzo.Durability.csproj" />
    <ProjectReference Include="..\..\..\src\Corvus.Text.Json.Arazzo.Durability.Postgres\Corvus.Text.Json.Arazzo.Durability.Postgres.csproj" />
    <ProjectReference Include="..\..\..\src\Corvus.Text.Json.Arazzo.Durability.Vault\Corvus.Text.Json.Arazzo.Durability.Vault.csproj" />
    <ProjectReference Include="..\..\..\src\Corvus.Text.Json.Arazzo.Generation\Corvus.Text.Json.Arazzo.Generation.csproj" />
    <ProjectReference Include="..\..\..\src\Corvus.Text.Json.OpenApi.HttpTransport\Corvus.Text.Json.OpenApi.HttpTransport.csproj" />
    <ProjectReference Include="..\..\..\src\Corvus.Text.Json.Arazzo.SourceCredentials.Http\Corvus.Text.Json.Arazzo.SourceCredentials.Http.csproj" />
    <ProjectReference Include="..\..\..\src\Corvus.Text.Json.AsyncApi.Nats\Corvus.Text.Json.AsyncApi.Nats.csproj" />
  </ItemGroup>

</Project>
