<Project Sdk="Microsoft.NET.Sdk.Web">

  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <LangVersion>preview</LangVersion>
    <IsPackable>false</IsPackable>
    <!-- §18: the runner compiles a captured draft at runtime through WorkflowExecutorProvider (durable mode); the
         Roslyn compile needs the reference assemblies preserved, exactly as the control-plane host requires. -->
    <PreserveCompilationContext>true</PreserveCompilationContext>
  </PropertyGroup>

  <ItemGroup>
    <!-- Aspire service defaults: OpenTelemetry (incl. the shared Corvus.Arazzo source/meter), health checks,
         service discovery, HTTP resilience — the runner's traces/logs/metrics flow to the Aspire dashboard. -->
    <ProjectReference Include="..\Corvus.Text.Json.Arazzo.ControlPlane.Demo.ServiceDefaults\Corvus.Text.Json.Arazzo.ControlPlane.Demo.ServiceDefaults.csproj" />
    <ProjectReference Include="..\..\..\src\Corvus.Text.Json.Arazzo\Corvus.Text.Json.Arazzo.csproj" />
    <ProjectReference Include="..\..\..\src\Corvus.Text.Json.Arazzo.Durability\Corvus.Text.Json.Arazzo.Durability.csproj" />
    <ProjectReference Include="..\..\..\src\Corvus.Text.Json.Arazzo.Durability.Sqlite\Corvus.Text.Json.Arazzo.Durability.Sqlite.csproj" />
    <!-- The §13 secret consumer: the HashiCorp Vault ISecretResolver (vault://), pulls in VaultSharp transitively. -->
    <ProjectReference Include="..\..\..\src\Corvus.Text.Json.Arazzo.Durability.Vault\Corvus.Text.Json.Arazzo.Durability.Vault.csproj" />
    <!-- §18 out-of-process draft hosting: the durable executor provider (compiles a captured draft), the HTTP
         transport factory the runner executes debug runs through, and the §13.5 credential-aware binder that resolves
         each source's secret as the runner's own read-only identity at bind time. -->
    <ProjectReference Include="..\..\..\src\Corvus.Text.Json.Arazzo.Generation\Corvus.Text.Json.Arazzo.Generation.csproj" />
    <ProjectReference Include="..\..\..\src\Corvus.Text.Json.OpenApi.HttpTransport\Corvus.Text.Json.OpenApi.HttpTransport.csproj" />
    <ProjectReference Include="..\..\..\src\Corvus.Text.Json.Arazzo.SourceCredentials.Http\Corvus.Text.Json.Arazzo.SourceCredentials.Http.csproj" />
    <!-- InMemoryMessageTransport: the demo's stand-in broker for AsyncAPI channel steps (a real broker adapter replaces it in production, design §8). Same reference the control-plane host uses. -->
    <ProjectReference Include="..\..\..\src\Corvus.Text.Json.AsyncApi.Testing\Corvus.Text.Json.AsyncApi.Testing.csproj" />
  </ItemGroup>

</Project>
