{
  "asyncapi": "3.0.0",
  "info": {
    "title": "Onboarding Notifications",
    "version": "1.0.0",
    "description": "The asynchronous KYC exchange, owned by the application (not the control plane). The onboard-customer workflow PUBLISHES a review request to kyc.requests (carrying the account id) then SUSPENDS awaiting the verdict on kyc.verdict, correlated by that account id. The KYC service SUBSCRIBES to the requests (its manual-recovery inbox) and PUBLISHES a verdict when an operator reviews it. This AsyncAPI defines that exchange the same way the OpenAPI specs define the synchronous HTTP ones."
  },
  "defaultContentType": "application/json",
  "channels": {
    "kycRequests": {
      "address": "kyc.requests",
      "messages": { "kycReviewRequest": { "$ref": "#/components/messages/kycReviewRequest" } }
    },
    "kycResults": {
      "address": "kyc.verdict",
      "messages": { "kycVerdict": { "$ref": "#/components/messages/kycVerdict" } }
    }
  },
  "operations": {
    "publishKycReview": {
      "action": "send",
      "channel": { "$ref": "#/channels/kycRequests" },
      "messages": [ { "$ref": "#/channels/kycRequests/messages/kycReviewRequest" } ]
    },
    "receiveKycReview": {
      "action": "receive",
      "channel": { "$ref": "#/channels/kycRequests" },
      "messages": [ { "$ref": "#/channels/kycRequests/messages/kycReviewRequest" } ]
    },
    "publishKycVerdict": {
      "action": "send",
      "channel": { "$ref": "#/channels/kycResults" },
      "messages": [ { "$ref": "#/channels/kycResults/messages/kycVerdict" } ]
    },
    "receiveKycVerdict": {
      "action": "receive",
      "channel": { "$ref": "#/channels/kycResults" },
      "messages": [ { "$ref": "#/channels/kycResults/messages/kycVerdict" } ]
    }
  },
  "components": {
    "correlationIds": {
      "kycAccount": {
        "description": "Correlates a KYC review request with its verdict by the account id carried in the payload.",
        "location": "$message.payload#/accountId"
      }
    },
    "messages": {
      "kycReviewRequest": {
        "name": "kycReviewRequest",
        "title": "KYC review requested",
        "correlationId": { "$ref": "#/components/correlationIds/kycAccount" },
        "payload": { "$ref": "#/components/schemas/kycReviewRequestPayload" }
      },
      "kycVerdict": {
        "name": "kycVerdict",
        "title": "KYC verdict",
        "correlationId": { "$ref": "#/components/correlationIds/kycAccount" },
        "payload": { "$ref": "#/components/schemas/kycVerdictPayload" }
      }
    },
    "schemas": {
      "kycReviewRequestPayload": {
        "type": "object",
        "properties": {
          "accountId": { "type": "string" },
          "email": { "type": "string", "format": "idn-email" },
          "fullName": { "type": "string" }
        },
        "required": [ "accountId" ]
      },
      "kycVerdictPayload": {
        "type": "object",
        "properties": {
          "accountId": { "type": "string" },
          "verified": { "type": "boolean" },
          "score": { "type": "number", "minimum": 0, "maximum": 1 }
        },
        "required": [ "accountId", "verified", "score" ]
      }
    }
  }
}
