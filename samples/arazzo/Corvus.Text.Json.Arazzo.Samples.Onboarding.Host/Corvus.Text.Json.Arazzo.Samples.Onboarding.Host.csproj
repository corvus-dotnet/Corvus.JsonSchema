<Project Sdk="Microsoft.NET.Sdk.Web">

  <!-- Hosts the onboarding domain service as its own process (an Aspire resource): a genuine external source the
       Arazzo control plane and runner call over the network, backed by its own PostgreSQL database. -->
  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <LangVersion>preview</LangVersion>
    <IsPackable>false</IsPackable>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Npgsql" />
  </ItemGroup>

  <ItemGroup>
    <!-- Aspire service defaults: OpenTelemetry, health checks, service discovery, HTTP resilience. -->
    <ProjectReference Include="..\Corvus.Text.Json.Arazzo.ControlPlane.Demo.ServiceDefaults\Corvus.Text.Json.Arazzo.ControlPlane.Demo.ServiceDefaults.csproj" />
    <ProjectReference Include="..\Corvus.Text.Json.Arazzo.Samples.Onboarding\Corvus.Text.Json.Arazzo.Samples.Onboarding.csproj" />
  </ItemGroup>

</Project>
