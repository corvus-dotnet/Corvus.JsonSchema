<Project Sdk="Microsoft.NET.Sdk">

  <!-- The onboarding domain service: a real, stateful onboarding backend (customer accounts, KYC identity
       verification, resource provisioning) presented through its generated OpenAPI server. It is a first-class
       library the Arazzo sample orchestrates as a genuine external source, not an inline mock. It owns its own
       Postgres database (the microservice-owns-its-data pattern) — see the .Host project + the AppHost wiring. -->
  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <LangVersion>preview</LangVersion>
    <IsPackable>false</IsPackable>
  </PropertyGroup>

  <ItemGroup>
    <!-- The generated ApiEndpointRegistration maps the operations onto ASP.NET Core minimal-API routes. -->
    <FrameworkReference Include="Microsoft.AspNetCore.App" />
  </ItemGroup>

  <ItemGroup>
    <!-- The account store persists the aggregate to the service's own Postgres database. -->
    <PackageReference Include="Npgsql" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\..\..\src\Corvus.Text.Json\Corvus.Text.Json.csproj" />
    <ProjectReference Include="..\..\..\src\Corvus.Text.Json.OpenApi\Corvus.Text.Json.OpenApi.csproj" />
  </ItemGroup>

  <ItemGroup>
    <!-- The service contract, kept beside the generated server it produces. Regenerate with the
         Corvus.Json.Cli openapi-server command over this spec (rootNamespace
         Corvus.Text.Json.Arazzo.Samples.Onboarding, outputPath the Generated folder) — see README. -->
    <None Include="specs\**\*.json" />
  </ItemGroup>

</Project>
