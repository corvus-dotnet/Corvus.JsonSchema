<Project Sdk="Microsoft.NET.Sdk">
  <Import Project="$(EndjinProjectPropsPath)" Condition="$(EndjinProjectPropsPath) != ''" />
  <PropertyGroup>
    <TargetFrameworks>net9.0;net10.0</TargetFrameworks>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <PreserveCompilationContext>true</PreserveCompilationContext>
    <NoWarn>$(NoWarn);NU1504;CS1591;SA1210;SA1514;SA1509;SA1513;SA1508;SA1000;SA1028;SA1400;SA1511;SA1507;RCS1251</NoWarn>
    <EndjinDisableCreateEditorConfig>true</EndjinDisableCreateEditorConfig>
    <EndjinDisableAutoPackagesLock>true</EndjinDisableAutoPackagesLock>
    <IsPackable>false</IsPackable>
  </PropertyGroup>

  <!-- The GeneratorConfig model is generated at build time from generator-config.json by the
       V4 source generator (the model and its consumers use the V4 Corvus.Json runtime).
       DocumentationNameHeuristic is re-enabled (the generator disables it by default) to preserve
       the documentation-derived type names this configuration schema relies on. -->
  <PropertyGroup>
    <CorvusJsonSchemaOptionalAsNullable>NullOrUndefined</CorvusJsonSchemaOptionalAsNullable>
    <CorvusJsonSchemaDisabledNamingHeuristics></CorvusJsonSchemaDisabledNamingHeuristics>
    <CorvusJsonSchemaDefaultAccessibility>Public</CorvusJsonSchemaDefaultAccessibility>
  </PropertyGroup>
  <ItemGroup>
    <CompilerVisibleProperty Include="CorvusJsonSchemaOptionalAsNullable" />
    <CompilerVisibleProperty Include="CorvusJsonSchemaDisabledNamingHeuristics" />
    <CompilerVisibleProperty Include="CorvusJsonSchemaDefaultAccessibility" />
    <AdditionalFiles Include="generator-config.json" />
    <ProjectReference Include="..\..\src-v4\Corvus.Json.SourceGenerator\Corvus.Json.SourceGenerator.csproj" OutputItemType="Analyzer" ReferenceOutputAssembly="false" SetTargetFramework="TargetFramework=netstandard2.0" />
  </ItemGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.CodeAnalysis.CSharp" />
    <PackageReference Include="Spectre.Console.Cli" />
    <PackageReference Include="System.Collections.Immutable" />
    <PackageReference Include="System.Reflection.Metadata" />
  </ItemGroup>
  <ItemGroup>
    <InternalsVisibleTo Include="Corvus.Text.Json.CodeGenerator.Tests" />
  </ItemGroup>
  <ItemGroup>
    <ProjectReference Include="..\..\src-v4\Corvus.Json.CodeGeneration.201909\Corvus.Json.CodeGeneration.201909.csproj" />
    <ProjectReference Include="..\..\src-v4\Corvus.Json.CodeGeneration.202012\Corvus.Json.CodeGeneration.202012.csproj" />
    <ProjectReference Include="..\..\src-v4\Corvus.Json.CodeGeneration.4\Corvus.Json.CodeGeneration.4.csproj" />
    <ProjectReference Include="..\..\src-v4\Corvus.Json.CodeGeneration.6\Corvus.Json.CodeGeneration.6.csproj" />
    <ProjectReference Include="..\..\src-v4\Corvus.Json.CodeGeneration.7\Corvus.Json.CodeGeneration.7.csproj" />
    <ProjectReference Include="..\..\src-v4\Corvus.Json.CodeGeneration.CorvusVocabulary\Corvus.Json.CodeGeneration.CorvusVocabulary.csproj" />
    <ProjectReference Include="..\..\src-v4\Corvus.Json.CodeGeneration.CSharp\Corvus.Json.CodeGeneration.CSharp.csproj" />
    <ProjectReference Include="..\..\src-v4\Corvus.Json.CodeGeneration.HttpClientDocumentResolver\Corvus.Json.CodeGeneration.HttpClientDocumentResolver.csproj" />
    <ProjectReference Include="..\..\src-v4\Corvus.Json.CodeGeneration.OpenApi30\Corvus.Json.CodeGeneration.OpenApi30.csproj" />
    <ProjectReference Include="..\..\src-v4\Corvus.Json.CodeGeneration.YamlPreProcessor\Corvus.Json.CodeGeneration.YamlPreProcessor.csproj" />
    <ProjectReference Include="..\..\src-v4\Corvus.Json.ExtendedTypes\Corvus.Json.ExtendedTypes.csproj" />
  </ItemGroup>
  <ItemGroup>
    <ProjectReference Include="..\Corvus.Text.Json.CodeGeneration\Corvus.Text.Json.CodeGeneration.csproj" />
    <ProjectReference Include="..\Corvus.Text.Json.JsonLogic.CodeGeneration\Corvus.Text.Json.JsonLogic.CodeGeneration.csproj" />
    <ProjectReference Include="..\Corvus.Text.Json.Jsonata.CodeGeneration\Corvus.Text.Json.Jsonata.CodeGeneration.csproj" />
    <ProjectReference Include="..\Corvus.Text.Json.JMESPath.CodeGeneration\Corvus.Text.Json.JMESPath.CodeGeneration.csproj" />
    <ProjectReference Include="..\Corvus.Text.Json.JsonPath.CodeGeneration\Corvus.Text.Json.JsonPath.CodeGeneration.csproj" />
    <ProjectReference Include="..\Corvus.Text.Json.Validator\Corvus.Text.Json.Validator.csproj" />
  </ItemGroup>
  <ItemGroup Condition="'$(TargetFramework)' == 'net10.0'">
    <ProjectReference Include="..\Corvus.Text.Json.OpenApi.CodeGeneration\Corvus.Text.Json.OpenApi.CodeGeneration.csproj" />
    <ProjectReference Include="..\Corvus.Text.Json.OpenApi32\Corvus.Text.Json.OpenApi32.csproj" />
    <ProjectReference Include="..\Corvus.Text.Json.OpenApi31\Corvus.Text.Json.OpenApi31.csproj" />
    <ProjectReference Include="..\Corvus.Text.Json.OpenApi30\Corvus.Text.Json.OpenApi30.csproj" />
    <ProjectReference Include="..\Corvus.Text.Json.AsyncApi.CodeGeneration\Corvus.Text.Json.AsyncApi.CodeGeneration.csproj" />
    <ProjectReference Include="..\Corvus.Text.Json.Arazzo11\Corvus.Text.Json.Arazzo11.csproj" />
    <ProjectReference Include="..\Corvus.Text.Json.Arazzo.CodeGeneration\Corvus.Text.Json.Arazzo.CodeGeneration.csproj" />
    <ProjectReference Include="..\Corvus.Text.Json.Arazzo.Generation\Corvus.Text.Json.Arazzo.Generation.csproj" />
  </ItemGroup>
  <!-- The metaschema documents and the AddMetaschema helper live in the net10-only
       Corvus.Text.Json.Arazzo.Generation assembly, which the net10 target references directly.
       The net9 target cannot reference it, so it links the same source + content (no duplication)
       to keep the V4/V5 JSON Schema generation path working under net9. -->
  <ItemGroup Condition="'$(TargetFramework)' == 'net9.0'">
    <Compile Include="..\Corvus.Text.Json.Arazzo.Generation\Metaschema.cs" Link="Metaschema.cs" />
    <None Include="..\Corvus.Text.Json.Arazzo.Generation\metaschema\**\*.json" Link="metaschema\%(RecursiveDir)%(Filename)%(Extension)">
      <CopyToOutputDirectory>PreserveNewest</CopyToOutputDirectory>
    </None>
  </ItemGroup>
  <ItemGroup>
    <PackageReference Include="Endjin.RecommendedPractices.GitHub" PrivateAssets="All" />
    <PackageReference Include="StyleCop.Analyzers" PrivateAssets="All" />
    <PackageReference Include="Roslynator.Analyzers" PrivateAssets="All" />
  </ItemGroup>
</Project>