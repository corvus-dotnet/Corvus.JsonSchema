<Project Sdk="Microsoft.NET.Sdk">
  <Import Project="$(EndjinProjectPropsPath)" Condition="$(EndjinProjectPropsPath) != ''" />
  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <LangVersion>preview</LangVersion>
    <AllowUnsafeBlocks>true</AllowUnsafeBlocks>
    <TreatWarningsAsErrors>true</TreatWarningsAsErrors>
    <WarningsNotAsErrors>$(WarningsNotAsErrors);NU1901;NU1902;NU1903;NU1904</WarningsNotAsErrors>
    <NoWarn>$(NoWarn);CS1591;NU1504;CS8500;CS8969;IDE0065;IDE0290;IDE0079;IDE0130;CS1572;CS1573;CS1574;CS1584;CS1658</NoWarn>
    <EndjinDisableCreateEditorConfig>true</EndjinDisableCreateEditorConfig>
    <IsPackable>true</IsPackable>
    <PackageLicenseExpression>Apache-2.0</PackageLicenseExpression>
    <Description>An ASP.NET Core server for the Arazzo durability control-plane REST API (generated from its OpenAPI 3.2 description), wiring the generated endpoints to ISecuredWorkflowManagement.</Description>
    <PackageReadmeFile>README.md</PackageReadmeFile>
  </PropertyGroup>
  <ItemGroup>
    <FrameworkReference Include="Microsoft.AspNetCore.App" />
  </ItemGroup>
  <ItemGroup>
    <InternalsVisibleTo Include="Corvus.Text.Json.Arazzo.Durability.ControlPlane.Server.Tests" />
    <InternalsVisibleTo Include="Corvus.Text.Json.Arazzo.Durability.Benchmarks" />
  </ItemGroup>
  <ItemGroup>
    <ProjectReference Include="..\Corvus.Text.Json\Corvus.Text.Json.csproj" />
    <ProjectReference Include="..\Corvus.Text.Json.OpenApi\Corvus.Text.Json.OpenApi.csproj" />
    <ProjectReference Include="..\Corvus.Text.Json.Arazzo\Corvus.Text.Json.Arazzo.csproj" />
    <ProjectReference Include="..\Corvus.Text.Json.Arazzo.Durability\Corvus.Text.Json.Arazzo.Durability.csproj" />
    <!-- The workflow-backed approval strategy (design §16.5.1) publishes the access.decision message via the generated
         producer; the opt-in options name IMessageTransport directly, so the AsyncAPI abstraction is referenced explicitly. -->
    <ProjectReference Include="..\Corvus.Text.Json.AsyncApi\Corvus.Text.Json.AsyncApi.csproj" />
    <ProjectReference Include="..\Corvus.Text.Json.Arazzo.Durability.ControlPlane.SystemWorkflows\Corvus.Text.Json.Arazzo.Durability.ControlPlane.SystemWorkflows.csproj" />
    <ProjectReference Include="..\Corvus.Text.Json.Arazzo.Directories\Corvus.Text.Json.Arazzo.Directories.csproj" />
    <!-- The validate endpoint builds a target schema from the package and validates against it at runtime. -->
    <ProjectReference Include="..\Corvus.Text.Json.Arazzo.CodeGeneration\Corvus.Text.Json.Arazzo.CodeGeneration.csproj" />
    <ProjectReference Include="..\Corvus.Text.Json.Validator\Corvus.Text.Json.Validator.csproj" />
    <!-- fetchSourceDocument (design §4.4): credentialed server-side fetch + YAML spec parsing. -->
    <ProjectReference Include="..\Corvus.Text.Json.Arazzo.SourceCredentials.Http\Corvus.Text.Json.Arazzo.SourceCredentials.Http.csproj" />
    <ProjectReference Include="..\Corvus.Text.Json.OpenApi.HttpTransport\Corvus.Text.Json.OpenApi.HttpTransport.csproj" />
    <ProjectReference Include="..\Corvus.Text.Json.Yaml\Corvus.Text.Json.Yaml.csproj" />
    <ProjectReference Include="..\Corvus.Text.Json.Arazzo.Testing\Corvus.Text.Json.Arazzo.Testing.csproj" />
  </ItemGroup>
  <ItemGroup>
    <PackageReference Include="Endjin.RecommendedPractices.GitHub" PrivateAssets="All" />
    <PackageReference Include="StyleCop.Analyzers" PrivateAssets="All" />
    <PackageReference Include="Roslynator.Analyzers" PrivateAssets="All" />
  </ItemGroup>
  <ItemGroup>
    <None Include="README.md" Pack="true" PackagePath="\" />
  </ItemGroup>
  <ItemGroup>
    <!-- The Arazzo meta-schemas, embedded for validateWorkspaceWorkflow's document-conformance pass
         (picked by the document's declared arazzo version). -->
    <EmbeddedResource Include="..\Corvus.Text.Json.Arazzo10\Arazzo10.json" Link="Schemas\Arazzo10.json" LogicalName="Corvus.Text.Json.Arazzo.Durability.ControlPlane.Server.Schemas.Arazzo10.json" />
    <EmbeddedResource Include="..\Corvus.Text.Json.Arazzo11\Arazzo11.json" Link="Schemas\Arazzo11.json" LogicalName="Corvus.Text.Json.Arazzo.Durability.ControlPlane.Server.Schemas.Arazzo11.json" />
  </ItemGroup>
</Project>
