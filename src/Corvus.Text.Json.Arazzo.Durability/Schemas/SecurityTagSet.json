{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "SecurityTagSet",
  "description": "The persisted JSON form of a row's security tags (KVP labels, §14.2) for backends that store the set as a single JSON value (e.g. a Redis hash field or an Azure Table property).",
  "type": "object",
  "required": ["securityTags"],
  "properties": {
    "securityTags": {
      "type": "array",
      "description": "The security labels.",
      "items": { "$ref": "#/$defs/SecurityTagEntry" }
    }
  },
  "additionalProperties": false,
  "$defs": {
    "SecurityTagEntry": {
      "title": "SecurityTagEntry",
      "type": "object",
      "description": "A security label (KVP).",
      "required": ["key", "value"],
      "properties": {
        "key": { "type": "string", "description": "The label key (e.g. tenant)." },
        "value": { "type": "string", "description": "The label value (e.g. acme)." }
      },
      "additionalProperties": false
    }
  }
}
