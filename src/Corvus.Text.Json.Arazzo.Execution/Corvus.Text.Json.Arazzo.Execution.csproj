<Project Sdk="Microsoft.NET.Sdk">
  <Import Project="$(EndjinProjectPropsPath)" Condition="$(EndjinProjectPropsPath) != ''" />
  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <LangVersion>preview</LangVersion>
    <TreatWarningsAsErrors>true</TreatWarningsAsErrors>
    <WarningsNotAsErrors>$(WarningsNotAsErrors);NU1901;NU1902;NU1903;NU1904</WarningsNotAsErrors>
    <NoWarn>$(NoWarn);CS1591;NU1504</NoWarn>
    <EndjinDisableCreateEditorConfig>true</EndjinDisableCreateEditorConfig>
    <IsPackable>true</IsPackable>
    <PackageLicenseExpression>Apache-2.0</PackageLicenseExpression>
    <Description>Runner-side hosting for Arazzo workflows: loads a compiled workflow executor assembly into a collectible AssemblyLoadContext, verifies its integrity against the executor manifest, and resolves it to an IHostedWorkflow.</Description>
  </PropertyGroup>
  <ItemGroup>
    <ProjectReference Include="..\Corvus.Text.Json.Arazzo\Corvus.Text.Json.Arazzo.csproj" />
  </ItemGroup>
  <ItemGroup>
    <PackageReference Include="Endjin.RecommendedPractices.GitHub" PrivateAssets="All" />
    <PackageReference Include="StyleCop.Analyzers" PrivateAssets="All" />
    <PackageReference Include="Roslynator.Analyzers" PrivateAssets="All" />
  </ItemGroup>
</Project>
