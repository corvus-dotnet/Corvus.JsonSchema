<Project Sdk="Microsoft.NET.Sdk">
  <Import Project="$(EndjinProjectPropsPath)" Condition="$(EndjinProjectPropsPath) != ''" />
  <PropertyGroup>
    <TargetFramework>net10.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <LangVersion>preview</LangVersion>
    <TreatWarningsAsErrors>true</TreatWarningsAsErrors>
    <WarningsNotAsErrors>$(WarningsNotAsErrors);NU1901;NU1902;NU1903;NU1904</WarningsNotAsErrors>
    <NoWarn>$(NoWarn);NU1504;IDE0065;IDE0290;IDE0079;IDE0130</NoWarn>
    <EndjinDisableCreateEditorConfig>true</EndjinDisableCreateEditorConfig>
    <IsPackable>true</IsPackable>
    <PackageLicenseExpression>Apache-2.0</PackageLicenseExpression>
    <Description>Code generation engine for AsyncAPI specifications. Walks AsyncAPI 2.6 and 3.0 typed models to emit producer, consumer, and message types.</Description>
  </PropertyGroup>
  <ItemGroup>
    <ProjectReference Include="..\Corvus.Text.Json\Corvus.Text.Json.csproj" />
    <ProjectReference Include="..\Corvus.Text.Json.AsyncApi30\Corvus.Text.Json.AsyncApi30.csproj" />
    <ProjectReference Include="..\Corvus.Text.Json.AsyncApi26\Corvus.Text.Json.AsyncApi26.csproj" />
    <ProjectReference Include="..\Corvus.Text.Json.OpenApi.CodeGeneration\Corvus.Text.Json.OpenApi.CodeGeneration.csproj" />
  </ItemGroup>
  <ItemGroup>
    <PackageReference Include="Endjin.RecommendedPractices.GitHub" PrivateAssets="All" />
    <PackageReference Include="StyleCop.Analyzers" PrivateAssets="All" />
    <PackageReference Include="Roslynator.Analyzers" PrivateAssets="All" />
  </ItemGroup>
</Project>