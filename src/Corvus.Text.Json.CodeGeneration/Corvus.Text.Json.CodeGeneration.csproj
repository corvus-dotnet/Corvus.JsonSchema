<Project Sdk="Microsoft.NET.Sdk">

  <Import Project="$(EndjinProjectPropsPath)" Condition="$(EndjinProjectPropsPath) != ''" />

  <PropertyGroup>
    <TargetFrameworks>net8.0;net9.0;net10.0;netstandard2.0</TargetFrameworks>
    <AllowUnsafeBlocks>true</AllowUnsafeBlocks>
    <!-- For this project, we want warnings if there are public APIs/types without properly formatted XML comments. -->
    <SkipIntellisenseNoWarnCS1591>true</SkipIntellisenseNoWarnCS1591>
    <NoWarn>$(NoWarn);CS8969</NoWarn>
    <TreatWarningsAsErrors>true</TreatWarningsAsErrors>
    <!-- Only upgrade NuGetAudit warnings to errors for official builds. -->
    <WarningsNotAsErrors>$(WarningsNotAsErrors);NU1901;NU1902;NU1903;NU1904</WarningsNotAsErrors>
    <NoWarn Condition="$(TargetFrameworks.Contains('netstandard'))">$(NoWarn);CA1510;CA1511;CA1512;CA1513;CA1845;CA1846;CA1847;CS8600;CS8602</NoWarn>
    <!-- Warnings to always disable -->
    <NoWarn>$(NoWarn);CS8500;CS8969;IDE0065;IDE0290;IDE0079;IDE0130;NU1504;CS1591;CS1573;CS1572;CS1570;CS1584;CS1658;CS1574;CS1734</NoWarn>
    <IsPackable>true</IsPackable>
    <PackageLicenseExpression>Apache-2.0</PackageLicenseExpression>
    <PackageReadmeFile>README.md</PackageReadmeFile>
    <Description>Shared code generation engine for producing strongly-typed C# from JSON Schema. Used by Corvus.Text.Json.SourceGenerator and Corvus.Text.Json.CodeGenerator. Supports JSON Schema draft 4, 6, 7, 2019-09, and 2020-12.</Description>
    <LangVersion>preview</LangVersion>
    <CorvusTextJsonPath>..\Corvus.Text.Json\</CorvusTextJsonPath>
    <EnableDefaultCompileItems>false</EnableDefaultCompileItems>
    <EnableDefaultEmbeddedResourceItems>false</EnableDefaultEmbeddedResourceItems>
    <Nullable>enable</Nullable>
    <DefineConstants>$(DefineConstants);CORVUS_TEXT_JSON_CODEGENERATION</DefineConstants>
    <EndjinDisableCreateEditorConfig>true</EndjinDisableCreateEditorConfig>
  </PropertyGroup>

  <ItemGroup>
    <None Include="README.md" Pack="true" PackagePath="\" />
  </ItemGroup>

  <ItemGroup>
    <Compile Include="StandaloneEvaluatorGenerator.cs" />
    <Compile Include="CodeGenerationMode.cs" />
    <Compile Include="RegexPatternCategory.cs" />
    <Compile Include="CodeFileBuilders\JsonSchemaPartial.cs" />
    <Compile Include="CodeFileBuilders\MutableCorePartial.cs" />
    <Compile Include="CodeFileBuilders\CorePartial.cs" />
    <Compile Include="CodeGeneratorExtensions.Validation.cs" />
    <Compile Include="CodeGeneratorExtensions.Number.cs" />
    <Compile Include="CodeGeneratorExtensions.JsonSchema.cs" />
    <Compile Include="CodeGeneratorExtensions.Array.cs" />
    <Compile Include="CodeGeneratorExtensions.Object.cs" />
    <Compile Include="CodeGeneratorExtensions.Builder.cs" />
    <Compile Include="CodeGeneratorExtensions.Operators.cs" />
    <Compile Include="CodeGeneratorExtensions.Conversions.cs" />
    <Compile Include="CodeGeneratorExtensions.Documentation.cs" />
    <Compile Include="CodeGeneratorExtensions.MemberNames.cs" />
    <Compile Include="CodeGeneratorExtensions.cs" />
    <Compile Include="ConditionalCodeSpecification.cs" />
    <Compile Include="CSharpLanguageProvider.cs" />
    <Compile Include="CSharpMemberName.cs" />
    <Compile Include="FormatHandlers\FormatHandlerExtensions.cs" />
    <Compile Include="FormatHandlers\FormatHandlerRegistry.cs" />
    <Compile Include="FormatHandlers\IFormatHandler.cs" />
    <Compile Include="FormatHandlers\INumberFormatHandler.cs" />
    <Compile Include="FormatHandlers\IStringFormatHandler.cs" />
    <Compile Include="FormatHandlers\WellKnownNumericFormatHandler.cs" />
    <Compile Include="FormatHandlers\WellKnownStringFormatHandler.cs" />
    <Compile Include="Formatting.cs" />
    <Compile Include="FrameworkType.cs" />
