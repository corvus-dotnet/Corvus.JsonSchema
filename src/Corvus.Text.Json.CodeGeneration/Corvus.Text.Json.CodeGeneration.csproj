    <Compile Include="NameHeuristics\SingleTypeArrayNameHeuristic.cs" />
    <Compile Include="NameHeuristics\SubschemaNameHeuristic.cs" />
    <Compile Include="NameHeuristics\WellKnownTypeNameHeuristic.cs" />
    <Compile Include="NullableAttributes.cs" />
    <Compile Include="PropertyDeclarationExtensions.cs" />
    <Compile Include="SimpleTypeAndFormatterAndKind.cs" />
    <Compile Include="ThrowHelper.cs" />
    <Compile Include="TypeDeclarationExtensions.cs" />
    <Compile Include="ValidationHandlers\AllOfChildHandlers\AllOfSubschemaValidationHandler.cs" />
    <Compile Include="ValidationHandlers\AnyOfChildHandlers\AnyOfConstValidationHandler.cs" />
    <Compile Include="ValidationHandlers\AnyOfChildHandlers\AnyOfSubschemaValidationHandler.cs" />
    <Compile Include="ValidationHandlers\ArrayChildHandlers\UniqueItemsValidationHandler.cs" />
    <Compile Include="ValidationHandlers\ArrayChildHandlers\ItemCountValidationHandler.cs" />
