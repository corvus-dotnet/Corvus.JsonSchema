<Project Sdk="Microsoft.NET.Sdk">
  <Import Project="$(EndjinProjectPropsPath)" Condition="$(EndjinProjectPropsPath) != ''" />
  <PropertyGroup>
    <TargetFramework>netstandard2.0</TargetFramework>
    <Nullable>enable</Nullable>
    <AllowUnsafeBlocks>true</AllowUnsafeBlocks>
    <LangVersion>preview</LangVersion>
    <EnableDefaultCompileItems>false</EnableDefaultCompileItems>
    <RootNamespace>Corvus.Text.Json.JsonPath.SourceGenerator</RootNamespace>
    <CorvusTextJsonJsonPathPath>..\Corvus.Text.Json.JsonPath\</CorvusTextJsonJsonPathPath>
    <CorvusTextJsonJsonPathCodeGenPath>..\Corvus.Text.Json.JsonPath.CodeGeneration\</CorvusTextJsonJsonPathCodeGenPath>
    <ManagePackageVersionsCentrally>false</ManagePackageVersionsCentrally>
    <PackageReadmeFile>README.md</PackageReadmeFile>
  </PropertyGroup>
  <PropertyGroup Label="SourceGenerator">
    <IsRoslynComponent>true</IsRoslynComponent>
    <EnforceExtendedAnalyzerRules>true</EnforceExtendedAnalyzerRules>
    <IncludeSymbols>false</IncludeSymbols>
    <DefineConstants>$(DefineConstants);BUILDING_SOURCE_GENERATOR</DefineConstants>
  </PropertyGroup>
  <PropertyGroup Label="Standard">
    <TreatWarningsAsErrors>true</TreatWarningsAsErrors>
    <WarningsNotAsErrors>$(WarningsNotAsErrors);NU1901;NU1902;NU1903;NU1904</WarningsNotAsErrors>
    <NoWarn>$(NoWarn);nullable;CS1591;CS3021;NU5128;RS2008;SA0001;NU1504;CS8500;CS8969;IDE0065;IDE0290;IDE0079;IDE0130</NoWarn>
    <NoWarn>$(NoWarn);CA1510;CA1511;CA1512;CA1513;CA1845;CA1846;CA1847;CS8600;CS8602</NoWarn>
    <!-- Suppressions needed for linked JsonPath files -->
    <NoWarn>$(NoWarn);SA1518;RCS1251</NoWarn>
    <!-- XML doc warnings in linked files we cannot modify -->
    <NoWarn>$(NoWarn);CS1572;CS1573;CS1574;CS1584;CS1658</NoWarn>
    <IsPackable>true</IsPackable>
    <EndjinDisableCreateEditorConfig>true</EndjinDisableCreateEditorConfig>
    <GenerateDocumentationFile>false</GenerateDocumentationFile>
  </PropertyGroup>
  <PropertyGroup Label="NuGet">
    <DevelopmentDependency>true</DevelopmentDependency>
    <IncludeBuildOutput>false</IncludeBuildOutput>
    <PackageLicenseExpression>Apache-2.0</PackageLicenseExpression>
    <Description>Roslyn incremental source generator that produces optimized C# evaluation code from JSONPath (RFC 9535) expression files at build time.</Description>
  </PropertyGroup>
  <ItemGroup>
    <Using Include="System" />
    <Using Include="System.IO" />
    <Using Include="System.Linq" />
    <Using Include="System.Text" />
    <Using Include="System.Threading" />
    <Using Include="System.Collections.Generic" />
  </ItemGroup>
  <!-- Roslyn and polyfill packages -->
  <ItemGroup>
    <PackageReference Include="Microsoft.CodeAnalysis.CSharp" Version="4.12.0" PrivateAssets="all" />
    <PackageReference Include="PolySharp" Version="1.15.0" PrivateAssets="all" />
    <PackageReference Include="Endjin.RecommendedPractices.GitHub" Version="2.1.18" PrivateAssets="All" />
    <PackageReference Include="StyleCop.Analyzers" Version="1.2.0-beta.556" PrivateAssets="All" />
    <PackageReference Include="Roslynator.Analyzers" Version="4.13.1" PrivateAssets="All" />
  </ItemGroup>
  <!-- Generator's own source files -->
  <ItemGroup>
    <Compile Include="JsonPathSourceGenerator.cs" />
  </ItemGroup>
  <!-- Link the JsonPath code generation engine -->
  <ItemGroup>
    <Compile Include="$(CorvusTextJsonJsonPathCodeGenPath)JsonPathCodeGenerator.cs" LinkBase="CodeGeneration" />
    <Compile Include="$(CorvusTextJsonJsonPathCodeGenPath)CustomFunction.cs" LinkBase="CodeGeneration" />
    <Compile Include="$(CorvusTextJsonJsonPathCodeGenPath)JpfnParser.cs" LinkBase="CodeGeneration" />
  </ItemGroup>
  <!-- Link the JsonPath parser, lexer, and AST (no external dependencies) -->
  <ItemGroup>
    <Compile Include="$(CorvusTextJsonJsonPathPath)Parser.cs" LinkBase="JsonPath" />
    <Compile Include="$(CorvusTextJsonJsonPathPath)Lexer.cs" LinkBase="JsonPath" />
    <Compile Include="$(CorvusTextJsonJsonPathPath)Token.cs" LinkBase="JsonPath" />
    <Compile Include="$(CorvusTextJsonJsonPathPath)TokenType.cs" LinkBase="JsonPath" />
    <Compile Include="$(CorvusTextJsonJsonPathPath)JsonPathNode.cs" LinkBase="JsonPath" />
    <Compile Include="$(CorvusTextJsonJsonPathPath)JsonPathException.cs" LinkBase="JsonPath" />
    <Compile Include="$(CorvusTextJsonJsonPathPath)JsonPathFunctionType.cs" LinkBase="JsonPath" />
    <Compile Include="$(CorvusTextJsonJsonPathPath)CustomFunctionSignature.cs" LinkBase="JsonPath" />
  </ItemGroup>
  <!-- Package the generator DLLinto analyzers/dotnet/cs -->
  <ItemGroup>
    <None Include="$(OutputPath)\$(AssemblyName).dll" Pack="true" PackagePath="analyzers/dotnet/cs" Visible="false" />
  </ItemGroup>
  <ItemGroup>
    <None Include="README.md" Pack="true" PackagePath="\" />
  </ItemGroup>
</Project>
