<Project Sdk="Microsoft.NET.Sdk">
  <Import Project="$(EndjinProjectPropsPath)" Condition="$(EndjinProjectPropsPath) != ''" />
  <PropertyGroup>
    <TargetFramework>netstandard2.0</TargetFramework>
    <Nullable>enable</Nullable>
    <AllowUnsafeBlocks>true</AllowUnsafeBlocks>
    <LangVersion>preview</LangVersion>
    <EnableDefaultCompileItems>false</EnableDefaultCompileItems>
    <EnableDefaultEmbeddedResourceItems>false</EnableDefaultEmbeddedResourceItems>
    <RootNamespace>Corvus.Text.Json.Jsonata.SourceGenerator</RootNamespace>
    <CorvusTextJsonJsonataPath>..\Corvus.Text.Json.Jsonata\</CorvusTextJsonJsonataPath>
    <CorvusTextJsonJsonataCodeGenPath>..\Corvus.Text.Json.Jsonata.CodeGeneration\</CorvusTextJsonJsonataCodeGenPath>
    <CommonPath>..\..\Common\src\</CommonPath>
    <ManagePackageVersionsCentrally>false</ManagePackageVersionsCentrally>
    <PackageReadmeFile>README.md</PackageReadmeFile>
  </PropertyGroup>
  <PropertyGroup Label="SourceGenerator">
    <IsRoslynComponent>true</IsRoslynComponent>
    <EnforceExtendedAnalyzerRules>true</EnforceExtendedAnalyzerRules>
    <IncludeSymbols>false</IncludeSymbols>
    <DefineConstants>$(DefineConstants);BUILDING_SOURCE_GENERATOR</DefineConstants>
  </PropertyGroup>
  <PropertyGroup Label="Standard">
    <TreatWarningsAsErrors>true</TreatWarningsAsErrors>
    <WarningsNotAsErrors>$(WarningsNotAsErrors);NU1901;NU1902;NU1903;NU1904</WarningsNotAsErrors>
    <NoWarn>$(NoWarn);nullable;CS1591;CS3021;NU5128;RS2008;SA0001;NU1504;CS8500;CS8969;IDE0065;IDE0290;IDE0079;IDE0130</NoWarn>
    <NoWarn>$(NoWarn);CA1510;CA1511;CA1512;CA1513;CA1845;CA1846;CA1847;CS8600;CS8602</NoWarn>
    <!-- XML doc warnings in linked files we cannot modify -->
    <NoWarn>$(NoWarn);CS1570;CS1572;CS1573;CS1574;CS1584;CS1658</NoWarn>
    <IsPackable>true</IsPackable>
    <EndjinDisableCreateEditorConfig>true</EndjinDisableCreateEditorConfig>
    <GenerateDocumentationFile>false</GenerateDocumentationFile>
  </PropertyGroup>
  <PropertyGroup Label="NuGet">
    <DevelopmentDependency>true</DevelopmentDependency>
    <IncludeBuildOutput>false</IncludeBuildOutput>
    <PackageLicenseExpression>Apache-2.0</PackageLicenseExpression>
    <Description>Roslyn incremental source generator that produces optimized C# evaluation code from JSONata expression files at build time.</Description>
  </PropertyGroup>
  <ItemGroup>
    <Using Include="System" />
    <Using Include="System.IO" />
    <Using Include="System.Linq" />
    <Using Include="System.Text" />
    <Using Include="System.Threading" />
    <Using Include="System.Collections.Generic" />
    <Using Include="Resources.Strings" Alias="SR" />
  </ItemGroup>
  <!-- Roslyn and polyfill packages -->
  <ItemGroup>
    <PackageReference Include="Microsoft.CodeAnalysis.CSharp" Version="4.12.0" PrivateAssets="all" />
    <PackageReference Include="PolySharp" Version="1.15.0" PrivateAssets="all" />
    <PackageReference Include="Endjin.RecommendedPractices.GitHub" Version="2.1.18" PrivateAssets="All" />
    <PackageReference Include="StyleCop.Analyzers" Version="1.2.0-beta.556" PrivateAssets="All" />
    <PackageReference Include="Roslynator.Analyzers" Version="4.13.1" PrivateAssets="All" />
  </ItemGroup>
  <!-- Generator's own source files -->
  <ItemGroup>
    <Compile Include="JsonataSourceGenerator.cs" />
    <Compile Include="SR.cs" />
    <Compile Include="Resources\Strings.Designer.cs" />
    <EmbeddedResource Include="Resources\Strings.resx" />
  </ItemGroup>
  <!-- Link the JSONata code generation engine -->
  <ItemGroup>
    <Compile Include="$(CorvusTextJsonJsonataCodeGenPath)JsonataCodeGenerator.cs" LinkBase="CodeGeneration" />
    <Compile Include="$(CorvusTextJsonJsonataCodeGenPath)CustomFunction.cs" LinkBase="CodeGeneration" />
    <Compile Include="$(CorvusTextJsonJsonataCodeGenPath)JfnParser.cs" LinkBase="CodeGeneration" />
  </ItemGroup>
  <!-- Link the JSONata parser, lexer, and AST (no external dependencies) -->
  <ItemGroup>
    <Compile Include="$(CommonPath)System\Text\Utf8ValueStringBuilder.cs" LinkBase="Common" />
    <Compile Include="$(CommonPath)System\Text\Utf8ValueStringBuilder.AppendHelpers.cs" LinkBase="Common" />
    <Compile Include="$(CorvusTextJsonJsonataPath)Parser.cs" LinkBase="Jsonata" />
    <Compile Include="$(CorvusTextJsonJsonataPath)Lexer.cs" LinkBase="Jsonata" />
    <Compile Include="$(CorvusTextJsonJsonataPath)Token.cs" LinkBase="Jsonata" />
    <Compile Include="$(CorvusTextJsonJsonataPath)TokenType.cs" LinkBase="Jsonata" />
    <Compile Include="$(CorvusTextJsonJsonataPath)Utf8Name.cs" LinkBase="Jsonata" />
    <Compile Include="$(CorvusTextJsonJsonataPath)JsonataException.cs" LinkBase="Jsonata" />
    <Compile Include="$(CorvusTextJsonJsonataPath)NodeBuilderExtensions.cs" LinkBase="Jsonata" />
    <Compile Include="$(CorvusTextJsonJsonataPath)Ast\ApplyNode.cs" LinkBase="Jsonata\Ast" />
    <Compile Include="$(CorvusTextJsonJsonataPath)Ast\ArrayConstructorNode.cs" LinkBase="Jsonata\Ast" />
    <Compile Include="$(CorvusTextJsonJsonataPath)Ast\BinaryNode.cs" LinkBase="Jsonata\Ast" />
    <Compile Include="$(CorvusTextJsonJsonataPath)Ast\BindNode.cs" LinkBase="Jsonata\Ast" />
    <Compile Include="$(CorvusTextJsonJsonataPath)Ast\BlockNode.cs" LinkBase="Jsonata\Ast" />
    <Compile Include="$(CorvusTextJsonJsonataPath)Ast\ConditionNode.cs" LinkBase="Jsonata\Ast" />
    <Compile Include="$(CorvusTextJsonJsonataPath)Ast\DescendantNode.cs" LinkBase="Jsonata\Ast" />
    <Compile Include="$(CorvusTextJsonJsonataPath)Ast\FilterNode.cs" LinkBase="Jsonata\Ast" />
    <Compile Include="$(CorvusTextJsonJsonataPath)Ast\FunctionCallNode.cs" LinkBase="Jsonata\Ast" />
    <Compile Include="$(CorvusTextJsonJsonataPath)Ast\GroupBy.cs" LinkBase="Jsonata\Ast" />
    <Compile Include="$(CorvusTextJsonJsonataPath)Ast\JsonataNode.cs" LinkBase="Jsonata\Ast" />
    <Compile Include="$(CorvusTextJsonJsonataPath)Ast\LambdaNode.cs" LinkBase="Jsonata\Ast" />
    <Compile Include="$(CorvusTextJsonJsonataPath)Ast\NameNode.cs" LinkBase="Jsonata\Ast" />
    <Compile Include="$(CorvusTextJsonJsonataPath)Ast\NodeType.cs" LinkBase="Jsonata\Ast" />
    <Compile Include="$(CorvusTextJsonJsonataPath)Ast\NumberNode.cs" LinkBase="Jsonata\Ast" />
    <Compile Include="$(CorvusTextJsonJsonataPath)Ast\ObjectConstructorNode.cs" LinkBase="Jsonata\Ast" />
    <Compile Include="$(CorvusTextJsonJsonataPath)Ast\ParentNode.cs" LinkBase="Jsonata\Ast" />
    <Compile Include="$(CorvusTextJsonJsonataPath)Ast\ParentSlot.cs" LinkBase="Jsonata\Ast" />
    <Compile Include="$(CorvusTextJsonJsonataPath)Ast\PartialNode.cs" LinkBase="Jsonata\Ast" />
    <Compile Include="$(CorvusTextJsonJsonataPath)Ast\PathNode.cs" LinkBase="Jsonata\Ast" />
    <Compile Include="$(CorvusTextJsonJsonataPath)Ast\PlaceholderNode.cs" LinkBase="Jsonata\Ast" />
    <Compile Include="$(CorvusTextJsonJsonataPath)Ast\RegexNode.cs" LinkBase="Jsonata\Ast" />
    <Compile Include="$(CorvusTextJsonJsonataPath)Ast\SortNode.cs" LinkBase="Jsonata\Ast" />
    <Compile Include="$(CorvusTextJsonJsonataPath)Ast\SortTerm.cs" LinkBase="Jsonata\Ast" />
    <Compile Include="$(CorvusTextJsonJsonataPath)Ast\StepAnnotations.cs" LinkBase="Jsonata\Ast" />
    <Compile Include="$(CorvusTextJsonJsonataPath)Ast\StringNode.cs" LinkBase="Jsonata\Ast" />
    <Compile Include="$(CorvusTextJsonJsonataPath)Ast\TransformNode.cs" LinkBase="Jsonata\Ast" />
    <Compile Include="$(CorvusTextJsonJsonataPath)Ast\UnaryNode.cs" LinkBase="Jsonata\Ast" />
    <Compile Include="$(CorvusTextJsonJsonataPath)Ast\ValueNode.cs" LinkBase="Jsonata\Ast" />
    <Compile Include="$(CorvusTextJsonJsonataPath)Ast\VariableNode.cs" LinkBase="Jsonata\Ast" />
    <Compile Include="$(CorvusTextJsonJsonataPath)Ast\WildcardNode.cs" LinkBase="Jsonata\Ast" />
  </ItemGroup>
  <!-- Package the generator DLL into analyzers/dotnet/cs -->
  <ItemGroup>
    <None Include="$(OutputPath)\$(AssemblyName).dll" Pack="true" PackagePath="analyzers/dotnet/cs" Visible="false" />
  </ItemGroup>
  <ItemGroup>
    <None Include="README.md" Pack="true" PackagePath="\" />
  </ItemGroup>
</Project>