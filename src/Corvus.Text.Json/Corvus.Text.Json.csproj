<Project Sdk="Microsoft.NET.Sdk">

  <Import Project="$(EndjinProjectPropsPath)" Condition="$(EndjinProjectPropsPath) != ''" />

  <PropertyGroup>
    <TargetFrameworks>net8.0;net9.0;net10.0;netstandard2.0</TargetFrameworks>
    <AllowUnsafeBlocks>true</AllowUnsafeBlocks>
    <!-- Use root .editorconfig, not the package's auto-generated one -->
    <EndjinDisableCreateEditorConfig>true</EndjinDisableCreateEditorConfig>
    <NoWarn>$(NoWarn);CS8969</NoWarn>
    <TreatWarningsAsErrors>true</TreatWarningsAsErrors>
    <!-- Only upgrade NuGetAudit warnings to errors for official builds. -->
    <WarningsNotAsErrors>$(WarningsNotAsErrors);NU1901;NU1902;NU1903;NU1904</WarningsNotAsErrors>
    <!-- Duplicate PackageReference from Endjin.RecommendedPractices targets -->
    <NoWarn>$(NoWarn);NU1504</NoWarn>
    <NoWarn Condition="$(TargetFrameworks.Contains('netstandard'))">$(NoWarn);CA1510;CA1511;CA1512;CA1513;CA1845;CA1846;CA1847</NoWarn>
    <!-- Warnings to always disable -->
    <NoWarn>$(NoWarn);CS8500;CS8969;IDE0065;IDE0290;IDE0079;IDE0130</NoWarn>
    <!-- XML doc warnings in linked Common/System.Private.CoreLib files we cannot modify -->
    <NoWarn>$(NoWarn);CS1570;CS1584;CS1658</NoWarn>
    <!-- XML doc completeness warnings - to be addressed in a later pass -->
    <NoWarn>$(NoWarn);CS1591;CS1573;CS1574;CS1572;CS0419;CS1571;CS1734;CS1712</NoWarn>
    <IncludeInternalObsoleteAttribute>true</IncludeInternalObsoleteAttribute>
    <GenerateDocumentationFile>true</GenerateDocumentationFile>
    <EmbedAllSources>true</EmbedAllSources>
    <IsPackable>true</IsPackable>
    <PackageLicenseExpression>Apache-2.0</PackageLicenseExpression>
    <PackageReadmeFile>README.md</PackageReadmeFile>
    <Description>High-performance JSON library for .NET that builds on the patterns of System.Text.Json with pooled-memory parsing, JSON Schema source generation (draft 4–2020-12), mutable document building, schema validation, extended numeric types, and NodaTime integration.</Description>
    <CommonPath>..\..\Common\src\</CommonPath>
    <LibrariesProjectRoot>..\..\</LibrariesProjectRoot>
    <CoreLibSharedDir>..\..\System.Private.CoreLib\src\</CoreLibSharedDir>
    <LangVersion>preview</LangVersion>
    <EnableDefaultCompileItems>false</EnableDefaultCompileItems>
    <EnableDefaultEmbeddedResourceItems>false</EnableDefaultEmbeddedResourceItems>
    <Nullable>enable</Nullable>
    <RootNamespace></RootNamespace>
  </PropertyGroup>

  <ItemGroup>
    <None Include="README.md" Pack="true" PackagePath="\" />
  </ItemGroup>

  <ItemGroup Label="Bundled Analyzers">
    <ProjectReference Include="..\Corvus.Text.Json.Analyzers\Corvus.Text.Json.Analyzers.csproj"
                      ReferenceOutputAssembly="false"
                      PrivateAssets="all" />
    <None Include="..\Corvus.Text.Json.Analyzers\bin\$(Configuration)\netstandard2.0\Corvus.Text.Json.Analyzers.dll"
          Pack="true"
          PackagePath="analyzers/dotnet/cs"
          Visible="false" />
  </ItemGroup>

  <ItemGroup>
    <InternalsVisibleTo Include="Corvus.Text.Json.Tests" />
  </ItemGroup>
  
  <ItemGroup>
    <Using Include="System" />
    <Using Include="System.Text" />
    <Using Include="SR = Resources.Strings" />
  </ItemGroup>

  <ItemGroup>
    <AssemblyAttribute Include="CLSCompliantAttribute">
      <_Parameter1>true</_Parameter1>
    </AssemblyAttribute>
  </ItemGroup>

  <!-- Adds System.Reflection.Emit.Lightweight to non .NETCoreApp builds. -->
  <ItemGroup Condition="'$(TargetFramework)' == 'netstandard2.0'">
    <PackageReference Include="System.Reflection.Emit.Lightweight" Version="4.7.0" />
  </ItemGroup>
  
  <!-- Adds Nullable annotation attributes to C# non .NETCoreApp builds. -->
  <ItemGroup Condition="'$(TargetFramework)' == 'netstandard2.0'">
    <Compile Include="$(CoreLibSharedDir)System\Diagnostics\CodeAnalysis\NullableAttributes.cs" Link="System\Diagnostics\CodeAnalysis\NullableAttributes.cs" />
  </ItemGroup>

  <!-- Adds polyfills on non-.NETCoreApp builds -->
  <ItemGroup Condition="'$(TargetFramework)' == 'netstandard2.0'">
    <Compile Include="$(CoreLibSharedDir)System\Runtime\CompilerServices\CallerArgumentExpressionAttribute.cs" />
    <Compile Include="$(LibrariesProjectRoot)\Common\src\System\ExceptionPolyfills.cs" Link="System\ExceptionPolyfills.cs" />
  </ItemGroup>

  <ItemGroup Condition="'$(TargetFramework)' == 'netstandard2.0'">
    <Compile Include="$(CoreLibSharedDir)System\Runtime\Versioning\PlatformAttributes.cs" Link="System\Runtime\Versioning\PlatformAttributes.cs" />
  </ItemGroup>

  <ItemGroup Condition="'$(TargetFramework)' == 'netstandard2.0'">
