<Project Sdk="Microsoft.NET.Sdk">
  <Import Project="$(EndjinProjectPropsPath)" Condition="$(EndjinProjectPropsPath) != ''" />
  <PropertyGroup>
    <TargetFrameworks>net9.0;net10.0;netstandard2.0;netstandard2.1</TargetFrameworks>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <LangVersion>preview</LangVersion>
    <AllowUnsafeBlocks>true</AllowUnsafeBlocks>
    <TreatWarningsAsErrors>true</TreatWarningsAsErrors>
    <WarningsNotAsErrors>$(WarningsNotAsErrors);NU1901;NU1902;NU1903;NU1904</WarningsNotAsErrors>
    <NoWarn>$(NoWarn);CS1591;NU1504;CS8500;CS8969;IDE0065;IDE0290;IDE0079;IDE0130;CS1572;CS1573;CS1574;CS1584;CS1658;CS3021</NoWarn>
    <NoWarn Condition="$(TargetFrameworks.Contains('netstandard'))">$(NoWarn);CA1510;CA1511;CA1512;CA1513;CA1845;CA1846;CA1847;nullable</NoWarn>
    <EndjinDisableCreateEditorConfig>true</EndjinDisableCreateEditorConfig>
    <IsPackable>true</IsPackable>
    <PackageLicenseExpression>Apache-2.0</PackageLicenseExpression>
    <Description>TOON (Token-Oriented Object Notation) conversion support using System.Text.Json only.</Description>
    <DefineConstants>$(DefineConstants);STJ;TOON</DefineConstants>
    <PackageReadmeFile>README.md</PackageReadmeFile>
  </PropertyGroup>
  <PropertyGroup>
    <CtjToonSourceDir>..\Corvus.Text.Json.Toon\Corvus\Text\Json\Toon\</CtjToonSourceDir>
    <CtjToonInternalDir>..\Corvus.Text.Json.Toon\Corvus\Text\Json\Toon\Internal\</CtjToonInternalDir>
    <CommonPath>..\..\Common\src\</CommonPath>
    <CoreLibSharedDir>..\..\System.Private.CoreLib\src\</CoreLibSharedDir>
    <EnableDefaultEmbeddedResourceItems>false</EnableDefaultEmbeddedResourceItems>
  </PropertyGroup>
  <ItemGroup>
    <Using Include="SR = Resources.Strings" />
    <Compile Include="..\Corvus.Text.Json.Toon\SR.cs" Link="SR.cs" />
    <EmbeddedResource Include="Resources\Strings.resx" Visible="true" IncludeDefaultValues="true" EmitFormatMethods="false" GenerateSource="true" OmitGetResourceString="true" />
  </ItemGroup>
  <ItemGroup>
    <Compile Include="$(CtjToonSourceDir)ToonDelimiter.cs" Link="Corvus\Toon\ToonDelimiter.cs" />
    <Compile Include="$(CtjToonSourceDir)ToonDocument.cs" Link="Corvus\Toon\ToonDocument.cs" />
    <Compile Include="$(CtjToonSourceDir)ToonException.cs" Link="Corvus\Toon\ToonException.cs" />
    <Compile Include="$(CtjToonSourceDir)ToonKeyFolding.cs" Link="Corvus\Toon\ToonKeyFolding.cs" />
    <Compile Include="$(CtjToonSourceDir)ToonPathExpansion.cs" Link="Corvus\Toon\ToonPathExpansion.cs" />
    <Compile Include="$(CtjToonSourceDir)ToonReaderOptions.cs" Link="Corvus\Toon\ToonReaderOptions.cs" />
    <Compile Include="$(CtjToonSourceDir)ToonWriterOptions.cs" Link="Corvus\Toon\ToonWriterOptions.cs" />
    <Compile Include="$(CtjToonSourceDir)Utf8ToonWriter.cs" Link="Corvus\Toon\Utf8ToonWriter.cs" />
  </ItemGroup>
  <ItemGroup>
    <Compile Include="$(CtjToonInternalDir)ArrayPoolBufferWriter.cs" Link="Corvus\Toon\Internal\ArrayPoolBufferWriter.cs" />
    <Compile Include="$(CtjToonInternalDir)JsonToToonConverter.cs" Link="Corvus\Toon\Internal\JsonToToonConverter.cs" />
    <Compile Include="$(CtjToonInternalDir)ToonToJsonConverter.cs" Link="Corvus\Toon\Internal\ToonToJsonConverter.cs" />
    <Compile Include="$(CtjToonInternalDir)ThrowHelper.cs" Link="Corvus\Toon\Internal\ThrowHelper.cs" />
  </ItemGroup>
  <ItemGroup>
    <Compile Include="..\Common\JsonConstants.cs" Link="Common\JsonConstants.cs" />
    <Compile Include="..\Common\Utf8KeyHashSet.cs" Link="Common\Utf8KeyHashSet.cs" />
    <Compile Include="..\Corvus.Text.Json\Corvus\Text\Json\Internal\Utf8Hash.cs" Link="Common\Utf8Hash.cs" />
    <Compile Include="$(CommonPath)System\Text\Utf8ValueStringBuilder.cs" Link="Common\Utf8ValueStringBuilder.cs" />
    <Compile Include="$(CommonPath)System\Text\Utf8ValueStringBuilder.AppendHelpers.cs" Link="Common\Utf8ValueStringBuilder.AppendHelpers.cs" />
    <Compile Include="$(CoreLibSharedDir)System\Collections\Generic\ValueListBuilder.cs" Link="Common\System\Collections\Generic\ValueListBuilder.cs" />
  </ItemGroup>
  <ItemGroup Condition="'$(TargetFramework)' == 'netstandard2.0'">
    <Compile Include="$(CoreLibSharedDir)System\Runtime\CompilerServices\IsExternalInit.cs" />
    <Compile Include="$(CoreLibSharedDir)System\Diagnostics\CodeAnalysis\NullableAttributes.cs" Link="System\Diagnostics\CodeAnalysis\NullableAttributes.cs" />
  </ItemGroup>
  <ItemGroup Condition="'$(TargetFramework)' == 'netstandard2.1'">
    <Compile Include="$(CoreLibSharedDir)System\Runtime\CompilerServices\IsExternalInit.cs" />
  </ItemGroup>
  <ItemGroup Condition="'$(TargetFramework)' == 'netstandard2.0' OR '$(TargetFramework)' == 'netstandard2.1'">
    <PackageReference Include="System.Memory" />
    <PackageReference Include="System.Buffers" />
    <PackageReference Include="System.Runtime.CompilerServices.Unsafe" />
  </ItemGroup>
  <ItemGroup Condition="!$([MSBuild]::IsTargetFrameworkCompatible('$(TargetFramework)', 'net10.0'))">
    <PackageReference Include="System.Text.Json" />
  </ItemGroup>
  <ItemGroup>
    <InternalsVisibleTo Include="Corvus.Toon.SystemTextJson.Tests" />
  </ItemGroup>
  <ItemGroup>
    <PackageReference Include="Endjin.RecommendedPractices.GitHub" PrivateAssets="All" />
    <PackageReference Include="Microsoft.CodeAnalysis.ResxSourceGenerator" PrivateAssets="all" />
    <PackageReference Include="StyleCop.Analyzers" PrivateAssets="All" />
    <PackageReference Include="Roslynator.Analyzers" PrivateAssets="All" />
  </ItemGroup>
  <ItemGroup>
    <None Include="README.md" Pack="true" PackagePath="\" />
  </ItemGroup>
</Project>