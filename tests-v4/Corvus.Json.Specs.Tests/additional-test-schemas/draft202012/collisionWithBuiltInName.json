    "tests": [
      {
        "description": "data: {\u0022system\u0022: \u0022foo\u0022, \u0022someOtherProp\u0022: \u0022bar\u0022 }",
        "data": {
          "system": "foo",
          "someOtherProp": "bar"
        },
        "valid": true
      },
      {
        "description": "data: {\u0022someOtherProp\u0022: \u0022bar\u0022  }",
        "data": {
          "someOtherProp": "bar"
        },
        "valid": false
      }
    ]
  }
