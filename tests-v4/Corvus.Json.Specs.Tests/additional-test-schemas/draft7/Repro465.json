[
  {
    "description": "Repro similar definition names",
    "schema": {
      "$schema": "http://json-schema.org/draft-07/schema#",
      "type": "object",
      "properties": {
        "id": {
          "$ref": "#/definitions/id_def"
        },
        "id2": {
          "$ref": "#/definitions/iddef"
        }
      },
      "definitions": {
        "id_def": {
          "type": "string",
          "maxLength": 70
        },
        "iddef": {
          "type": "string",
          "maxLength": 70
        }
      }
    },
    "tests": [
      {
        "description": "data: { \u0022id\u0022: \u0022foo\u0022, \u0022id2\u0022: \u0022bar\u0022 }",
        "data": {
          "id": "foo",
          "id2": "bar"
        },
        "valid": true
      }
    ]
  }
]