{
  "asyncapi": "3.0.0",
  "info": {
    "title": "Bindings Example",
    "version": "1.0.0"
  },
  "channels": {
    "orders": {
      "address": "shop.orders",
      "messages": {
        "OrderCreated": {
          "$ref": "#/components/messages/OrderCreated"
        }
      },
      "bindings": {
        "kafka": {
          "topic": "shop.orders",
          "partitions": 12,
          "replicas": 3,
          "topicConfiguration": {
            "cleanup.policy": ["compact"],
            "retention.ms": 604800000
          }
        }
      }
    },
    "notifications": {
      "address": "shop.notifications",
      "messages": {
        "Notification": {
          "payload": {
            "type": "object",
            "properties": {
              "message": { "type": "string" }
            }
          },
          "bindings": {
            "amqp": {
              "contentEncoding": "utf-8",
              "messageType": "notification.v1"
            }
          }
        }
      },
      "bindings": {
        "amqp": {
          "is": "routingKey",
          "exchange": {
            "name": "shop-exchange",
            "type": "topic",
            "durable": true,
            "autoDelete": false
          }
        }
      }
    }
  },
  "operations": {
    "processOrder": {
      "action": "receive",
      "channel": { "$ref": "#/channels/orders" },
      "messages": [
        { "$ref": "#/channels/orders/messages/OrderCreated" }
      ],
      "bindings": {
        "kafka": {
          "groupId": { "type": "string", "enum": ["order-processors"] },
          "clientId": { "type": "string", "enum": ["order-service"] }
        }
      }
    },
    "sendNotification": {
      "action": "send",
      "channel": { "$ref": "#/channels/notifications" },
      "messages": [
        { "$ref": "#/channels/notifications/messages/Notification" }
      ],
      "bindings": {
        "amqp": {
          "ack": true
        }
      }
    }
  },
  "components": {
    "messages": {
      "OrderCreated": {
        "payload": {
          "type": "object",
          "properties": {
            "orderId": { "type": "string" }
          }
        }
      }
    }
  }
}