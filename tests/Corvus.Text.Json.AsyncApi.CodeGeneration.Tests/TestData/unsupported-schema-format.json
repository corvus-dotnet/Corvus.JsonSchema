{
  "asyncapi": "3.0.0",
  "info": {
    "title": "Avro Schema Example",
    "version": "1.0.0"
  },
  "channels": {
    "events": {
      "address": "app.events",
      "messages": {
        "avroMessage": {
          "name": "avroMessage",
          "payload": {
            "schemaFormat": "application/vnd.apache.avro;version=1.9.0",
            "schema": {
              "type": "record",
              "name": "UserEvent",
              "fields": [
                { "name": "email", "type": "string" }
              ]
            }
          }
        }
      }
    }
  },
  "operations": {
    "sendAvro": {
      "action": "send",
      "channel": { "$ref": "#/channels/events" },
      "messages": [
        { "$ref": "#/channels/events/messages/avroMessage" }
      ]
    }
  }
}