{
  "asyncapi": "3.0.0",
  "info": { "title": "Notifications", "version": "1.0.0" },
  "defaultContentType": "application/json",
  "channels": {
    "notifications": {
      "address": "notifications",
      "messages": {
        "notification": { "$ref": "#/components/messages/notification" }
      }
    }
  },
  "operations": {
    "notify": {
      "action": "send",
      "channel": { "$ref": "#/channels/notifications" },
      "messages": [
        { "$ref": "#/channels/notifications/messages/notification" }
      ]
    }
  },
  "components": {
    "messages": {
      "notification": {
        "name": "notification",
        "title": "Notification",
        "contentType": "application/json",
        "payload": { "$ref": "#/components/schemas/notificationPayload" }
      }
    },
    "schemas": {
      "notificationPayload": {
        "type": "object",
        "properties": {
          "text": { "type": "string", "description": "The notification text." }
        }
      }
    }
  }
}
