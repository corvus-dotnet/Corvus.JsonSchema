{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "title": "An array of items",
    "type": "array",
    "items": {
        "type": "object",
        "required": ["id"],
        "properties": {
            "id": { "type": "integer", "format": "int32" },
            "label": { "type": "string" }
        }
    }
}
