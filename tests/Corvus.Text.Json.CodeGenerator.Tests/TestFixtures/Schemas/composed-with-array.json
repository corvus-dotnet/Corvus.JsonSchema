{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "title": "Composed type with array branch",
    "$defs": {
        "string-list": {
            "type": "array",
            "items": { "type": "string" }
        },
        "named-object": {
            "type": "object",
            "properties": {
                "name": { "type": "string" }
            }
        }
    },
    "type": "object",
    "properties": {
        "payload": {
            "allOf": [
                { "$ref": "#/$defs/string-list" },
                { "minItems": 1, "maxItems": 10 }
            ]
        },
        "mixed": {
            "allOf": [
                { "$ref": "#/$defs/named-object" },
                {
                    "type": "array",
                    "items": { "type": "integer" }
                }
            ]
        }
    }
}
