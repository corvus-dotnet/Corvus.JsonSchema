{
  "openapi": "3.0.3",
  "info": {
    "title": "Coverage Test API",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "https://{environment}.example.com/{version}",
      "variables": {
        "environment": {
          "default": "api",
          "enum": [
            "api",
            "staging",
            "sandbox"
          ]
        },
        "version": {
          "default": "v1"
        }
      }
    }
  ],
  "paths": {
    "/items": {
      "servers": [
        {
          "url": "https://items.example.com/v2"
        }
      ],
      "get": {
        "operationId": "listItems",
        "summary": "List items with various default parameter values",
        "parameters": [
          {
            "name": "active",
            "in": "query",
            "schema": {
              "type": "boolean",
              "default": true
            }
          },
          {
            "name": "category",
            "in": "query",
            "schema": {
              "type": "string",
              "default": "general"
            }
          },
          {
            "name": "page",
            "in": "query",
            "schema": {
              "type": "integer",
              "format": "int32",
              "default": 1
            }
          },
          {
            "name": "sort",
            "in": "query",
            "schema": {
              "type": "string",
              "default": null
            }
          },
          {
            "name": "verbose",
            "in": "query",
            "schema": {
              "type": "boolean",
              "default": false
            }
          }
        ],
        "responses": {
          "200": {
            "description": "JSON list of items",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Item"
                  }
                }
              }
            }
          },
          "default": {
            "description": "Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      },
      "post": {
        "operationId": "createItem",
        "summary": "Create a new item",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "name": {
                    "type": "string"
                  },
                  "tag": {
                    "type": "string"
                  }
                },
                "required": [
                  "name"
                ]
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Item created",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "id": {
                      "type": "string"
                    },
                    "name": {
                      "type": "string"
                    },
                    "tag": {
                      "type": "string"
                    }
                  },
                  "required": [
                    "id",
                    "name"
                  ]
                }
              }
            },
            "links": {
              "GetCreatedItem": {
                "operationId": "getItem",
                "parameters": {
                  "itemId": "$response.body#/id"
                },
                "description": "Retrieve the created item by its id."
              }
            }
          }
        }
      }
    },
    "/items/{itemId}": {
      "get": {
        "operationId": "getItem",
        "servers": [
          {
            "url": "https://detail.example.com"
          }
        ],
        "parameters": [
          {
            "name": "itemId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "An item",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Item"
                }
              },
              "text/plain": {
                "schema": {
                  "type": "string"
                }
              }
            },
            "headers": {
              "X-Rate-Limit": {
                "schema": {
                  "type": "integer",
                  "format": "int32"
                }
              },
              "X-Active": {
                "schema": {
                  "type": "boolean"
                }
              },
              "X-Tags": {
                "schema": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  }
                }
              },
              "X-Page-Sizes": {
                "schema": {
                  "type": "array",
                  "items": {
                    "type": "integer",
                    "format": "int32"
                  }
                }
              },
              "X-Flags": {
                "schema": {
                  "type": "array",
                  "items": {
                    "type": "boolean"
                  }
                }
              },
              "X-Request-Id": {
                "description": "Request correlation ID (no schema \u00e2\u20ac\u201d raw string)"
              }
            },
            "links": {
              "RefreshItem": {
                "operationId": "getItem",
                "parameters": {
                  "itemId": "$request.path.itemId"
                },
                "description": "Re-fetch the same item."
              }
            }
          }
        }
      }
    },
    "/items/{itemId}/form": {
      "post": {
        "operationId": "updateItemForm",
        "parameters": [
          {
            "name": "itemId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/x-www-form-urlencoded": {
              "schema": {
                "type": "object",
                "properties": {
                  "name": {
                    "type": "string"
                  },
                  "tags": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    }
                  },
                  "metadata": {
                    "type": "object",
                    "properties": {
                      "color": {
                        "type": "string"
                      },
                      "size": {
                        "type": "string"
                      }
                    }
                  }
                }
              },
              "encoding": {
                "tags": {
                  "style": "form",
                  "explode": true
                },
                "metadata": {
                  "style": "deepObject",
                  "allowReserved": true,
                  "contentType": "application/json"
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Updated item",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Item"
                }
              }
            }
          }
        }
      }
    },
    "/items/{itemId}/upload": {
      "post": {
        "operationId": "uploadItemData",
        "parameters": [
          {
            "name": "itemId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "multipart/form-data": {
              "schema": {
                "type": "object",
                "properties": {
                  "description": {
                    "type": "string"
                  },
                  "file": {
                    "type": "string",
                    "format": "binary"
                  }
                }
              },
              "encoding": {
                "file": {
                  "contentType": "application/octet-stream"
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Uploaded",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Item"
                }
              }
            }
          }
        }
      }
    },
    "/download": {
      "get": {
        "operationId": "downloadFile",
        "responses": {
          "200": {
            "description": "A file",
            "content": {
              "*/*": {
                "schema": {
                  "type": "string",
                  "format": "binary"
                }
              }
            }
          }
        }
      }
    },
    "/quirky/{qid}": {
      "get": {
        "operationId": "getQuirky",
        "parameters": [
          {
            "name": "qid",
            "in": "path",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "weirdLoc",
            "in": "custom",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "ok",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Item"
                }
              }
            }
          }
        }
      }
    },
    "/quirky/{sid}/styled": {
      "get": {
        "operationId": "getStyledQuirky",
        "parameters": [
          {
            "name": "sid",
            "in": "path",
            "required": true,
            "style": "form",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "badQueryStyle",
            "in": "query",
            "style": "simple",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "ok",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Item"
                }
              }
            }
          }
        }
      }
    },
    "/empty-servers": {
      "servers": [],
      "get": {
        "operationId": "getEmptyServers",
        "servers": [],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "ok": {
                      "type": "boolean"
                    }
                  }
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "Item": {
        "type": "object",
        "required": [
          "id",
          "name"
        ],
        "properties": {
          "id": {
            "type": "integer",
            "format": "int64"
          },
          "name": {
            "type": "string"
          },
          "active": {
            "type": "boolean"
          }
        }
      },
      "Error": {
        "type": "object",
        "required": [
          "code",
          "message"
        ],
        "properties": {
          "code": {
            "type": "integer",
            "format": "int32"
          },
          "message": {
            "type": "string"
          }
        }
      }
    }
  }
}