{
  "openapi": "3.1.0",
  "info": {
    "title": "Coverage Test API",
    "version": "1.0.0"
  },
  "servers": [
    {
      "url": "https://{environment}.example.com/{version}",
      "variables": {
        "environment": {
          "default": "api",
          "enum": [
            "api",
            "staging",
            "sandbox"
          ]
        },
        "version": {
          "default": "v1"
        }
      }
    }
  ],
  "paths": {
    "/items": {
      "servers": [
        {
          "url": "https://items.example.com/v2"
        }
      ],
      "get": {
        "operationId": "listItems",
        "summary": "List items with various default parameter values",
        "parameters": [
          {
            "name": "active",
            "in": "query",
            "schema": {
              "type": "boolean",
              "default": true
            }
          },
          {
            "name": "category",
            "in": "query",
            "schema": {
              "type": "string",
              "default": "general"
            }
          },
          {
            "name": "page",
            "in": "query",
            "schema": {
              "type": "integer",
              "format": "int32",
              "default": 1
            }
          },
          {
            "name": "sort",
            "in": "query",
            "schema": {
              "type": "string",
              "default": null
            }
          },
          {
            "name": "verbose",
            "in": "query",
            "schema": {
              "type": "boolean",
              "default": false
            }
          }
        ],
        "responses": {
          "200": {
            "description": "JSON list of items",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Item"
                  }
                }
              }
            }
          },
          "default": {
            "description": "Error",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            }
          }
        }
      },
      "post": {
        "operationId": "createItem",
        "summary": "Create a new item",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "name": {
                    "type": "string"
                  },
                  "tag": {
                    "type": "string"
                  },
                  "metadata": {
                    "type": "object",
                    "properties": {
                      "source": {
                        "type": "string"
                      }
                    }
                  }
                },
                "required": [
                  "name"
                ]
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Item created",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "id": {
                      "type": "string"
                    },
                    "name": {
                      "type": "string"
                    },
                    "tag": {
                      "type": "string"
                    }
                  },
                  "required": [
                    "id",
                    "name"
                  ]
                }
              }
            },
            "links": {
              "GetCreatedItem": {
                "operationId": "getItem",
                "parameters": {
                  "itemId": "$response.body#/id"
                },
                "description": "Retrieve the created item by its id."
              },
              "SearchByName": {
                "operationId": "searchItems",
                "parameters": {
                  "q": "$request.body#/metadata/source"
                },
                "description": "Search for items by the created name"
              }
            }
          }
        },
        "parameters": [
          {
            "name": "X-Correlation-Id",
            "in": "header",
            "required": false,
            "schema": {
              "type": "string"
            }
          }
        ]
      }
    },
    "/items/{itemId}": {
      "get": {
        "operationId": "getItem",
        "servers": [
          {
            "url": "https://detail.example.com"
          }
        ],
        "parameters": [
          {
            "name": "itemId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "An item",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Item"
                }
              },
              "text/plain": {
                "schema": {
                  "type": "string"
                }
              }
            },
            "headers": {
              "X-Rate-Limit": {
                "schema": {
                  "type": "integer",
                  "format": "int32"
                }
              },
              "X-Active": {
                "schema": {
                  "type": "boolean"
                }
              },
              "X-Request-Id": {
                "description": "Request correlation ID (no schema â€” raw string)"
              },
              "X-Tags": {
                "schema": {
                  "type": "array",
                  "items": {
                    "type": "string"
                  }
                }
              },
              "X-Page-Sizes": {
                "schema": {
                  "type": "array",
                  "items": {
                    "type": "integer",
                    "format": "int32"
                  }
                }
              },
              "X-Flags": {
                "schema": {
                  "type": "array",
                  "items": {
                    "type": "boolean"
                  }
                }
              }
            },
            "links": {
              "RefreshItem": {
                "operationId": "getItem",
                "parameters": {
                  "itemId": "$request.path.itemId"
                },
                "description": "Re-fetch the same item."
              },
              "NonExistentLink": {
                "operationId": "doesNotExist",
                "parameters": {
                  "id": "$response.body#/id"
                }
              }
            }
          }
        }
      }
    },
    "/items/{itemId}/form": {
      "post": {
        "operationId": "updateItemForm",
        "parameters": [
          {
            "name": "itemId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/x-www-form-urlencoded": {
              "schema": {
                "type": "object",
                "properties": {
                  "name": {
                    "type": "string"
                  },
                  "tags": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    }
                  },
                  "metadata": {
                    "type": "object",
                    "properties": {
                      "color": {
                        "type": "string"
                      },
                      "size": {
                        "type": "string"
                      }
                    }
                  }
                }
              },
              "encoding": {
                "tags": {
                  "style": "form",
                  "explode": true
                },
                "metadata": {
                  "style": "deepObject",
                  "allowReserved": true,
                  "contentType": "application/json"
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Updated item",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Item"
                }
              }
            }
          }
        }
      }
    },
    "/items/{itemId}/upload": {
      "post": {
        "operationId": "uploadItemData",
        "parameters": [
          {
            "name": "itemId",
            "in": "path",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "multipart/form-data": {
              "schema": {
                "type": "object",
                "properties": {
                  "description": {
                    "type": "string"
                  },
                  "file": {
                    "type": "string",
                    "format": "binary"
                  }
                }
              },
              "encoding": {
                "file": {
                  "contentType": "application/octet-stream"
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Uploaded",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Item"
                }
              }
            }
          }
        }
      }
    },
    "/download": {
      "get": {
        "operationId": "downloadFile",
        "responses": {
          "200": {
            "description": "A file",
            "content": {
              "*/*": {
                "schema": {
                  "type": "string",
                  "format": "binary"
                }
              }
            }
          }
        }
      }
    },
    "/quirky/{qid}": {
      "get": {
        "operationId": "getQuirky",
        "parameters": [
          {
            "name": "qid",
            "in": "path",
            "required": false,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "weirdLoc",
            "in": "custom",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "ok",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Item"
                }
              }
            }
          }
        }
      }
    },
    "/quirky/{sid}/styled": {
      "get": {
        "operationId": "getStyledQuirky",
        "parameters": [
          {
            "name": "sid",
            "in": "path",
            "required": true,
            "style": "form",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "badQueryStyle",
            "in": "query",
            "style": "simple",
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "ok",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Item"
                }
              }
            }
          }
        }
      }
    },
    "/export": {
      "get": {
        "operationId": "exportData",
        "responses": {
          "200": {
            "description": "Export data as binary",
            "content": {
              "application/*": {
                "schema": {
                  "type": "string",
                  "format": "binary"
                }
              }
            }
          },
          "default": {
            "description": "Error (JSON or binary)",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              },
              "application/octet-stream": {
                "schema": {
                  "type": "string",
                  "format": "binary"
                }
              }
            }
          }
        }
      }
    },
    "/empty-servers": {
      "servers": [],
      "get": {
        "operationId": "getEmptyServers",
        "servers": [],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "ok": {
                      "type": "boolean"
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "/search": {
      "get": {
        "operationId": "searchItems",
        "tags": [
          "Items",
          "Search"
        ],
        "parameters": [
          {
            "name": "q",
            "in": "query",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "tags",
            "in": "query",
            "style": "pipeDelimited",
            "explode": false,
            "schema": {
              "type": "array",
              "items": {
                "type": "string"
              }
            }
          },
          {
            "name": "coords",
            "in": "query",
            "style": "spaceDelimited",
            "explode": false,
            "schema": {
              "type": "array",
              "items": {
                "type": "number"
              }
            }
          },
          {
            "name": "filter",
            "in": "query",
            "style": "deepObject",
            "explode": true,
            "schema": {
              "type": "object",
              "properties": {
                "min": {
                  "type": "integer"
                },
                "max": {
                  "type": "integer"
                }
              }
            }
          },
          {
            "name": "session",
            "in": "cookie",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "prefs",
            "in": "cookie",
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "X-Correlation-Id",
            "in": "header",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Search results",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Item"
                  }
                }
              }
            }
          }
        }
      },
      "post": {
        "operationId": "searchItemsAdvanced",
        "tags": [
          "Search"
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "query": {
                    "type": "string"
                  },
                  "limit": {
                    "type": "integer"
                  }
                }
              }
            }
          }
        },
        "parameters": [
          {
            "name": "session",
            "in": "cookie",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Search results",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "results": {
                      "type": "array",
                      "items": {
                        "$ref": "#/components/schemas/Item"
                      }
                    },
                    "id": {
                      "type": "string"
                    }
                  }
                }
              }
            },
            "links": {
              "GetFirstResult": {
                "$ref": "#/components/links/GetItemById"
              }
            }
          }
        }
      }
    },
    "/health": {
      "$ref": "#/components/pathItems/HealthCheck"
    },
    "/upload": {
      "post": {
        "operationId": "uploadFile",
        "tags": [
          "Items"
        ],
        "summary": "Upload a file",
        "requestBody": {
          "required": true,
          "content": {
            "application/octet-stream": {
              "schema": {
                "type": "string",
                "format": "binary"
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "File uploaded",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Item"
                }
              }
            },
            "links": {
              "GetUploadedItem": {
                "operationId": "getItem",
                "parameters": {
                  "itemId": "$response.body#/id"
                }
              },
              "ReUpload": {
                "operationId": "uploadFile",
                "parameters": {
                  "name": "$request.header.X-File-Name"
                }
              }
            }
          }
        },
        "parameters": [
          {
            "name": "X-File-Name",
            "in": "header",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ]
      }
    },
    "/feedback": {
      "post": {
        "operationId": "submitFeedback",
        "tags": [
          "Items"
        ],
        "summary": "Submit feedback",
        "requestBody": {
          "required": true,
          "content": {
            "application/x-www-form-urlencoded": {
              "schema": {
                "type": "object",
                "properties": {
                  "rating": {
                    "type": "integer"
                  },
                  "comment": {
                    "type": "string"
                  }
                },
                "required": [
                  "rating"
                ]
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Feedback submitted",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Item"
                }
              }
            },
            "links": {
              "UpdateFeedback": {
                "operationId": "getItem",
                "parameters": {
                  "itemId": "$request.body#/rating"
                }
              }
            }
          }
        },
        "parameters": [
          {
            "name": "source",
            "in": "query",
            "required": false,
            "schema": {
              "type": "string"
            }
          }
        ]
      }
    },
    "/attachments": {
      "post": {
        "operationId": "uploadAttachment",
        "tags": [
          "Items"
        ],
        "summary": "Upload attachment",
        "requestBody": {
          "required": true,
          "content": {
            "multipart/form-data": {
              "schema": {
                "type": "object",
                "properties": {
                  "file": {
                    "type": "string",
                    "format": "binary"
                  },
                  "description": {
                    "type": "string"
                  }
                },
                "required": [
                  "file"
                ]
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Attachment uploaded",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Item"
                }
              }
            },
            "links": {
              "UpdateDescription": {
                "operationId": "getItem",
                "parameters": {
                  "itemId": "$request.body#/description"
                }
              }
            }
          }
        },
        "parameters": [
          {
            "name": "X-Upload-Token",
            "in": "header",
            "required": true,
            "schema": {
              "type": "string"
            }
          }
        ]
      }
    },
    "/feedback-encoded": {
      "post": {
        "operationId": "submitFeedbackEncoded",
        "tags": [
          "Items"
        ],
        "summary": "Submit feedback with encoding",
        "requestBody": {
          "required": true,
          "content": {
            "application/x-www-form-urlencoded": {
              "schema": {
                "type": "object",
                "properties": {
                  "tags": {
                    "type": "array",
                    "items": {
                      "type": "string"
                    }
                  },
                  "comment": {
                    "type": "string"
                  }
                },
                "required": [
                  "tags"
                ]
              },
              "encoding": {
                "tags": {
                  "style": "pipeDelimited",
                  "explode": false
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Feedback submitted",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Item"
                }
              }
            },
            "links": {
              "RefreshFeedback": {
                "operationId": "getItem",
                "parameters": {
                  "itemId": "$request.body#/comment"
                }
              }
            }
          }
        },
        "parameters": [
          {
            "name": "X-Session-Id",
            "in": "header",
            "required": false,
            "schema": {
              "type": "string"
            }
          }
        ]
      }
    },
    "/attachments-encoded": {
      "post": {
        "operationId": "uploadAttachmentEncoded",
        "tags": [
          "Items"
        ],
        "summary": "Upload attachment with encoding",
        "requestBody": {
          "required": true,
          "content": {
            "multipart/form-data": {
              "schema": {
                "type": "object",
                "properties": {
                  "file": {
                    "type": "string",
                    "format": "binary"
                  },
                  "metadata": {
                    "type": "object",
                    "properties": {
                      "name": {
                        "type": "string"
                      }
                    }
                  }
                },
                "required": [
                  "file"
                ]
              },
              "encoding": {
                "metadata": {
                  "contentType": "application/json"
                }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Attachment uploaded",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Item"
                }
              }
            },
            "links": {
              "ReUploadEncoded": {
                "operationId": "getItem",
                "parameters": {
                  "itemId": "$request.body#/metadata"
                }
              }
            }
          }
        },
        "parameters": [
          {
            "name": "X-Batch-Id",
            "in": "header",
            "required": false,
            "schema": {
              "type": "string"
            }
          }
        ]
      }
    }
  },
  "components": {
    "schemas": {
      "Item": {
        "type": "object",
        "required": [
          "id",
          "name"
        ],
        "properties": {
          "id": {
            "type": "integer",
            "format": "int64"
          },
          "name": {
            "type": "string"
          },
          "active": {
            "type": "boolean"
          }
        }
      },
      "Error": {
        "type": "object",
        "required": [
          "code",
          "message"
        ],
        "properties": {
          "code": {
            "type": "integer",
            "format": "int32"
          },
          "message": {
            "type": "string"
          }
        }
      }
    },
    "pathItems": {
      "HealthCheck": {
        "get": {
          "operationId": "healthCheck",
          "responses": {
            "200": {
              "description": "Healthy",
              "content": {
                "application/json": {
                  "schema": {
                    "type": "object",
                    "properties": {
                      "status": {
                        "type": "string"
                      }
                    }
                  }
                }
              }
            }
          }
        }
      }
    },
    "links": {
      "GetItemById": {
        "operationId": "getItem",
        "parameters": {
          "itemId": "$response.body#/id"
        },
        "description": "Fetch the item by its ID"
      }
    }
  }
}
