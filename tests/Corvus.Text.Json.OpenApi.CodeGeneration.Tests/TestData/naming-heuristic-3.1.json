              }
            }
          },
          "default": {
            "description": "Default error",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": { "itemsDefault": { "type": "string" } }
                }
              }
            }
          }
        }
      },
      "post": {
        "operationId": "createItem",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": { "postBody": { "type": "string" } }
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Created",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
