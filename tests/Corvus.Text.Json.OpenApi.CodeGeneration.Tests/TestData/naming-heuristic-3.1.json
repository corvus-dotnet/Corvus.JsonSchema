          "204": {
            "description": "No content",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": { "noContentInfo": { "type": "string" } }
                }
              }
            }
          },
          "418": {
            "description": "Unknown status code",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": { "teapot": { "type": "boolean" } }
                }
              }
            }
          }
        }
      }
    },
    "/data~items": {
      "get": {
        "operationId": "getTildeItems",
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": { "tildeData": { "type": "string" } }
