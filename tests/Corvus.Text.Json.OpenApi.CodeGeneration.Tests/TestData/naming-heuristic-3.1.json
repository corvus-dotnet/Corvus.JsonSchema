    "/items/{itemId}": {
      "get": {
        "operationId": "getItem",
        "parameters": [
          {
            "name": "itemId",
            "in": "path",
            "required": true,
            "schema": { "type": "string", "pattern": "^[a-z]+$" }
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": { "itemDetail": { "type": "string" } }
                }
              }
            }
          }
        }
      }
    },
    "/items/{itemId}/details": {
      "get": {
        "operationId": "getItemDetails",
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": { "detailInfo": { "type": "string" } }
                }
              }
            }
          }
        }
      }
    },
    "/items/{itemId}/sub-items/{subId}": {
      "get": {
        "operationId": "getSubItem",
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": { "subItem": { "type": "string" } }
