{
  "openapi": "3.1.0",
  "info": {
    "title": "URI Canonicalization Tests",
    "version": "1.0.0"
  },
  "paths": {
    "/items/{itemId}": {
      "get": {
        "operationId": "getItem",
        "summary": "Get item by string ID with mixed param types",
        "parameters": [
          {
            "name": "itemId",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          },
          {
            "name": "filter",
            "in": "query",
            "schema": { "type": "string" }
          },
          {
            "name": "limit",
            "in": "query",
            "schema": { "type": "integer", "format": "int32" }
          },
          {
            "name": "verbose",
            "in": "query",
            "schema": { "type": "boolean" }
          },
          {
            "name": "X-Request-Id",
            "in": "header",
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": { "type": "object" }
              }
            }
          }
        }
      }
    },
    "/items/{itemId}/tags/{tagName}": {
      "get": {
        "operationId": "getItemTag",
        "summary": "Two path params: int64 + string",
        "parameters": [
          {
            "name": "itemId",
            "in": "path",
            "required": true,
            "schema": { "type": "integer", "format": "int64" }
          },
          {
            "name": "tagName",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          },
          {
            "name": "score",
            "in": "query",
            "schema": { "type": "number", "format": "double" }
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": { "type": "object" }
              }
            }
          }
        }
      }
    },
    "/search": {
      "get": {
        "operationId": "search",
        "summary": "Required + optional query params",
        "parameters": [
          {
            "name": "q",
            "in": "query",
            "required": true,
            "schema": { "type": "string" }
          },
          {
            "name": "page",
            "in": "query",
            "schema": { "type": "integer", "format": "int32" }
          },
          {
            "name": "rating",
            "in": "query",
            "schema": { "type": "number", "format": "float" }
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": { "type": "object" }
              }
            }
          }
        }
      }
    }
  }
}
