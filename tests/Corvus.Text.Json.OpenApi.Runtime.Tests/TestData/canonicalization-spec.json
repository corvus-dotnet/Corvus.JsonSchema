{
  "openapi": "3.1.0",
  "info": {
    "title": "Runtime Tests",
    "version": "1.0.0"
  },
  "servers": [
    { "url": "https://api.example.com/v1" }
  ],
  "paths": {
    "/items/{itemId}": {
      "get": {
        "operationId": "getItem",
        "summary": "Get item by string ID with mixed param types",
        "tags": ["items"],
        "parameters": [
          {
            "name": "itemId",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          },
          {
            "name": "filter",
            "in": "query",
            "schema": { "type": "string" }
          },
          {
            "name": "limit",
            "in": "query",
            "schema": { "type": "integer", "format": "int32" }
          },
          {
            "name": "verbose",
            "in": "query",
            "schema": { "type": "boolean" }
          },
          {
            "name": "X-Request-Id",
            "in": "header",
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "id": { "type": "string" },
                    "name": { "type": "string" }
                  },
                  "required": ["id", "name"]
                }
              }
            }
          },
          "404": {
            "description": "Not found",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "code": { "type": "integer", "format": "int32" },
                    "message": { "type": "string" }
                  },
                  "required": ["code", "message"]
                }
              }
            }
          },
          "default": {
            "description": "Unexpected error",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "error": { "type": "string" }
                  },
                  "required": ["error"]
                }
              }
            }
          }
        }
      },
      "delete": {
        "operationId": "deleteItem",
        "summary": "Delete an item (204 no content)",
        "tags": ["items"],
        "parameters": [
          {
            "name": "itemId",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "204": {
            "description": "Deleted"
          },
          "404": {
            "description": "Not found",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "code": { "type": "integer", "format": "int32" },
                    "message": { "type": "string" }
                  },
                  "required": ["code", "message"]
                }
              }
            }
          }
        }
      }
    },
    "/items/{itemId}/tags/{tagName}": {
      "get": {
        "operationId": "getItemTag",
        "summary": "Two path params: int64 + string, with trailing literal path",
        "tags": ["items"],
        "parameters": [
          {
            "name": "itemId",
            "in": "path",
            "required": true,
            "schema": { "type": "integer", "format": "int64" }
          },
          {
            "name": "tagName",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          },
          {
            "name": "score",
            "in": "query",
            "schema": { "type": "number", "format": "double" }
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "headers": {
              "X-Total-Count": {
                "description": "Total number of items available",
                "schema": { "type": "integer", "format": "int32" }
              },
              "X-Request-Id": {
                "description": "Request correlation ID",
                "schema": { "type": "string" }
              },
              "X-Tags": {
                "description": "Array of tag names",
                "schema": {
                  "type": "array",
                  "items": { "type": "string" }
                }
              },
              "X-Metadata": {
                "description": "Object with string properties",
                "schema": {
                  "type": "object",
                  "properties": {
                    "region": { "type": "string" },
                    "version": { "type": "string" }
                  }
                }
              }
            },
            "content": {
              "application/json": {
                "schema": { "type": "object" }
              }
            }
          }
        }
      }
    },
    "/items/{itemId}/details": {
      "get": {
        "operationId": "getItemDetails",
        "summary": "Path with trailing literal after param",
        "tags": ["items"],
        "parameters": [
          {
            "name": "itemId",
            "in": "path",
            "required": true,
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": { "type": "object" }
              }
            }
          }
        }
      }
    },
    "/search": {
      "get": {
        "operationId": "search",
        "summary": "Required + optional query params",
        "tags": ["search"],
        "parameters": [
          {
            "name": "q",
            "in": "query",
            "required": true,
            "schema": { "type": "string" }
          },
          {
            "name": "page",
            "in": "query",
            "schema": { "type": "integer", "format": "int32" }
          },
          {
            "name": "rating",
            "in": "query",
            "schema": { "type": "number", "format": "float" }
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": { "type": "object" }
              }
            }
          }
        }
      }
    },
    "/flags/{active}": {
      "get": {
        "operationId": "getByFlag",
        "summary": "Boolean path param",
        "tags": ["flags"],
        "parameters": [
          {
            "name": "active",
            "in": "path",
            "required": true,
            "schema": { "type": "boolean" }
          },
          {
            "name": "X-Trace-Id",
            "in": "header",
            "required": true,
            "schema": { "type": "string" }
          },
          {
            "name": "X-Request-Count",
            "in": "header",
            "required": true,
            "schema": { "type": "integer", "format": "int32" }
          },
          {
            "name": "X-Debug",
            "in": "header",
            "schema": { "type": "boolean" }
          },
          {
            "name": "X-Score",
            "in": "header",
            "schema": { "type": "number", "format": "double" }
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": { "type": "object" }
              }
            }
          }
        }
      }
    },
    "/pages/{pageNum}": {
      "get": {
        "operationId": "getPage",
        "summary": "Int32 path param with unbounded number query",
        "tags": ["pages"],
        "parameters": [
          {
            "name": "pageNum",
            "in": "path",
            "required": true,
            "schema": { "type": "integer", "format": "int32" }
          },
          {
            "name": "offset",
            "in": "query",
            "schema": { "type": "integer" }
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": { "type": "object" }
              }
            }
          }
        }
      }
    },
    "/items": {
      "post": {
        "operationId": "createItem",
        "summary": "Create an item with request body",
        "tags": ["items"],
        "requestBody": {
          "description": "The item to create",
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "name": { "type": "string" },
                  "price": { "type": "number", "format": "double" }
                },
                "required": ["name"]
              }
            }
          }
        },
        "responses": {
          "201": {
            "description": "Created",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "id": { "type": "string" },
                    "name": { "type": "string" }
                  },
                  "required": ["id", "name"]
                }
              }
            }
          },
          "422": {
            "description": "Validation error",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "errors": { "type": "array", "items": { "type": "string" } }
                  },
                  "required": ["errors"]
                }
              }
            }
          }
        }
      },
      "put": {
        "operationId": "updateItem",
        "summary": "Update an item",
        "tags": ["items"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "id": { "type": "string" },
                  "name": { "type": "string" }
                },
                "required": ["id", "name"]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Updated",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "id": { "type": "string" },
                    "name": { "type": "string" }
                  },
                  "required": ["id", "name"]
                }
              }
            }
          }
        }
      }
    },
    "/session/profile": {
      "get": {
        "operationId": "getSessionProfile",
        "summary": "Cookie params: session, theme (optional), debug flag (optional)",
        "tags": ["session"],
        "parameters": [
          {
            "name": "session_id",
            "in": "cookie",
            "required": true,
            "schema": { "type": "string" }
          },
          {
            "name": "theme",
            "in": "cookie",
            "schema": { "type": "string" }
          },
          {
            "name": "debug",
            "in": "cookie",
            "schema": { "type": "boolean" }
          },
          {
            "name": "max_age",
            "in": "cookie",
            "schema": { "type": "integer", "format": "int32" }
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": { "type": "object" }
              }
            }
          }
        }
      }
    },
    "/orders/{orderId}": {
      "parameters": [
        {
          "name": "orderId",
          "in": "path",
          "required": true,
          "schema": { "type": "string", "format": "uuid" }
        },
        {
          "name": "X-Trace-Id",
          "in": "header",
          "schema": { "type": "string" }
        }
      ],
      "get": {
        "operationId": "getOrder",
        "summary": "Get order — inherits path-level orderId and X-Trace-Id",
        "tags": ["orders"],
        "parameters": [
          {
            "name": "fields",
            "in": "query",
            "schema": { "type": "string" }
          }
        ],
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "orderId": { "type": "string", "format": "uuid" },
                    "status": { "type": "string" },
                    "total": { "type": "number" }
                  },
                  "required": ["orderId", "status", "total"]
                }
              }
            }
          }
        }
      },
      "put": {
        "operationId": "updateOrder",
        "summary": "Update order — inherits path-level params, overrides X-Trace-Id",
        "tags": ["orders"],
        "parameters": [
          {
            "name": "X-Trace-Id",
            "in": "header",
            "required": true,
            "schema": { "type": "string", "format": "uuid" }
          }
        ],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "properties": {
                  "status": { "type": "string" },
                  "total": { "type": "number" }
                },
                "required": ["status"]
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "OK",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "orderId": { "type": "string", "format": "uuid" },
                    "status": { "type": "string" },
                    "total": { "type": "number" }
                  },
                  "required": ["orderId", "status", "total"]
                }
              }
            }
          }
        }
      }
    }
  }
}
