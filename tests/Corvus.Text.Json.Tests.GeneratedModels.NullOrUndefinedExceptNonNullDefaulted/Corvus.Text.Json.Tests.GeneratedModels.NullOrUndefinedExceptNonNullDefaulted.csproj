<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFrameworks>netstandard2.0;netstandard2.1;net9.0;net10.0</TargetFrameworks>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <LangVersion>Preview</LangVersion>
    <NoWarn>$(NoWarn);CS8500;CS8969;CS8618;IDE0065;IDE0290;IDE0079;IDE0130;IDE1006;IDE0130</NoWarn>
    <EmitCompilerGeneratedFiles>true</EmitCompilerGeneratedFiles>
    <CorvusTextJsonOptionalAsNullable>NullOrUndefinedExceptNonNullDefaulted</CorvusTextJsonOptionalAsNullable>
    <IsPackable>false</IsPackable>
  </PropertyGroup>

  <ItemGroup>
    <CompilerVisibleProperty Include="CorvusTextJsonOptionalAsNullable" />
  </ItemGroup>

  <ItemGroup>
    <AdditionalFiles Include="object-with-default-properties-2020-12.json" />
    <AdditionalFiles Include="object-with-default-array-2020-12.json" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\..\src\Corvus.Text.Json.SourceGenerator\Corvus.Text.Json.SourceGenerator.csproj" PrivateAssets="all" ReferenceOutputAssembly="false" OutputItemType="Analyzer" />
    <ProjectReference Include="..\..\src\Corvus.Text.Json\Corvus.Text.Json.csproj" />
  </ItemGroup>

</Project>
