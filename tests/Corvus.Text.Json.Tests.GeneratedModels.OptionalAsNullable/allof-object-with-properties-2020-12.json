{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "AllOfObjectWithProperties",
  "description": "An inline object composed via allOf with local additional properties.",
  "allOf": [
    {
      "type": "object",
      "required": ["name"],
      "properties": {
        "name": { "type": "string" },
        "age": { "type": "integer", "format": "int32" }
      }
    }
  ],
  "properties": {
    "email": { "type": "string" }
  }
}
