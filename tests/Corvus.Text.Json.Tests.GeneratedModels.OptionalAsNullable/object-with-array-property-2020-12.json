{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "type": "object",
    "required": ["tags"],
    "properties": {
        "tags": {
            "type": "array",
            "items": { "type": "string" }
        },
        "scores": {
            "type": "array",
            "items": { "type": "number", "format": "double" }
        }
    }
}
