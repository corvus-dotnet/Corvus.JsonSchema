<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFrameworks>netstandard2.0;netstandard2.1;net9.0;net10.0</TargetFrameworks>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <LangVersion>Preview</LangVersion>
    <NoWarn>$(NoWarn);CS8500;CS8969;CS8618;IDE0065;IDE0290;IDE0079;IDE0130;IDE1006;IDE0130</NoWarn>
    <EmitCompilerGeneratedFiles>true</EmitCompilerGeneratedFiles>
    <CorvusJsonSchemaOptionalAsNullable>NullOrUndefinedExceptNonNullDefaulted</CorvusJsonSchemaOptionalAsNullable>
    <IsPackable>false</IsPackable>
  </PropertyGroup>

  <ItemGroup>
    <CompilerVisibleProperty Include="CorvusJsonSchemaOptionalAsNullable" />
  </ItemGroup>

  <ItemGroup>
    <AdditionalFiles Include="object-with-default-properties-2020-12.json" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="..\..\src-v4\Corvus.Json.ExtendedTypes\Corvus.Json.ExtendedTypes.csproj" />
    <ProjectReference Include="..\..\src-v4\Corvus.Json.SourceGenerator\Corvus.Json.SourceGenerator.csproj" OutputItemType="Analyzer" ReferenceOutputAssembly="false" SetTargetFramework="TargetFramework=netstandard2.0" />
  </ItemGroup>

</Project>
