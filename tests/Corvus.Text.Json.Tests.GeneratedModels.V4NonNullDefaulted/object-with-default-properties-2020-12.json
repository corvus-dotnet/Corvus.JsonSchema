{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "type": "object",
    "required": ["name"],
    "properties": {
        "name": { "type": "string" },
        "status": { "type": "string", "default": "active" },
        "label": { "type": "string" },
        "nickname": { "type": ["string", "null"], "default": null }
    }
}
