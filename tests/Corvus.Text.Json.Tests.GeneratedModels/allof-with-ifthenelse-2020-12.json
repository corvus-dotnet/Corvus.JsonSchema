{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "AllOfWithIfThenElse",
  "description": "Merges base properties via allOf and narrows via if/then/else.",
  "allOf": [
    {
      "type": "object",
      "required": ["type"],
      "properties": {
        "type": { "type": "string" }
      }
    }
  ],
  "if": {
    "type": "object",
    "required": ["type"],
    "properties": {
      "type": { "const": "premium" }
    }
  },
  "then": {
    "type": "object",
    "properties": {
      "discount": { "type": "number", "format": "double" }
    },
    "required": ["discount"]
  },
  "else": {
    "type": "object",
    "properties": {
      "message": { "type": "string" }
    }
  }
}
