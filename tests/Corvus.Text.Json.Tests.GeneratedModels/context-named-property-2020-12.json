{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "title": "ContextNamedProperty",
    "type": "object",
    "required": ["nested", "context"],
    "properties": {
        "nested": {
            "title": "NestedValue",
            "type": "object",
            "required": ["value"],
            "properties": {
                "value": { "type": "string" }
            }
        },
        "context": { "type": "string" }
    }
}
