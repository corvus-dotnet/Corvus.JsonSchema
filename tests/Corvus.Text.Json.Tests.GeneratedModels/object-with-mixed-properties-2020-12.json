{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "type": "object",
    "required": ["name", "age"],
    "properties": {
        "name": { "type": "string" },
        "age": { "type": "number", "format": "int32" },
        "email": { "type": "string", "format": "email" },
        "isActive": { "type": "boolean" }
    }
}
