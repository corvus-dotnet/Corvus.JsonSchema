{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "title": "An object with pattern properties",
    "type": "object",
    "properties": {
        "name": { "type": "string" }
    },
    "required": ["name"],
    "patternProperties": {
        "^S_": { "type": "string" },
        "^I_": { "type": "integer", "format": "int32" }
    },
    "additionalProperties": false
}
