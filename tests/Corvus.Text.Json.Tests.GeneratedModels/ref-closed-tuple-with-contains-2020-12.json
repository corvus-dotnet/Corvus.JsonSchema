{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "RefClosedTupleWithContains",
  "description": "A $ref-based closed tuple via allOf with a contains constraint.",
  "$defs": {
    "baseTuple": {
      "type": "array",
      "prefixItems": [
        { "type": "string" },
        { "type": "integer", "format": "int32" }
      ],
      "items": false
    }
  },
  "allOf": [
    { "$ref": "#/$defs/baseTuple" }
  ],
  "contains": { "type": "integer" }
}
