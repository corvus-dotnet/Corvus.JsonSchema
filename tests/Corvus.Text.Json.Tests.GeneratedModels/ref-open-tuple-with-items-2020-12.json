{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "RefOpenTupleWithItems",
  "description": "A $ref-based open tuple via allOf with typed additional items.",
  "$defs": {
    "baseTuple": {
      "type": "array",
      "prefixItems": [
        { "type": "string" },
        { "type": "integer", "format": "int32" }
      ]
    }
  },
  "allOf": [
    { "$ref": "#/$defs/baseTuple" }
  ],
  "items": { "type": "boolean" }
}
