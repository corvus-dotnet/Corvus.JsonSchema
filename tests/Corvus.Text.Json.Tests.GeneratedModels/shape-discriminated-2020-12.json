{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "title": "Shape",
    "type": "object",
    "required": [ "kind" ],
    "properties": {
        "kind": {
            "type": "string",
            "enum": [ "Circle", "Rectangle" ]
        }
    },
    "oneOf": [
        { "$ref": "#/$defs/circle" },
        { "$ref": "#/$defs/rectangle" }
    ],
    "$defs": {
        "circle": {
            "title": "Circle",
            "type": "object",
            "required": [ "kind", "radius" ],
            "properties": {
                "kind": { "const": "Circle" },
                "radius": { "type": "number" }
            }
        },
        "rectangle": {
            "title": "Rectangle",
            "type": "object",
            "required": [ "kind", "width", "height" ],
            "properties": {
                "kind": { "const": "Rectangle" },
                "width": { "type": "number" },
                "height": { "type": "number" }
            }
        }
    }
}
