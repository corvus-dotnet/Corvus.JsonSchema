{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Migration Composite Type (allOf)",
  "type": "object",
  "allOf": [
    {
      "type": "object",
      "required": [ "name" ],
      "properties": {
        "name": { "type": "string" },
        "description": { "type": "string" }
      }
    },
    {
      "type": "object",
      "required": [ "count" ],
      "properties": {
        "count": { "type": "integer" }
      }
    }
  ],
  "required": [ "budget" ],
  "properties": {
    "budget": { "type": "number" }
  }
}
